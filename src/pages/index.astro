---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recent = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---
<Layout title="Home">
  <section class="hero">
    <div class="hero-label">Director of Digital Quality &amp; Data Integrity</div>
    <h1>Goutham Madhadi</h1>
    <p class="hero-sub">
      Writing about data integrity in regulated biotech, AI tools for GxP compliance,
      and the intersection of software engineering with life sciences.
    </p>
    <div class="hero-links">
      <a href="/articles" class="btn-primary">Read Articles →</a>
      <a href="/about" class="btn-ghost">About Me</a>
    </div>
  </section>

  <section class="pillars">
    <div class="pillar">
      <div class="pillar-icon">⬡</div>
      <h3>Data Integrity</h3>
      <p>FDA 21 CFR Part 11, ALCOA+, audit trails, and building compliant systems in regulated biotech environments.</p>
    </div>
    <div class="pillar">
      <div class="pillar-icon">⬡</div>
      <h3>AI & Automation</h3>
      <p>Practical AI tools for GxP compliance, signal detection, and automation in pharma and biotech workflows.</p>
    </div>
    <div class="pillar">
      <div class="pillar-icon">⬡</div>
      <h3>Gene Editing</h3>
      <p>Quality systems, BLA submissions, and data governance in the context of next-generation genetic medicines.</p>
    </div>
  </section>

  {recent.length > 0 && (
    <section class="recent">
      <div class="section-header">
        <h2>Recent Articles</h2>
        <a href="/articles" class="see-all">All articles →</a>
      </div>
      <ul class="article-list">
        {recent.map(post => (
          <li class="article-item">
            <a href={`/articles/${post.slug}`} class="article-link">
              <span class="article-title">{post.data.title}</span>
              <span class="article-arrow">→</span>
            </a>
            <p class="article-excerpt">{post.data.description}</p>
            <div class="article-foot">
              <time class="article-date">
                {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </time>
              {post.data.tags.slice(0, 2).map(tag => <span class="tag">{tag}</span>)}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>

<style>
  .hero {
    padding: 3rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 3rem;
  }

  .hero-label {
    font-size: 0.8rem;
    font-family: var(--mono);
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #09090b;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    transition: background 0.15s;
  }

  .btn-primary:hover { background: var(--accent-h); color: #09090b; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    color: var(--muted);
    font-size: 0.9rem;
    padding: 0.6rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: color 0.15s, border-color 0.15s;
  }

  .btn-ghost:hover { color: var(--text); border-color: var(--muted); }

  /* Pillars */
  .pillars {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 3.5rem;
  }

  .pillar {
    background: var(--bg);
    padding: 1.75rem 1.5rem;
    transition: background 0.15s;
  }

  .pillar:hover { background: var(--surface); }

  .pillar-icon {
    font-size: 1.2rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .pillar h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .pillar p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* Recent articles */
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .see-all {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .see-all:hover { color: var(--accent); }

  .article-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .article-item:last-child { border-bottom: none; }

  .article-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--text);
    margin-bottom: 0.4rem;
  }

  .article-link:hover .article-title { color: var(--accent); }

  .article-title {
    font-size: 1rem;
    font-weight: 500;
    transition: color 0.15s;
  }

  .article-arrow {
    color: var(--border);
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .article-link:hover .article-arrow { color: var(--accent); }

  .article-excerpt {
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  .article-foot {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .article-date {
    font-size: 0.78rem;
    color: var(--muted);
    font-family: var(--mono);
  }
</style>
