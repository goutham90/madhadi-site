---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recent = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);

const pillarImg = {
  'data-integrity': '/images/records-review.jpg',
  'csv-csa': '/images/records-server.jpg',
  'equipment-qualification': '/images/instrument-bench.jpg',
  'quality-assurance': '/images/audit-signing.jpg',
  'audits-inspection': '/images/audit-paperwork.jpg',
  'cell-gene-therapy': '/images/microscopy-blue.jpg',
  'manufacturing-automation': '/images/manufacturing-cleanroom.jpg',
  'ai-automation': '/images/instrument-machine.jpg',
};
const featured = recent[0];
const featuredImg = (featured?.data.pillar && pillarImg[featured.data.pillar]) || '/images/lab-glassware.jpg';
const featRead = Math.max(1, Math.ceil((featured?.body?.split(/\s+/).length ?? 0) / 220));
const rest = recent.slice(1);

const entries = [
  { n: '01', tier: 'Beginner', href: '/tracks/foundations', title: 'Foundations',
    blurb: 'Regulatory framework, ALCOA+ principles, GAMP 5, and what FDA and EMA actually inspect. For anyone entering the field or building a program from scratch.',
    samples: [{ t: 'What Is GMP?', s: 'what-is-gmp' }, { t: 'Data Integrity Foundations', s: 'data-integrity-foundations' }, { t: 'GxP Roles Explained', s: 'gxp-roles-responsibilities' }] },
  { n: '02', tier: 'Intermediate', href: '/tracks/implementation', title: 'Implementation',
    blurb: 'Audit trail design, validation deliverables, CSV/CSA, manufacturing automation, and inspection readiness. For practitioners building or inheriting GxP systems.',
    samples: [{ t: 'Audit Trail Design and Review', s: 'audit-trail-design-and-review' }, { t: 'GAMP 5, Second Edition', s: 'gamp5-csv-framework' }, { t: 'CSV Risk Assessment', s: 'csv-risk-assessment-methodology' }] },
  { n: '03', tier: 'Advanced', href: '/tracks/advanced', title: 'Program & Leadership',
    blurb: 'Enterprise DI program architecture, 483 responses, CSA, cloud validation, CGT-specific challenges, and AI tooling in regulated environments.',
    samples: [{ t: 'DI Program Architecture', s: 'di-program-architecture' }, { t: 'DI Gap Assessment', s: 'di-gap-assessment-methodology' }, { t: 'BLA Readiness', s: 'bla-readiness-data-package' }] },
];

const pillars = [
  { slug: 'data-integrity', name: 'Data Integrity', desc: 'ALCOA+, DI program architecture, audit trail design, warning-letter patterns.' },
  { slug: 'csv-csa', name: 'CSV / CSA', desc: 'GAMP 5, validation lifecycle, the CSA risk-based approach, cloud and SaaS.' },
  { slug: 'equipment-qualification', name: 'Equipment Qualification', desc: 'IQ/OQ/PQ, USP <1058>, AIQ lifecycle, analytical instruments.' },
  { slug: 'quality-assurance', name: 'Quality Assurance', desc: 'PQS, ICH Q10, change control, CAPA, document management.' },
  { slug: 'audits-inspection', name: 'Audits & Inspection', desc: 'FDA inspection readiness, 483 responses, front- and back-room operations.' },
  { slug: 'cell-gene-therapy', name: 'Cell & Gene Therapy', desc: 'CGT data integrity, potency assays, BLA-level scrutiny, viral vectors.' },
  { slug: 'manufacturing-automation', name: 'Manufacturing Automation', desc: 'MES, EBR, SCADA, DCS, PLC audit trails, review-by-exception.' },
  { slug: 'ai-automation', name: 'AI & Automation', desc: '21 CFR-compliant AI tools, NLP for audit-trail review, data pipelines.' },
];

const roles = [
  { role: 'CSV Consultant', desc: 'Scoping validations, writing protocols, risk assessments, change control, retroactive validation, vendor qualification.', articles: [{ title: 'GAMP 5 Second Edition', slug: 'gamp5-csv-framework' }, { title: 'CSV Risk Assessment Methodology', slug: 'csv-risk-assessment-methodology' }, { title: 'Validation Deliverables Guide', slug: 'validation-deliverables-guide' }, { title: 'Change Control for Validated Systems', slug: 'change-control-validated-systems' }] },
  { role: 'Data Integrity Expert', desc: 'DI gap assessments, audit trail review, forensic data analysis, remediation programs, DI training design.', articles: [{ title: 'Audit Trail Design and Review', slug: 'audit-trail-design-and-review' }, { title: 'DI Gap Assessment Methodology', slug: 'di-gap-assessment-methodology' }, { title: 'DI Remediation Program', slug: 'di-remediation-program' }, { title: 'Quality Culture and DI Failures', slug: 'quality-culture-di-failures' }] },
  { role: 'QMS Specialist', desc: 'CAPA management, document control, deviation handling, internal audits, supplier qualification, training programs.', articles: [{ title: 'CAPA: Corrective and Preventive Action', slug: 'what-is-a-capa' }, { title: 'Deviation Management', slug: 'deviation-management' }, { title: 'Document Control Fundamentals', slug: 'document-control-fundamentals' }, { title: 'Internal Audit Program', slug: 'internal-audit-program' }] },
  { role: 'Quality Assurance', desc: 'OOS investigations, batch record review, process validation, stability programs, inspection readiness.', articles: [{ title: 'OOS Investigation Process', slug: 'oos-investigation-process' }, { title: 'Process Validation Lifecycle', slug: 'process-validation-lifecycle' }, { title: 'Stability Programs: ICH Q1A-Q1F', slug: 'stability-programs-ich' }, { title: 'FDA Inspection Readiness', slug: 'fda-inspection-readiness' }] },
  { role: 'Instrument & Equipment Qualification', desc: 'IQ/OQ/PQ lifecycle, analytical instrument qualification, method validation, method transfer, calibration programs.', articles: [{ title: 'Equipment Qualification Lifecycle', slug: 'equipment-qualification-lifecycle' }, { title: 'Analytical Instrument Qualification', slug: 'analytical-instrument-qualification' }, { title: 'Method Validation: ICH Q2(R2)', slug: 'method-validation-essentials' }, { title: 'Analytical Method Transfer', slug: 'analytical-method-transfer' }] },
  { role: 'Clinical Quality Assurance', desc: 'GCP data integrity, EDC validation, TMF management, clinical audit programs, BLA data packages.', articles: [{ title: 'Clinical QA: GCP Data Integrity', slug: 'clinical-qa-gcp-data-integrity' }, { title: 'BLA Readiness: Data Package Architecture', slug: 'bla-readiness-data-package' }, { title: 'FDA vs EMA Inspection Dynamics', slug: 'fda-vs-ema-inspection-dynamics' }] },
  { role: 'Inspection Readiness Consultant', desc: 'Pre-inspection preparation, 483 response strategy, FDA vs EMA dynamics, front/back room operations, DI inspection focus.', articles: [{ title: 'FDA Inspection Readiness', slug: 'fda-inspection-readiness' }, { title: 'FDA 483 Response Strategy', slug: 'fda-483-response-strategy' }, { title: 'FDA Warning Letter Patterns', slug: 'fda-warning-letters-patterns' }, { title: 'Internal Audit Program', slug: 'internal-audit-program' }] },
  { role: 'New to GxP / Career Switcher', desc: 'Start with the foundations. What GMP is, who does what, the systems involved, and how to build your knowledge from scratch.', articles: [{ title: 'What Is GMP?', slug: 'what-is-gmp' }, { title: 'GxP Roles Explained', slug: 'gxp-roles-responsibilities' }, { title: 'GxP Computerized Systems Overview', slug: 'gxp-systems-overview' }, { title: 'Breaking Into GxP Quality', slug: 'breaking-into-gxp-quality' }] },
];

const topics = [
  { name: 'Data Integrity', count: 14 }, { name: 'GxP', count: 22 }, { name: 'Validation', count: 14 }, { name: 'FDA', count: 12 }, { name: 'QMS', count: 9 }, { name: 'ALCOA+', count: 5 }, { name: 'GAMP 5', count: 5 }, { name: 'Laboratory', count: 7 }, { name: 'GMP', count: 6 }, { name: '21 CFR Part 11', count: 5 }, { name: 'Audit Trail', count: 5 }, { name: 'Cell & Gene Therapy', count: 5 }, { name: 'Inspection', count: 6 }, { name: 'CAPA', count: 4 }, { name: 'Warning Letters', count: 3 }, { name: 'Process Validation', count: 3 }, { name: 'Clinical QA', count: 2 }, { name: 'BLA', count: 3 }, { name: 'Method Validation', count: 3 }, { name: 'Career', count: 4 },
];

const fmtShort = (d) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const tierColor = { Beginner: 'var(--accent)', Intermediate: 'var(--violet)', Advanced: '#FF8A5B' };
---
<Layout title="Home" wide={true}>
  <!-- ═════ HERO ═════ -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="wrap hero-in">
      <div class="hero-copy" data-reveal>
        <span class="pill"><span class="dot"></span>Field manual · v3 · {allArticles.length} records</span>
        <h1 class="hero-h1">The working record of<br>how quality <span class="hl">actually</span> holds&nbsp;up.</h1>
        <p class="hero-lead">Operational depth on data integrity, validation, QMS, process validation, inspection readiness, and cell &amp; gene therapy — written for practitioners who need to do the job, not pass a quiz.</p>
        <div class="hero-cta">
          <a href="/start" class="btn-accent">Start the field manual →</a>
          <a href="/articles" class="btn-ghost">Browse all {allArticles.length} articles</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><span class="stat-n">{allArticles.length}</span><span class="stat-l">Records</span></div>
          <div class="stat"><span class="stat-n">08</span><span class="stat-l">Disciplines</span></div>
          <div class="stat"><span class="stat-n">03</span><span class="stat-l">Tracks</span></div>
          <div class="stat"><span class="stat-n">PD</span><span class="stat-l">Public domain</span></div>
        </div>
      </div>
      <aside class="hero-panel" data-reveal>
        <div class="panel-top"><span class="mono-label">verified_record.log</span><span class="panel-dots"><i></i><i></i><i></i></span></div>
        <div class="panel-body">
          <div class="line"><span class="ok">✓</span> ALCOA+ &nbsp;<span class="dim">attributable · legible · contemporaneous</span></div>
          <div class="line"><span class="ok">✓</span> Audit trail &nbsp;<span class="dim">complete · reviewed · secure</span></div>
          <div class="line"><span class="ok">✓</span> GAMP 5 &nbsp;<span class="dim">risk-based · fit-for-intended-use</span></div>
          <div class="line"><span class="ok">✓</span> 21 CFR Part 11 &nbsp;<span class="dim">e-sig · controls · validated</span></div>
          <div class="line"><span class="ok">✓</span> Inspection-ready &nbsp;<span class="dim">front room · back room</span></div>
          <div class="line build"><span class="run">▸</span> CGT · BLA readiness &nbsp;<span class="dim">in progress…</span></div>
        </div>
        <div class="panel-foot"><span class="marginalia">No marketing. No paywall. No popup. Just the record.</span></div>
      </aside>
    </div>
  </section>

  <!-- ═════ FEATURED ═════ -->
  {featured && (
    <section class="wrap sec">
      <div class="sec-head" data-reveal><span class="kicker eyebrow">Latest record</span><a href="/articles" class="sec-link">All articles →</a></div>
      <a href={`/articles/${featured.slug}`} class="feature" data-reveal>
        <div class="feature-img"><img src={featuredImg} alt="" loading="lazy" /></div>
        <div class="feature-body">
          <span class="mono-label">{featured.data.pillar?.replace(/-/g,' ') ?? 'Practice'} · {fmtShort(featured.data.pubDate)} · {featRead} min</span>
          <h2 class="feature-h">{featured.data.title}</h2>
          <p class="feature-desc">{featured.data.description}</p>
          <span class="feature-go">Read the record →</span>
        </div>
      </a>
    </section>
  )}

  <!-- ═════ TRACKS ═════ -->
  <section class="wrap sec">
    <div class="sec-head" data-reveal>
      <div><span class="kicker eyebrow">Where to begin</span><h2 class="sec-h">Three ways in, by depth.</h2></div>
      <p class="sec-note">Same topics, explained differently depending on where you are. Pick the track that matches today — not the one you aspire to.</p>
    </div>
    <div class="tracks">
      {entries.map(e => (
        <div class="track" data-reveal style={`--c:${tierColor[e.tier]}`}>
          <div class="track-top"><span class="track-n">{e.n}</span><span class="track-tier">{e.tier}</span></div>
          <h3 class="track-title">{e.title}</h3>
          <p class="track-blurb">{e.blurb}</p>
          <div class="track-samples">{e.samples.map(s => <a href={`/articles/${s.s}`} class="chip">{s.t}</a>)}</div>
          <a href={e.href} class="track-go">Open track →</a>
        </div>
      ))}
    </div>
  </section>

  <!-- ═════ DISCIPLINES / PILLARS ═════ -->
  <section class="band">
    <div class="wrap sec">
      <div class="sec-head" data-reveal>
        <div><span class="kicker eyebrow">The eight disciplines</span><h2 class="sec-h">Everything quality runs on.</h2></div>
        <a href="/pillars" class="sec-link">All pillars →</a>
      </div>
      <div class="grid8">
        {pillars.map((p, i) => (
          <a href={`/pillars/${p.slug}`} class="disc" data-reveal>
            <span class="disc-n">{String(i+1).padStart(2,'0')}</span>
            <h3 class="disc-name">{p.name}</h3>
            <p class="disc-desc">{p.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═════ BY ROLE ═════ -->
  <section class="wrap sec">
    <div class="sec-head" data-reveal><div><span class="kicker eyebrow">By role</span><h2 class="sec-h">Find your shelf.</h2></div>
      <p class="sec-note">Pick the hat you wear and jump straight to the records that matter for it.</p></div>
    <div class="roles">
      {roles.map(r => (
        <div class="role" data-reveal>
          <h3 class="role-name">{r.role}</h3>
          <p class="role-desc">{r.desc}</p>
          <ul class="role-list">{r.articles.slice(0,4).map(a => <li><a href={`/articles/${a.slug}`}>{a.title}</a></li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ═════ RECENT ═════ -->
  {rest.length > 0 && (
    <section class="band">
      <div class="wrap sec">
        <div class="sec-head" data-reveal><div><span class="kicker eyebrow">Recently added</span><h2 class="sec-h">Fresh off the bench.</h2></div><a href="/articles" class="sec-link">All →</a></div>
        <div class="recent">
          {rest.map(a => (
            <a href={`/articles/${a.slug}`} class="rec" data-reveal>
              <span class="mono-label">{fmtShort(a.data.pubDate)}</span>
              <h3 class="rec-h">{a.data.title}</h3>
              <p class="rec-desc">{a.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═════ TOPICS ═════ -->
  <section class="wrap sec">
    <div class="sec-head" data-reveal><div><span class="kicker eyebrow">Browse by topic</span><h2 class="sec-h">The index.</h2></div><a href="/topics" class="sec-link">All topics →</a></div>
    <div class="topics" data-reveal>
      {topics.map(t => <a href={`/topics/${t.name.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'')}`} class="topic">{t.name}<span>{t.count}</span></a>)}
    </div>
  </section>

  <!-- ═════ CTA ═════ -->
  <section class="wrap">
    <div class="cta" data-reveal>
      <div class="cta-glow"></div>
      <span class="kicker eyebrow">Start here</span>
      <h2 class="cta-h">Stop skimming. Start using.</h2>
      <p class="cta-lead">A guided path through the foundations to the program-level work — in the order a real career actually needs it.</p>
      <div class="hero-cta"><a href="/start" class="btn-accent">Begin the field manual →</a><a href="/about" class="btn-ghost">Who writes this</a></div>
    </div>
  </section>
</Layout>

<style>
  .sec { padding: 78px 0 0; }
  .sec-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 38px; }
  .sec-h { font-size: clamp(1.9rem, 3.6vw, 3rem); margin-top: 12px; }
  .sec-note { color: var(--faint); max-width: 34ch; font-size: 0.95rem; }
  .sec-link { font-family: var(--mono); font-size: 0.78rem; letter-spacing: 0.08em; color: var(--accent); white-space: nowrap; }
  .sec-link:hover { color: var(--text); }
  .band { background: var(--bg-2); border-block: 1px solid var(--line); margin-top: 78px; }
  .band .sec { padding-block: 78px; }

  /* hero */
  .hero { position: relative; padding: 70px 0 30px; }
  .hero-glow { position: absolute; inset: -10% -10% auto -10%; height: 520px; background: radial-gradient(50% 60% at 30% 0%, rgba(52,229,155,0.16), transparent 70%), radial-gradient(40% 50% at 80% 10%, rgba(138,125,255,0.14), transparent 70%); filter: blur(10px); z-index: -1; }
  .hero-in { display: grid; grid-template-columns: 1.15fr 0.85fr; gap: 56px; align-items: center; }
  .hero-h1 { font-size: clamp(2.5rem, 5.6vw, 4.4rem); letter-spacing: -0.04em; margin: 22px 0 0; }
  .hero-h1 .hl { color: var(--accent); font-style: italic; }
  .hero-lead { font-size: clamp(1.05rem, 1.4vw, 1.22rem); color: var(--muted); max-width: 46ch; margin: 22px 0 30px; line-height: 1.6; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 14px; }
  .hero-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-top: 42px; padding-top: 28px; border-top: 1px solid var(--line); }
  .stat-n { display: block; font-family: var(--display); font-size: 1.9rem; font-weight: 600; color: var(--text); letter-spacing: -0.03em; }
  .stat-l { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--faint); }

  .hero-panel { background: linear-gradient(180deg, var(--surface), var(--bg-2)); border: 1px solid var(--line-2); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
  .panel-top { display: flex; align-items: center; justify-content: space-between; padding: 13px 16px; border-bottom: 1px solid var(--line); background: rgba(255,255,255,0.02); }
  .panel-dots i { display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: var(--line-2); margin-left: 6px; }
  .panel-body { padding: 18px 16px; font-family: var(--mono); font-size: 0.82rem; line-height: 2.05; }
  .panel-body .line { color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .panel-body .ok { color: var(--accent); }
  .panel-body .run { color: var(--violet); }
  .panel-body .dim { color: var(--faint); }
  .panel-body .build { color: var(--text); }
  .panel-foot { padding: 13px 16px; border-top: 1px solid var(--line); }

  /* feature */
  .feature { display: grid; grid-template-columns: 1.05fr 1fr; gap: 0; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg); overflow: hidden; transition: border-color .2s, transform .2s; }
  .feature:hover { border-color: var(--line-2); transform: translateY(-3px); }
  .feature-img { overflow: hidden; min-height: 280px; }
  .feature-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.2) contrast(1.05); transition: transform .5s; }
  .feature:hover .feature-img img { transform: scale(1.04); }
  .feature-body { padding: 40px; display: flex; flex-direction: column; justify-content: center; }
  .feature-h { font-size: clamp(1.5rem, 2.5vw, 2.1rem); margin: 14px 0 14px; }
  .feature-desc { color: var(--muted); margin-bottom: 22px; }
  .feature-go { font-family: var(--mono); font-size: 0.8rem; color: var(--accent); letter-spacing: 0.06em; }

  /* tracks */
  .tracks { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
  .track { position: relative; background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 26px; display: flex; flex-direction: column; gap: 14px; transition: transform .2s, border-color .2s; overflow: hidden; }
  .track::before { content:""; position:absolute; inset:0 auto 0 0; width:3px; background: var(--c); opacity: 0.85; }
  .track:hover { transform: translateY(-4px); border-color: var(--c); }
  .track-go::after { content:""; position:absolute; inset:0; z-index:0; }
  .track .chip, .track-go { position: relative; z-index: 1; }
  .track-top { display: flex; align-items: center; justify-content: space-between; }
  .track-n { font-family: var(--mono); font-size: 1.5rem; color: var(--c); font-weight: 700; }
  .track-tier { font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--c); border: 1px solid var(--c); padding: 4px 9px; border-radius: 999px; }
  .track-title { font-size: 1.45rem; }
  .track-blurb { font-size: 0.94rem; color: var(--muted); flex: 1; }
  .track-samples { display: flex; flex-wrap: wrap; gap: 7px; }
  .chip { font-family: var(--mono); font-size: 0.68rem; color: var(--muted); border: 1px solid var(--line); padding: 5px 9px; border-radius: 7px; transition: .15s; }
  .chip:hover { border-color: var(--c); color: var(--text); }
  .track-go { font-family: var(--mono); font-size: 0.78rem; color: var(--text); letter-spacing: 0.05em; margin-top: 2px; }

  /* disciplines */
  .grid8 { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .disc { background: var(--bg-2); padding: 26px 22px; transition: background .2s; position: relative; }
  .disc:hover { background: var(--surface); }
  .disc-n { font-family: var(--mono); font-size: 0.72rem; color: var(--accent); letter-spacing: 0.1em; }
  .disc-name { font-size: 1.18rem; margin: 12px 0 9px; }
  .disc-desc { font-size: 0.88rem; color: var(--faint); }

  /* roles */
  .roles { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; }
  .role { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; transition: border-color .2s, transform .2s; }
  .role:hover { border-color: var(--line-2); transform: translateY(-3px); }
  .role-name { font-size: 1.3rem; margin-bottom: 8px; }
  .role-desc { font-size: 0.92rem; color: var(--muted); margin-bottom: 16px; }
  .role-list { list-style: none; display: grid; gap: 2px; }
  .role-list a { display: flex; gap: 10px; align-items: baseline; font-size: 0.92rem; color: var(--muted); padding: 7px 0; border-top: 1px solid var(--line); transition: color .15s, padding-left .15s; }
  .role-list a::before { content:"→"; color: var(--accent); font-family: var(--mono); font-size: 0.8rem; }
  .role-list a:hover { color: var(--text); padding-left: 6px; }

  /* recent */
  .recent { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; }
  .rec { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); padding: 26px; transition: border-color .2s, transform .2s; }
  .rec:hover { border-color: var(--accent); transform: translateY(-3px); }
  .rec-h { font-size: 1.3rem; margin: 12px 0 10px; }
  .rec-desc { font-size: 0.92rem; color: var(--muted); }

  /* topics */
  .topics { display: flex; flex-wrap: wrap; gap: 10px; }
  .topic { display: inline-flex; align-items: center; gap: 9px; padding: 9px 14px; background: var(--surface); border: 1px solid var(--line); border-radius: 10px; font-size: 0.9rem; color: var(--muted); transition: .18s; }
  .topic span { font-family: var(--mono); font-size: 0.7rem; color: var(--accent); }
  .topic:hover { border-color: var(--accent); color: var(--text); transform: translateY(-2px); }

  /* cta */
