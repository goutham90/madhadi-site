---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const recent = allArticles
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);

const pillarImg = {
  'data-integrity': '/images/records-review.jpg',
  'csv-csa': '/images/records-server.jpg',
  'equipment-qualification': '/images/instrument-bench.jpg',
  'quality-assurance': '/images/audit-signing.jpg',
  'audits-inspection': '/images/audit-paperwork.jpg',
  'cell-gene-therapy': '/images/microscopy-blue.jpg',
  'manufacturing-automation': '/images/manufacturing-cleanroom.jpg',
  'ai-automation': '/images/instrument-machine.jpg',
};
const featured = recent[0];
const featuredImg = (featured?.data.pillar && pillarImg[featured.data.pillar]) || '/images/lab-glassware.jpg';
const featRead = Math.max(1, Math.ceil((featured?.body?.split(/\s+/).length ?? 0) / 220));
const rest = recent.slice(1);

const entries = [
  { n: '01', tier: 'Beginner', href: '/tracks/foundations', title: 'Foundations',
    blurb: 'Regulatory framework, ALCOA+ principles, GAMP 5, and what FDA and EMA actually inspect. For anyone entering the field or building a program from scratch.',
    samples: [{ t: 'What Is GMP?', s: 'what-is-gmp' }, { t: 'Data Integrity Foundations', s: 'data-integrity-foundations' }, { t: 'GxP Roles Explained', s: 'gxp-roles-responsibilities' }] },
  { n: '02', tier: 'Intermediate', href: '/tracks/implementation', title: 'Implementation',
    blurb: 'Audit trail design, validation deliverables, CSV/CSA, manufacturing automation, and inspection readiness. For practitioners building or inheriting GxP systems.',
    samples: [{ t: 'Audit Trail Design and Review', s: 'audit-trail-design-and-review' }, { t: 'GAMP 5, Second Edition', s: 'gamp5-csv-framework' }, { t: 'CSV Risk Assessment', s: 'csv-risk-assessment-methodology' }] },
  { n: '03', tier: 'Advanced', href: '/tracks/advanced', title: 'Program & Leadership',
    blurb: 'Enterprise DI program architecture, 483 responses, CSA, cloud validation, advanced-modality and biologics challenges, and AI tooling in regulated environments.',
    samples: [{ t: 'DI Program Architecture', s: 'di-program-architecture' }, { t: 'DI Gap Assessment', s: 'di-gap-assessment-methodology' }, { t: 'BLA Readiness', s: 'bla-readiness-data-package' }] },
];

import { PILLARS } from '../data/pillars';
const pillars = PILLARS;

const roles = [
  { role: 'CSV Consultant', desc: 'Scoping validations, writing protocols, risk assessments, change control, retroactive validation, vendor qualification.', articles: [{ title: 'GAMP 5 Second Edition', slug: 'gamp5-csv-framework' }, { title: 'CSV Risk Assessment Methodology', slug: 'csv-risk-assessment-methodology' }, { title: 'Validation Deliverables Guide', slug: 'validation-deliverables-guide' }, { title: 'Change Control for Validated Systems', slug: 'change-control-validated-systems' }] },
  { role: 'Data Integrity Expert', desc: 'DI gap assessments, audit trail review, forensic data analysis, remediation programs, DI training design.', articles: [{ title: 'Audit Trail Design and Review', slug: 'audit-trail-design-and-review' }, { title: 'DI Gap Assessment Methodology', slug: 'di-gap-assessment-methodology' }, { title: 'DI Remediation Program', slug: 'di-remediation-program' }, { title: 'Quality Culture and DI Failures', slug: 'quality-culture-di-failures' }] },
  { role: 'QMS Specialist', desc: 'CAPA management, document control, deviation handling, internal audits, supplier qualification, training programs.', articles: [{ title: 'CAPA: Corrective and Preventive Action', slug: 'what-is-a-capa' }, { title: 'Deviation Management', slug: 'deviation-management' }, { title: 'Document Control Fundamentals', slug: 'document-control-fundamentals' }, { title: 'Internal Audit Program', slug: 'internal-audit-program' }] },
  { role: 'Quality Assurance', desc: 'OOS investigations, batch record review, process validation, stability programs, inspection readiness.', articles: [{ title: 'OOS Investigation Process', slug: 'oos-investigation-process' }, { title: 'Process Validation Lifecycle', slug: 'process-validation-lifecycle' }, { title: 'Stability Programs: ICH Q1A-Q1F', slug: 'stability-programs-ich' }, { title: 'FDA Inspection Readiness', slug: 'fda-inspection-readiness' }] },
  { role: 'Instrument & Equipment Qualification', desc: 'IQ/OQ/PQ lifecycle, analytical instrument qualification, method validation, method transfer, calibration programs.', articles: [{ title: 'Equipment Qualification Lifecycle', slug: 'equipment-qualification-lifecycle' }, { title: 'Analytical Instrument Qualification', slug: 'analytical-instrument-qualification' }, { title: 'Method Validation: ICH Q2(R2)', slug: 'method-validation-essentials' }, { title: 'Analytical Method Transfer', slug: 'analytical-method-transfer' }] },
  { role: 'Clinical Quality Assurance', desc: 'GCP data integrity, EDC validation, TMF management, clinical audit programs, BLA data packages.', articles: [{ title: 'Clinical QA: GCP Data Integrity', slug: 'clinical-qa-gcp-data-integrity' }, { title: 'BLA Readiness: Data Package Architecture', slug: 'bla-readiness-data-package' }, { title: 'FDA vs EMA Inspection Dynamics', slug: 'fda-vs-ema-inspection-dynamics' }] },
  { role: 'Inspection Readiness Consultant', desc: 'Pre-inspection preparation, 483 response strategy, FDA vs EMA dynamics, front/back room operations, DI inspection focus.', articles: [{ title: 'FDA Inspection Readiness', slug: 'fda-inspection-readiness' }, { title: 'FDA 483 Response Strategy', slug: 'fda-483-response-strategy' }, { title: 'FDA Warning Letter Patterns', slug: 'fda-warning-letters-patterns' }, { title: 'Internal Audit Program', slug: 'internal-audit-program' }] },
  { role: 'New to GxP / Career Switcher', desc: 'Start with the foundations. What GMP is, who does what, the systems involved, and how to build your knowledge from scratch.', articles: [{ title: 'What Is GMP?', slug: 'what-is-gmp' }, { title: 'GxP Roles Explained', slug: 'gxp-roles-responsibilities' }, { title: 'GxP Computerized Systems Overview', slug: 'gxp-systems-overview' }, { title: 'Breaking Into GxP Quality', slug: 'breaking-into-gxp-quality' }] },
];

// Derived from the actual article tags so counts never go stale as content grows.
// Merge near-duplicate tags (e.g. "data-integrity" vs "data integrity") by a shared
// anchor key that matches the /topics page section ids.
const anchorOf = (s: string) => s.toLowerCase().trim().replace(/\s+/g, '-');
const tagAgg: Record<string, { name: string; count: number; anchor: string }> = {};
for (const a of allArticles) for (const t of (a.data.tags ?? [])) {
  const name = String(t).trim(); if (!name) continue;
  const anchor = anchorOf(name);
  if (!tagAgg[anchor]) tagAgg[anchor] = { name, count: 0, anchor };
  tagAgg[anchor].count++;
}
const topics = Object.values(tagAgg)
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
  .slice(0, 24);

const fmtShort = (d) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<Layout title="Home" wide={true}>
  <!-- ═════ PAGE HEADER ═════ -->
  <section class="hd">
    <div class="wrap hd-in">
      <div class="hd-copy">
        <span class="overline">{allArticles.length} articles · free to read</span>
        <h1 class="hd-h1">The working record of how quality actually holds up.</h1>
        <p class="hd-lead">Operational depth on data integrity, computerized system validation, the quality system, process and equipment validation, sterility, devices, clinical, and supply chain, written for everyone in biotech, pharma, and life sciences who has to do the work, not pass a quiz.</p>
        <div class="hd-cta">
          <a href="/start" class="btn-accent">Start here →</a>
          <a href="/articles" class="btn-ghost">Browse all {allArticles.length} articles</a>
        </div>
        <dl class="hd-stats">
          <div><dt>{allArticles.length}</dt><dd>Articles</dd></div>
          <div><dt>08</dt><dd>Topic areas</dd></div>
          <div><dt>03</dt><dd>Learning tracks</dd></div>
          <div><dt>Public</dt><dd>No paywall</dd></div>
        </dl>
      </div>
      <aside class="hd-card">
        <div class="hd-card-h">In this reference</div>
        <ul class="hd-card-list">
          <li><a href="/start">New here, start with the foundations</a></li>
          <li><a href="/pillars">Browse the topic areas</a></li>
          <li><a href="/articles">The full article index</a></li>
          <li><a href="/regulatory-refs">Regulatory references &amp; citations</a></li>
          <li><a href="/glossary">Glossary of GxP terms</a></li>
        </ul>
        <figure class="hd-fig">
          <img src="/images/scientist-pipette.jpg" alt="Analyst working at a laboratory bench" loading="eager" />
          <figcaption>Where the record begins, the bench.</figcaption>
        </figure>
      </aside>
    </div>
  </section>

  <!-- ═════ START BY DEPTH ═════ -->
  <section class="band">
    <div class="wrap sec">
      <header class="sec-head" data-reveal>
        <div><span class="overline">Where to begin</span><h2 class="sec-h">Three ways in, by depth</h2></div>
        <p class="sec-note">Same material, pitched differently depending on where you are. Choose the track that matches today, not the one you aspire to.</p>
      </header>
      <div class="tracks">
        {entries.map(e => (
          <div class="track" data-reveal>
            <div class="track-top"><span class="track-n">{e.n}</span><span class="track-tier">{e.tier}</span></div>
            <h3 class="track-title">{e.title}</h3>
            <p class="track-blurb">{e.blurb}</p>
            <ul class="track-list">{e.samples.map(s => <li><a href={`/articles/${s.s}`}>{s.t}</a></li>)}</ul>
            <a href={e.href} class="track-go">Open the {e.title} track →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═════ TOPIC AREAS ═════ -->
  <section class="wrap sec">
    <header class="sec-head" data-reveal>
      <div><span class="overline">The topic areas</span><h2 class="sec-h">Everything quality runs on</h2></div>
      <a href="/pillars" class="sec-link">View all topics →</a>
    </header>
    <div class="pillars">
      {pillars.map((p, i) => (
        <a href={`/pillars/${p.slug}`} class="pillar" data-reveal>
          <span class="pillar-n">{String(i+1).padStart(2,'0')}</span>
          <div><h3 class="pillar-name">{p.short}</h3><p class="pillar-desc">{p.blurb}</p></div>
          <span class="pillar-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ═════ FEATURED ═════ -->
  {featured && (
    <section class="band">
      <div class="wrap sec">
        <header class="sec-head" data-reveal><div><span class="overline">Latest</span><h2 class="sec-h">Most recent article</h2></div><a href="/articles" class="sec-link">All articles →</a></header>
        <a href={`/articles/${featured.slug}`} class="feature" data-reveal>
          <div class="feature-img"><img src={featuredImg} alt="" loading="lazy" /></div>
          <div class="feature-body">
            <span class="feature-meta">{(featured.data.pillar ?? 'practice').replace(/-/g,' ')} · {fmtShort(featured.data.pubDate)} · {featRead} min read</span>
            <h3 class="feature-h">{featured.data.title}</h3>
            <p class="feature-desc">{featured.data.description}</p>
            <span class="feature-go">Read the full article →</span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- ═════ BY ROLE ═════ -->
  <section class="wrap sec">
    <header class="sec-head" data-reveal><div><span class="overline">By role</span><h2 class="sec-h">Information for your role</h2></div>
      <p class="sec-note">Find the hat you wear and go straight to the articles that matter for it.</p></header>
    <div class="roles">
      {roles.map(r => (
        <div class="role" data-reveal>
          <h3 class="role-name">{r.role}</h3>
          <p class="role-desc">{r.desc}</p>
          <ul class="role-list">{r.articles.slice(0,4).map(a => <li><a href={`/articles/${a.slug}`}>{a.title}</a></li>)}</ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ═════ RECENT ═════ -->
  {rest.length > 0 && (
    <section class="band">
      <div class="wrap sec">
        <header class="sec-head" data-reveal><div><span class="overline">Recently published</span><h2 class="sec-h">New on the reference</h2></div><a href="/articles" class="sec-link">All →</a></header>
        <ul class="recent">
          {rest.map(a => (
            <li class="rec" data-reveal>
              <span class="rec-date">{fmtShort(a.data.pubDate)}</span>
              <div><a href={`/articles/${a.slug}`} class="rec-h">{a.data.title}</a><p class="rec-desc">{a.data.description}</p></div>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- ═════ TOPICS INDEX ═════ -->
  <section class="wrap sec">
    <header class="sec-head" data-reveal><div><span class="overline">Browse by topic</span><h2 class="sec-h">Subject index</h2></div><a href="/topics" class="sec-link">All topics →</a></header>
    <div class="topics" data-reveal>
      {topics.map(t => <a href={`/topics#${t.anchor}`} class="topic">{t.name} <span>{t.count}</span></a>)}
    </div>
  </section>

  <!-- ═════ CTA BAND ═════ -->
  <section class="cta">
    <div class="wrap cta-in" data-reveal>
      <div>
        <span class="overline overline-light">Start here</span>
        <h2 class="cta-h">A guided path, in the order a real career needs it.</h2>
        <p class="cta-lead">From the foundations through to program-level work, sequenced the way the job actually demands.</p>
      </div>
      <div class="cta-actions"><a href="/start" class="btn-light">Begin the reference →</a><a href="/about" class="cta-link">Who writes this?</a></div>
    </div>
  </section>
</Layout>

<style>
  .sec { padding: 64px 0; }
  .band { background: var(--panel); border-block: 1px solid var(--line); }
  .sec-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 28px; margin-bottom: 34px; padding-bottom: 18px; border-bottom: 2px solid var(--navy); }
  .sec-h { font-size: clamp(1.7rem, 3vw, 2.4rem); margin-top: 8px; }
  .sec-note { color: var(--muted); max-width: 36ch; font-size: 0.96rem; }
  .sec-link { font-weight: 600; font-size: 0.95rem; white-space: nowrap; }
  .overline-light { color: #fff; } .overline-light::before { background: var(--gold); }

  /* header */
  .hd { background:
      linear-gradient(180deg, #fff, var(--page));
      padding: 56px 0 0; }
  .hd-in { display: grid; grid-template-columns: 1.5fr 1fr; gap: 56px; align-items: start; }
  .hd-h1 { font-size: clamp(2.2rem, 4.6vw, 3.5rem); line-height: 1.1; margin: 18px 0 0; letter-spacing: -0.02em; }
  .hd-lead { font-size: clamp(1.08rem, 1.5vw, 1.28rem); color: var(--ink-2); max-width: 48ch; margin: 22px 0 28px; line-height: 1.55; }
  .hd-cta { display: flex; flex-wrap: wrap; gap: 13px; }
  .hd-stats { display: grid; grid-template-columns: repeat(4,auto); gap: 36px; margin-top: 40px; padding-top: 26px; border-top: 1px solid var(--line); }
  .hd-stats dt { font-family: var(--display); font-size: 2rem; font-weight: 700; color: var(--navy); line-height: 1; }
  .hd-stats dd { font-size: 0.8rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 5px; font-weight: 600; }

  .hd-card { border: 1px solid var(--line-strong); border-top: 4px solid var(--navy); border-radius: var(--radius); background: #fff; box-shadow: var(--shadow); overflow: hidden; }
  .hd-card-h { background: var(--panel); padding: 14px 20px; font-weight: 700; color: var(--navy); font-size: 0.92rem; letter-spacing: 0.02em; border-bottom: 1px solid var(--line); }
  .hd-card-list { list-style: none; padding: 8px 20px 14px; }
  .hd-card-list li { border-bottom: 1px solid var(--line); }
  .hd-card-list li:last-child { border-bottom: none; }
  .hd-card-list a { display: flex; gap: 9px; padding: 12px 0; font-weight: 600; font-size: 0.95rem; color: var(--blue); }
  .hd-card-list a::before { content:"›"; color: var(--gold); font-weight: 700; }
  .hd-card-list a:hover { text-decoration: underline; }
  .hd-fig { margin: 0; }
  .hd-fig img { width: 100%; height: 190px; object-fit: cover; }
  .hd-fig figcaption { font-size: 0.78rem; color: var(--faint); padding: 9px 20px; background: var(--panel); border-top: 1px solid var(--line); }

  /* tracks */
  .tracks { display: grid; grid-template-columns: repeat(3,1fr); gap: 24px; }
  .track { background: #fff; border: 1px solid var(--line-strong); border-top: 4px solid var(--navy); border-radius: var(--radius); padding: 26px 24px; display: flex; flex-direction: column; gap: 12px; transition: box-shadow .15s, transform .15s; }
  .track:hover { box-shadow: var(--shadow); transform: translateY(-2px); }
  .track-top { display: flex; align-items: center; justify-content: space-between; }
  .track-n { font-family: var(--display); font-size: 1.6rem; font-weight: 700; color: var(--navy); }
  .track-tier { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--blue); background: #eaf2f9; padding: 4px 10px; border-radius: 3px; }
  .track-title { font-size: 1.4rem; }
  .track-blurb { font-size: 0.93rem; color: var(--muted); flex: 1; }
  .track-list { list-style: none; display: grid; gap: 0; }
  .track-list li { border-top: 1px solid var(--line); }
  .track-list a { display: block; padding: 9px 0 9px 16px; position: relative; font-size: 0.92rem; font-weight: 600; }
  .track-list a::before { content:"›"; position: absolute; left: 0; color: var(--gold); }
  .track-go { font-weight: 700; font-size: 0.93rem; margin-top: 4px; }

  /* pillars */
  .pillars { display: grid; grid-template-columns: repeat(2,1fr); gap: 0; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .pillar { display: grid; grid-template-columns: auto 1fr auto; gap: 18px; align-items: center; padding: 22px 24px; background: #fff; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); transition: background .15s; }
  .pillar:nth-child(2n) { border-right: none; }
  .pillar:hover { background: var(--panel); text-decoration: none; }
  .pillar-n { font-family: var(--display); font-size: 1.3rem; font-weight: 700; color: var(--gold); }
  .pillar-name { font-size: 1.22rem; margin-bottom: 4px; }
  .pillar-desc { font-size: 0.9rem; color: var(--muted); }
  .pillar-arrow { color: var(--blue); font-weight: 700; font-size: 1.1rem; }

  /* feature */
  .feature { display: grid; grid-template-columns: 1.1fr 1.3fr; background: #fff; border: 1px solid var(--line-strong); border-radius: var(--radius); overflow: hidden; transition: box-shadow .15s; }
  .feature:hover { box-shadow: var(--shadow); text-decoration: none; }
  .feature-img { min-height: 260px; } .feature-img img { width: 100%; height: 100%; object-fit: cover; }
  .feature-body { padding: 38px; }
  .feature-meta { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--blue); }
  .feature-h { font-size: clamp(1.5rem, 2.4vw, 2rem); margin: 12px 0 12px; }
  .feature-desc { color: var(--ink-2); margin-bottom: 20px; }
  .feature-go { font-weight: 700; color: var(--blue); }

  /* roles */
  .roles { display: grid; grid-template-columns: repeat(2,1fr); gap: 26px 40px; }
  .role { padding-top: 4px; }
  .role-name { font-size: 1.25rem; padding-bottom: 8px; border-bottom: 2px solid var(--gold); display: inline-block; margin-bottom: 12px; }
  .role-desc { font-size: 0.92rem; color: var(--muted); margin-bottom: 12px; }
  .role-list { list-style: none; }
  .role-list li { border-top: 1px solid var(--line); }
  .role-list a { display: block; padding: 9px 0 9px 16px; position: relative; font-size: 0.93rem; font-weight: 600; }
  .role-list a::before { content:"›"; position: absolute; left: 0; color: var(--gold); }

  /* recent */
  .recent { list-style: none; display: grid; gap: 0; }
  .rec { display: grid; grid-template-columns: 130px 1fr; gap: 24px; padding: 22px 0; border-top: 1px solid var(--line); align-items: baseline; }
  .rec:first-child { border-top: 2px solid var(--navy); }
  .rec-date { font-size: 0.84rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }
  .rec-h { font-family: var(--display); font-size: 1.3rem; font-weight: 600; color: var(--navy); }
  .rec-h:hover { color: var(--blue); }
  .rec-desc { font-size: 0.94rem; color: var(--muted); margin-top: 5px; }

  /* topics */
  .topics { display: flex; flex-wrap: wrap; gap: 10px; }
  .topic { display: inline-flex; align-items: center; gap: 8px; padding: 8px 14px; background: #fff; border: 1px solid var(--line-strong); border-radius: 3px; font-size: 0.92rem; font-weight: 600; color: var(--navy); }
  .topic span { color: var(--blue); font-size: 0.8rem; }
  .topic:hover { border-color: var(--navy); background: var(--panel); text-decoration: none; }

  /* cta */
  .cta { background: var(--navy); margin-top: 0; }
  .cta-in { display: flex; justify-content: space-between; align-items: center; gap: 40px; padding: 56px 0; }
  .cta-h { color: #fff; font-size: clamp(1.7rem, 3vw, 2.4rem); margin: 12px 0; max-width: 22ch; }
  .cta-lead { color: var(--on-navy-dim); max-width: 46ch; }
  .cta-actions { display: flex; flex-direction: column; gap: 14px; align-items: flex-start; }
  .btn-light { display: inline-flex; align-items: center; gap: 9px; padding: 13px 24px; background: #fff; color: var(--navy); font-weight: 700; border-radius: var(--radius); white-space: nowrap; }
  .btn-light:hover { background: var(--panel); text-decoration: none; }
  .cta-link { color: var(--on-navy); font-weight: 600; }
  .cta-link:hover { color: #fff; }

  @media (max-width: 980px) {
    .hd-in, .tracks, .pillars, .feature, .roles { grid-template-columns: 1fr; }
    .pillar { border-right: none; } .feature-img { min-height: 200px; }
    .sec-head { flex-direction: column; align-items: flex-start; gap: 14px; }
    .cta-in { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 560px) { .rec { grid-template-columns: 1fr; gap: 6px; } .hd-stats { grid-template-columns: 1fr 1fr; gap: 22px; } }
</style>
