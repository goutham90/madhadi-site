---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<Layout title="Articles" description="Data integrity articles, ALCOA+, FDA, 21 CFR Part 11, cell & gene therapy, and AI tools for GxP compliance." wide={true}>
	<div class="articles-wrap">
		<div class="page-header">
			<div class="page-label">All Articles</div>
			<h1>Articles</h1>
			<p class="lead">In-depth writing on data integrity, regulatory compliance, and AI tools for pharma and biotech.</p>
		</div>

		<ol class="article-list">
			{sorted.map((post, i) => {
				const wordCount = post.body?.split(/\s+/).length ?? 0;
				const readTime = Math.max(1, Math.ceil(wordCount / 220));
				return (
					<li>
						<a href={`/articles/${post.slug}`} class="article-row">
							<div class="article-num">{String(i + 1).padStart(2, '0')}</div>
							<div class="article-content">
								<div class="article-tags">
									{post.data.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}
								</div>
								<h2 class="article-title">{post.data.title}</h2>
								<p class="article-desc">{post.data.description}</p>
								<div class="article-meta">
									<time>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
									<span class="sep">·</span>
									<span>{readTime} min read</span>
								</div>
							</div>
							<div class="article-arrow" aria-hidden="true">→</div>
						</a>
					</li>
				);
			})}
		</ol>
	</div>
</Layout>

<style>
	.articles-wrap {
		max-width: var(--container-narrow);
		margin: 0 auto;
		padding-top: 4rem;
	}

	.article-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--line);
	}

	.article-row {
		display: grid;
		grid-template-columns: 3rem 1fr 1.5rem;
		gap: 1.75rem;
		align-items: start;
		padding: 2rem 1rem;
		border-bottom: 1px solid var(--line);
		color: inherit;
		transition: background 0.15s ease;
	}

	.article-row:hover { background: var(--paper-2); }
	.article-row:hover .article-title { color: var(--link-h); }
	.article-row:hover .article-arrow { color: var(--brass); transform: translateX(3px); }

	.article-num {
		font-family: var(--mono);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--brass);
		padding-top: 0.35rem;
		letter-spacing: 0.04em;
	}

	.article-tags {
		display: flex;
		gap: 0.4rem;
		flex-wrap: wrap;
		margin-bottom: 0.7rem;
	}

	.article-title {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.45rem;
		line-height: 1.25;
		letter-spacing: -0.015em;
		color: var(--ink);
		margin-bottom: 0.55rem;
		transition: color 0.15s ease;
	}

	.article-desc {
		font-size: 1rem;
		color: var(--muted);
		line-height: 1.6;
		margin-bottom: 0.85rem;
		max-width: 46rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.article-meta {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-family: var(--mono);
		font-size: 0.76rem;
		color: var(--muted);
		letter-spacing: 0.02em;
	}
	.article-meta .sep { color: var(--line-2); }

	.article-arrow {
		color: var(--line-2);
		font-size: 1.2rem;
		padding-top: 0.5rem;
		transition: color 0.15s ease, transform 0.15s ease;
	}

	@media (max-width: 640px) {
		.articles-wrap { padding-top: 0; }
		.article-row {
			grid-template-columns: 1fr 1.25rem;
			gap: 1rem;
			padding: 1.75rem 0;
		}
		.article-num { display: none; }
		.article-title { font-size: 1.25rem; }
	}
</style>
