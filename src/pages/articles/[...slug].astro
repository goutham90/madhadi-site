---
import { getCollection } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
 const articles = await getCollection('articles', ({ data }) => !data.draft);
 const templates = await getCollection('templates', ({ data }) => !data.draft);
 const toRef = (t) => ({ slug: t.slug, title: t.data.title, docType: t.data.docType });
 const sortDocs = (a, b) => a.data.docType.localeCompare(b.data.docType) || a.data.title.localeCompare(b.data.title);
 return articles.map(entry => {
 const direct = templates
 .filter(t => (t.data.relatedArticles ?? []).includes(entry.slug))
 .sort(sortDocs);
 const directSlugs = new Set(direct.map(t => t.slug));
 // Fallback: if no document targets this article directly, surface up to 6 from the same
 // pillar so the article still connects to the library.
 const pillar = entry.data.pillar
 ? templates.filter(t => t.data.pillar === entry.data.pillar && !directSlugs.has(t.slug)).sort(sortDocs).slice(0, 6)
 : [];
 return {
 params: { slug: entry.slug },
 props: {
 entry,
 relatedTemplates: direct.map(toRef),
 pillarTemplates: direct.length ? [] : pillar.map(toRef),
 },
 };
 });
}

const { entry, relatedTemplates, pillarTemplates } = Astro.props;
const { Content } = await entry.render();
---
<ArticleLayout
 title={entry.data.title}
 description={entry.data.description}
 pubDate={entry.data.pubDate}
 tags={entry.data.tags}
 tier={entry.data.tier}
 pillar={entry.data.pillar}
 body={entry.body}
 relatedTemplates={relatedTemplates}
 pillarTemplates={pillarTemplates}
 pillarSlug={entry.data.pillar}
>
 <Content />
</ArticleLayout>
