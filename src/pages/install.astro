---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Install the app" description="Add madhadi.com to your home screen for a full-screen, offline experience. Simple steps for iPhone, Android, and desktop. Free, no app store, no login.">
  <header class="dc-hero">
    <div class="wrap dc-inner">
      <nav class="crumb"><a href="/">Home</a> <span>›</span> Install the app</nav>
      <h1 class="dc-h1">Use madhadi.com as an app</h1>
      <p class="dc-lead">Add it to your home screen for a full-screen experience that works offline. It is free, there is no app store, no login, and nothing to download.</p>
    </div>
  </header>

  <div class="wrap dc-body">
    <section class="ins-cta" id="ins-android">
      <h2>Android (Chrome) &amp; desktop</h2>
      <p>The reliable way, works every time:</p>
      <ol class="ins-steps">
        <li>Open the browser menu (the three dots, usually top right).</li>
        <li>Tap <strong>Install app</strong>, or <strong>Add to Home screen</strong>.</li>
        <li>Confirm <strong>Install</strong>.</li>
      </ol>
      <p>Or, when your browser offers it, one tap:</p>
      <button id="ins-btn" class="ins-btn" type="button" disabled>Install app</button>
      <p class="ins-note" id="ins-note">If this button stays grey, use the menu steps above. They always work, the one-tap option is only offered by some browsers.</p>
    </section>

    <section id="ins-ios">
      <h2>iPhone &amp; iPad (Safari)</h2>
      <p>Apple does not allow a one-tap install, so it takes three quick taps:</p>
      <ol class="ins-steps">
        <li>Tap the <strong>Share</strong> icon (the square with an arrow pointing up), at the bottom on iPhone or the top on iPad.</li>
        <li>Scroll down and tap <strong>Add to Home Screen</strong>.</li>
        <li>Tap <strong>Add</strong> in the top corner.</li>
      </ol>
      <p class="ins-note">The madhadi.com icon then sits on your home screen like any app, opening full screen.</p>
    </section>

    <section>
      <h2>What you get</h2>
      <ul class="ins-list">
        <li>Full screen, no browser bars.</li>
        <li>Offline reading of pages you have already opened.</li>
        <li>A home-screen icon and fast launch.</li>
        <li>Automatic updates, nothing to reinstall.</li>
      </ul>
      <p class="ins-note">Already added it? You can ignore this page. If you removed it from your home screen, just follow the steps above to add it again.</p>
    </section>
  </div>
</Layout>

<script>
  (function () {
    var btn = document.getElementById('ins-btn');
    var note = document.getElementById('ins-note');
    var androidSec = document.getElementById('ins-android');
    var iosSec = document.getElementById('ins-ios');
    if (!btn) return;

    var standalone = (window.matchMedia && window.matchMedia('(display-mode: standalone)').matches) || window.navigator.standalone === true;
    var ua = navigator.userAgent || '';
    var isIOS = /iphone|ipad|ipod/i.test(ua) || (/Macintosh/.test(ua) && navigator.maxTouchPoints > 1);

    if (isIOS && androidSec) { androidSec.style.display = 'none'; }
    if (!isIOS && iosSec) { iosSec.style.display = 'none'; }
    if (standalone && note) { note.textContent = 'You are already using the installed app.'; }

    function ready() {
      if (!window.__bipEvent) return;
      btn.disabled = false;
      if (note) note.textContent = 'Ready. Tap Install app above, or use the menu steps.';
    }
    ready();                                  // the event may have already fired (captured in <head>)
    window.addEventListener('bip-ready', ready); // or it arrives a moment later
    btn.addEventListener('click', function () {
      var e = window.__bipEvent;
      if (!e) { if (note) note.textContent = 'This browser did not offer one-tap install. Use the menu steps above: Install app / Add to Home screen.'; return; }
      e.prompt();
      e.userChoice.then(function (c) {
        if (note) note.textContent = (c && c.outcome === 'accepted') ? 'Installed. Check your home screen.' : 'No problem, you can install any time from the menu steps.';
        window.__bipEvent = null;
      });
    });
  })();
</script>

<style>
  .dc-hero { background: var(--navy); color: #fff; }
  .dc-inner { padding: 3.2rem 0 2.4rem; }
  .crumb { font-size: 0.82rem; color: var(--on-navy-dim); margin-bottom: 1.1rem; } .crumb a { color: var(--on-navy-dim); } .crumb a:hover { color:#fff; } .crumb span { opacity:.6; margin:0 3px; }
  .dc-h1 { color: #fff; font-size: clamp(1.9rem, 3.6vw, 2.8rem); margin: 6px 0 14px; letter-spacing: -0.025em; }
  .dc-lead { color: var(--on-navy); font-family: var(--serif); font-size: clamp(1.05rem, 1.5vw, 1.25rem); line-height: 1.5; max-width: 60ch; }
  .dc-body { max-width: var(--measure); padding: 48px 28px 60px; }
  .dc-body section { margin-bottom: 2rem; }
  .dc-body h2 { font-family: var(--display); font-size: 1.35rem; color: var(--navy); margin-bottom: 0.6rem; padding-top: 1.2rem; border-top: 1px solid var(--line); }
  .dc-body section:first-child h2 { border-top: none; padding-top: 0; }
  .dc-body p { font-family: var(--serif); font-size: 1.08rem; line-height: 1.7; color: var(--ink-2); margin-bottom: 0.9rem; }
  .dc-body a { color: var(--blue); font-weight: 600; }
  .ins-btn { background: var(--blue); color: #fff; border: 0; font-family: var(--sans); font-weight: 700; font-size: 1rem; padding: 0.8rem 1.6rem; border-radius: 10px; cursor: pointer; }
  .ins-btn:hover:not([disabled]) { background: var(--blue-d); }
  .ins-btn[disabled] { opacity: 0.5; cursor: default; }
  .ins-note { font-size: 0.92rem !important; color: var(--ink-3, #6b7076) !important; margin-top: 0.6rem; }
  .ins-steps, .ins-list { font-family: var(--serif); font-size: 1.08rem; line-height: 1.7; color: var(--ink-2); padding-left: 1.4rem; }
  .ins-steps li, .ins-list li { margin-bottom: 0.6rem; }
</style>
