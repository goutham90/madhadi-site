---
import Layout from '../layouts/Layout.astro';

const tools = [
  {
    name: 'Audit Trail Anomaly Detector',
    desc: 'Statistical analysis of LIMS/ELN audit trail exports. Flags off-hours entries, back-to-back edit sequences, bulk modifications, and user behavior outliers. Outputs a prioritized review queue for QA.',
    status: 'Active',
    stack: ['Python', 'Pandas', 'LIMS Export'],
    detail: 'Covers temporal anomalies, sequential edit patterns, metadata gaps, and statistical deviation from baseline user behavior.',
  },
  {
    name: 'ALCOA+ Gap Analyzer',
    desc: 'Parses SOP, batch record, or protocol text and cross-references it against ALCOA+ requirements and FDA data integrity guidance. Returns a structured gap report with severity ratings.',
    status: 'Active',
    stack: ['Python', 'Claude API', 'NLP'],
    detail: 'Output includes: missing attributability controls, contemporaneity gaps, completeness issues, and record endurance risks.',
  },
  {
    name: 'Deviation Pattern Classifier',
    desc: 'AI-based classifier for incoming deviation reports. Categorizes by type, assigns a risk tier, and surfaces the three most similar historical deviations for investigator reference.',
    status: 'Active',
    stack: ['Python', 'scikit-learn', 'CAPA DB'],
    detail: 'Reduces triage time and improves consistency in deviation categorization across sites.',
  },
  {
    name: '21 CFR Part 11 Assessment Tool',
    desc: 'Evaluates a computerized system against 21 CFR Part 11 requirements. Generates a readiness matrix covering audit trails, access controls, electronic signatures, and record retention.',
    status: 'Active',
    stack: ['Python', 'Excel Output', 'GxP'],
    detail: 'Designed for pre-qualification assessment and periodic review of validated systems.',
  },
  {
    name: 'Chromatography Data System Auditor',
    desc: 'Specialized audit tool for CDS platforms (Empower, Chemstation). Detects sequence injection anomalies, processing method changes, result set deletions, and integration parameter manipulation.',
    status: 'Active',
    stack: ['Python', 'CDS API', 'QC'],
    detail: 'CDS platforms are the most common source of data integrity findings in analytical QC labs.',
  },
  {
    name: 'Data Integrity Risk Register',
    desc: 'Systematic risk assessment framework for GxP systems. Scores each system on data criticality, control gaps, and detection capability. Prioritizes remediation by risk exposure.',
    status: 'Active',
    stack: ['Python', 'Risk Matrix', 'GxP'],
    detail: 'Generates a prioritized remediation roadmap aligned to FDA and EMA data integrity guidance.',
  },
];
---
<Layout title="Tools" description="Data integrity tools for GxP compliance — audit trail analysis, ALCOA+ gap assessment, deviation classification, and 21 CFR Part 11 evaluation.">
  <div class="page-header">
    <div class="page-label">Built Tools</div>
    <h1>Tools</h1>
    <p>
      Automation systems built to solve real data integrity problems in regulated biotech.
      All tools are designed with GxP validation in mind — documented, testable, and auditable.
    </p>
    <div class="callout">
      <div class="callout-title">Note</div>
      <p>These tools are built for internal GxP environments. Any AI-assisted output feeds a documented human review process — AI flags, humans decide, decisions are logged.</p>
    </div>
  </div>

  <div class="tools-grid">
    {tools.map(tool => (
      <div class="tool-card">
        <div class="tool-header">
          <h2 class="tool-name">{tool.name}</h2>
          <span class="status-badge">{tool.status}</span>
        </div>
        <p class="tool-desc">{tool.desc}</p>
        <div class="tool-detail">{tool.detail}</div>
        <div class="tool-footer">
          <div class="tool-stack">
            {tool.stack.map(s => <span class="stack-tag">{s}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    font-size: 0.72rem;
    font-family: var(--mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .page-header h1 { font-size: 2.25rem; letter-spacing: -0.03em; margin-bottom: 0.5rem; }
  .page-header > p { color: var(--muted-light); margin-bottom: 1.5rem; }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .tool-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .tool-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .tool-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .tool-name {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--text);
  }

  .status-badge {
    font-size: 0.68rem;
    font-family: var(--mono);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(52, 211, 153, 0.1);
    color: var(--green);
    border: 1px solid rgba(52, 211, 153, 0.2);
    flex-shrink: 0;
  }

  .tool-desc {
    font-size: 0.875rem;
    color: var(--muted-light);
    line-height: 1.65;
  }

  .tool-detail {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.55;
    padding: 0.75rem 1rem;
    background: var(--surface2);
    border-radius: 7px;
    border-left: 2px solid var(--border);
    flex: 1;
  }

  .tool-footer { margin-top: 0.5rem; }

  .tool-stack {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .stack-tag {
    font-size: 0.7rem;
    font-family: var(--mono);
    padding: 0.2rem 0.55rem;
    border-radius: 5px;
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
  }

  @media (max-width: 600px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
