 ['Product grouping / bracketing rationale','Reduces testing while staying defensible.'],
 ['Revalidation trigger criteria','Define when to revalidate (new product, change, periodic).'],
 ],
 },
 };

 function renderVD(type) {
 var data = vdData[type];
 var container = document.getElementById('vd-content');
 if (!container || !data) return;
 function row(cls, d) {
 return '<li class="vd-item ' + cls + '"><span class="vd-text"><span class="vd-name">' + d[0] + '</span><span class="vd-why">' + d[1] + '</span></span></li>';
 }
 container.innerHTML =
 '<div class="vd-section">' +
 '<div class="vd-section-title required-label">Required Deliverables</div>' +
 '<ul class="vd-list-items">' + data.required.map(function (d) { return row('req', d); }).join('') + '</ul>' +
 '</div>' +
 '<div class="vd-section">' +
 '<div class="vd-section-title recommended-label">Recommended / Risk-Based</div>' +
 '<ul class="vd-list-items">' + data.recommended.map(function (d) { return row('rec', d); }).join('') + '</ul>' +
 '</div>';
 }

 function selectVDType(type, btn) {
 document.querySelectorAll('.vd-type-btn').forEach(function (b) { b.classList.remove('active'); });
 btn.classList.add('active');
 renderVD(type);
 }
</script>

