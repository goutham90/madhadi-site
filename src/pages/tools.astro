---
import Layout from '../layouts/Layout.astro';

const auditGuides = [
  {
    href: '/articles/di-self-audit-checklist',
    abbr: 'DI',
    color: '#7A2E23',
    emblem: 'data-integrity',
    title: 'Data Integrity Self-Audit',
    desc: '5-layer DI compliance audit: infrastructure controls, system configuration, procedural controls, work practice forensics, and culture indicators. Structured around FDA, MHRA, WHO, and PIC/S DI expectations.',
    tier: 'Advanced',
    pillar: 'Data Integrity',
  },
  {
    href: '/articles/csv-csa-audit-checklist',
    abbr: 'CSV',
    color: '#7A2E23',
    emblem: 'csv-csa',
    title: 'CSV / CSA Program Self-Audit',
    desc: 'Evaluate your computer system validation program: system inventory, GAMP category assignments, validation documentation quality, traceability, supplier assessment, change control, and periodic review. Aligned with GAMP 5 Second Edition and FDA CSA final guidance (Feb 2026).',
    tier: 'Advanced',
    pillar: 'CSV & CSA',
  },
  {
    href: '/articles/equipment-qualification-audit-checklist',
    abbr: 'EQ',
    color: '#B26B1E',
    emblem: 'equipment-qualification',
    title: 'Equipment Qualification Audit',
    desc: 'Full lifecycle qualification audit for analytical instruments and manufacturing equipment: DQ, IQ, OQ, PQ, calibration, maintenance, periodic review, and change control. References USP <1058>, EU Annex 15, and ISPE C&Q Baseline Guide.',
    tier: 'Intermediate',
    pillar: 'Equipment Qualification',
  },
  {
    href: '/articles/qms-self-audit-checklist',
    abbr: 'QMS',
    color: '#B26B1E',
    emblem: 'quality-assurance',
    title: 'QMS Self-Audit',
    desc: 'Complete quality management system audit: document control, deviation management, CAPA quality and effectiveness, change control, training, supplier qualification, internal audits, and quality metrics. Aligned with ICH Q10 and FDA/EMA inspection expectations.',
    tier: 'Intermediate',
    pillar: 'Quality Assurance',
  },
];

const tierColors: Record<string, string> = {
  Beginner: '#3C6B4A',
  Intermediate: '#B26B1E',
  Advanced: '#7A2E23',
};
---
<Layout title="Tools" description="Interactive GxP reference tools: ALCOA+ self-assessment, GAMP 5 category decision aid, 483 response checklist, validation deliverable selector, and self-audit checklists." wide={true}>

 <!-- ═══════════ HEADER (duotone band) ═══════════ -->
 <section class="tools-hero">
 <div class="tools-hero-bg duotone duotone-soft"><img src="/images/instrument-machine.jpg" alt="" loading="eager" /></div>
 <div class="tools-hero-grad"></div>
 <div class="wrap tools-hero-inner">
 <div class="tools-hero-kick">
 <span class="kicker">Reference Tools</span>
 <span class="tools-hero-line"></span>
 <span class="marginalia">Runs in-browser · No login · No data sent</span>
 </div>
 <h1 class="tools-hero-h1">The instruments<em> on the bench.</em></h1>
 <p class="lead tools-hero-lead">
 Interactive reference tools and self-audit checklists for GxP quality work.
 Everything on this page runs in your browser. No login, no data sent anywhere.
 </p>
 </div>
 </section>

 <!-- ═══════════ AUDIT GUIDES (editorial index) ═══════════ -->
 <section class="section-tight guides">
 <div class="wrap">
 <div class="guides-head">
 <div>
 <span class="kicker">Audit Guides</span>
 <h2 class="display-2">Self-audit checklists.</h2>
 </div>
 <p class="marginalia guides-note">Detailed structured checklists to evaluate compliance programs, designed to find what FDA and EMA inspectors find.</p>
 </div>

 <ul class="index-list guides-list">
 {auditGuides.map((g, i) => {
 const tierColor = tierColors[g.tier] ?? '#837B69';
 return (
 <li>
 <a href={g.href} class="guide-row">
 <span class="guide-n">{String(i + 1).padStart(2, '0')}</span>
 <span class="emblem guide-emblem" style={`--src:url('/brand/emblems/pillar-${g.emblem}.svg'); color:${g.color}`}></span>
 <div class="guide-main">
 <div class="guide-title-row">
 <span class="guide-abbr">{g.abbr}</span>
 <h3 class="guide-title">{g.title}</h3>
 </div>
 <p class="guide-desc">{g.desc}</p>
 <div class="guide-meta">
 <span class="tier-badge" style={`background:${tierColor}1A; color:${tierColor}; border-color:${tierColor}40`}>{g.tier}</span>
 <span class="guide-pillar">{g.pillar}</span>
 </div>
 </div>
 <span class="guide-go">Open →</span>
 </a>
 </li>
 );
 })}
 </ul>
 </div>
 </section>

 <!-- ═══════════ INTERACTIVE INTRO (dark plate) ═══════════ -->
 <section class="section-tight section-dark tools-intro">
 <div class="wrap">
 <div class="tools-intro-grid">
 <div>
 <span class="kicker">Reference Tools</span>
 <h2 class="display-2">Interactive quick-reference.</h2>
 </div>
 <p class="tools-intro-desc">Client-side reference tools for common GxP assessments. Nothing is sent anywhere, these run in your browser.</p>
 </div>
 </div>
 </section>

 <!-- ═══════════ INTERACTIVE TOOLS ═══════════ -->
 <section class="section-tight tools-grid-section">
 <div class="wrap">
 <div class="checklists-grid">

 <!-- ALCOA+ Self-Assessment -->
 <div class="tool-panel checklist-card" id="alcoa-card">
 <div class="tool-panel-tab"><span class="tool-tab-num">01</span><span class="tool-tab-kind">Self-Assessment</span></div>
 <div class="checklist-header">
 <h3>ALCOA+ Self-Assessment</h3>
 <span class="checklist-count" id="alcoa-count">0 / 9</span>
 </div>
 <p class="checklist-desc">Evaluate a GxP record or system against all nine ALCOA+ principles. Check each principle only if your current controls fully satisfy it.</p>
 <div class="checklist-items" id="alcoa-items">
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Attributable</strong>, every entry traces to the person who made it.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> unique named accounts (no shared or generic logins); e-signatures bound to the record with name, date and meaning; the audit trail captures the user for every create, modify and delete.</p>
 <p><strong>Common failures:</strong> shared instrument or "admin" logins; generic accounts; e-signatures not tied to an individual; an audit trail that records the change but not who made it.</p>
 <p><strong>How to fix:</strong> enforce unique accounts (ideally SSO), disable shared logins, configure the audit trail to capture identity, and bind e-signatures per 21 CFR Part 11.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Legible</strong>, records are readable and permanently recorded.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> permanent media (ink or controlled electronic); corrections made with a single-line strike-through plus initial, date and reason; electronic data not held in obsolete or proprietary formats that can no longer be rendered.</p>
 <p><strong>Common failures:</strong> pencil entries; correction fluid or whitespace over an error; data trapped in a format the current software can no longer open.</p>
 <p><strong>How to fix:</strong> ink or electronic capture only; apply good-documentation-practice correction rules; preserve readability through format and migration controls.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Contemporaneous</strong>, recorded at the time the activity occurs.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> entries made in real time; system clocks synchronized (NTP) and not user-editable; timestamps match the true order of events; no backdating.</p>
 <p><strong>Common failures:</strong> recording later from scratch paper; backdated entries; local clock drift or a clock a user can change.</p>
 <p><strong>How to fix:</strong> require real-time entry, lock system clocks to NTP, and review audit-trail timestamps against the expected sequence.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Original</strong>, the first capture of data is preserved.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> raw data retained; dynamic records kept dynamic (a chromatogram stays re-integratable, not flattened to a PDF); any copy certified as a true copy.</p>
 <p><strong>Common failures:</strong> keeping only the printed report; deleting raw data after processing; storing a PDF of a record that should remain dynamic.</p>
 <p><strong>How to fix:</strong> retain raw and dynamic data for its full lifecycle, define a true-copy procedure, and archive originals.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Accurate</strong>, records reflect what actually happened.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> values are not manipulated; integration methods and parameters are controlled; a second person reviews critical data; calculations are verified.</p>
 <p><strong>Common failures:</strong> re-integrating until a result passes; overriding a parameter without justification; transcription errors carried forward.</p>
 <p><strong>How to fix:</strong> lock integration methods, control parameter changes, and use audit-trail review (by exception) to catch undocumented edits.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Complete</strong>, all data is included, including invalidated and OOS results.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> every run is present including failed, aborted, repeated and out-of-specification results; nothing is selectively deleted; the audit trail is intact.</p>
 <p><strong>Common failures:</strong> deleting a "bad" injection; trial or test runs not recorded; selective reporting of only the passing result.</p>
 <p><strong>How to fix:</strong> disable record deletion, require every run to be recorded and justified, and review the audit trail for gaps.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Consistent</strong>, dates, times and sequences are internally consistent.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> timestamps and sequences are in the expected chronological order within a record and reconcile across independent systems (instrument, LIMS, ERP).</p>
 <p><strong>Common failures:</strong> timestamps out of order; the same event recorded with different times in two systems; time-zone mismatches across sites.</p>
 <p><strong>How to fix:</strong> synchronize time across systems, define a single time-zone convention, and reconcile cross-system records.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Enduring</strong>, stored on durable media for the full retention period.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> durable storage; defined retention periods; backups that are actually tested by restore; migrations that preserve both data and meaning.</p>
 <p><strong>Common failures:</strong> data on a single un-backed-up drive; backups never test-restored; retention period undefined; a migration that drops metadata or the audit trail.</p>
 <p><strong>How to fix:</strong> implement backup with tested restore, set a retention schedule, archive properly, and validate any data migration.</p>
 </div>
 </div>
 <div class="cl-row">
 <label class="cl-item"><input type="checkbox" data-group="alcoa" /><span class="cl-label"><strong>Available</strong>, retrievable in human-readable form throughout retention.</span></label>
 <button type="button" class="cl-more">How to assess</button>
 <div class="cl-detail" hidden>
 <p><strong>Verify:</strong> records can be retrieved and presented in readable form across the whole retention period, including quickly to an inspector; access controls do not block legitimate retrieval.</p>
 <p><strong>Common failures:</strong> data locked inside a decommissioned system; no way to read an archived format; retrieval that takes days during an inspection.</p>
 <p><strong>How to fix:</strong> archive with a retrieval capability, migrate data off decommissioned systems, and confirm a readable export exists.</p>
 </div>
 </div>
 </div>
 <div class="checklist-progress">
 <div class="progress-bar"><div class="progress-fill" id="alcoa-fill" style="width:0%"></div></div>
 <span class="progress-label" id="alcoa-label">Not assessed</span>
 </div>
 </div>

 <!-- GAMP Category Decision Aid -->
 <div class="tool-panel checklist-card" id="gamp-card">
 <div class="tool-panel-tab"><span class="tool-tab-num">02</span><span class="tool-tab-kind">Decision Aid</span></div>
 <div class="checklist-header">
 <h3>GAMP 5 Category Decision Aid</h3>
 <span class="checklist-result" id="gamp-result"></span>
 </div>
 <p class="checklist-desc">Answer a short series of questions to determine the GAMP 5 software category. Based on GAMP 5 Second Edition (2022). Note: Category 2 was retired, so the categories are 1, 3, 4 and 5. Categorize each component; a system can contain pieces of more than one category.</p>
 <div class="gamp-questions">
 <div class="gamp-q" id="gamp-q1">
 <div class="gamp-q-text">Is this infrastructure software (OS, middleware, database engine, network services) that is not GxP-specific?</div>
 <div class="gamp-btns">
 <button class="gamp-btn" onclick="gampAnswer(1,'yes')">Yes</button>
 <button class="gamp-btn" onclick="gampAnswer(1,'no')">No</button>
 </div>
 </div>
 <div class="gamp-q hidden" id="gamp-q2">
 <div class="gamp-q-text">Is this COTS software used without configuration (non-configurable, used as-delivered)?</div>
 <div class="gamp-btns">
 <button class="gamp-btn" onclick="gampAnswer(2,'yes')">Yes</button>
 <button class="gamp-btn" onclick="gampAnswer(2,'no')">No</button>
 </div>
 </div>
 <div class="gamp-q hidden" id="gamp-q3">
 <div class="gamp-q-text">Is this COTS software configured to meet business requirements (workflow setup, report templates, access roles)?</div>
 <div class="gamp-btns">
 <button class="gamp-btn" onclick="gampAnswer(3,'yes')">Yes</button>
 <button class="gamp-btn" onclick="gampAnswer(3,'no')">No</button>
 </div>
 </div>
 <div class="gamp-answer hidden" id="gamp-cat1">
 <div class="gamp-cat cat1">Category 1, Infrastructure Software</div>
 <div class="gamp-cat-desc"><span class="gc-line"><strong>What it is:</strong> operating systems, database engines, network services, virtualization and IT infrastructure that is not GxP-application-specific.</span><span class="gc-line"><strong>Examples:</strong> Windows Server, the Oracle or SQL Server engine, VMware, Active Directory, the network.</span><span class="gc-line"><strong>Validation effort:</strong> lowest, focus on qualified installation of the environment and ongoing control, not functional testing of the platform itself.</span><span class="gc-line"><strong>Key activities:</strong> infrastructure qualification, supplier documentation, patch and configuration management, access control.</span><span class="gc-line"><strong>Watch-out:</strong> the GxP application running on top is categorized separately (usually 3, 4 or 5). This category does not cover the app.</span></div>
 <button class="gamp-reset" onclick="gampReset()">Start over</button>
 </div>
 <div class="gamp-answer hidden" id="gamp-cat3">
 <div class="gamp-cat cat3">Category 3, Non-Configured Software</div>
 <div class="gamp-cat-desc"><span class="gc-line"><strong>What it is:</strong> commercial off-the-shelf software run as delivered, with default settings and no business-specific configuration.</span><span class="gc-line"><strong>Examples:</strong> instrument firmware, a simple balance or pH meter with fixed functionality, a non-configurable data viewer.</span><span class="gc-line"><strong>Validation effort:</strong> low to moderate, verify the intended-use functionality works in your environment.</span><span class="gc-line"><strong>Key activities:</strong> requirements for intended use, supplier assessment, a risk-based OQ/PQ of the functions you rely on, vendor documentation review.</span><span class="gc-line"><strong>Watch-out:</strong> if you set up workflows, user roles, report templates or calculations, it is configured (Category 4), not 3.</span></div>
 <button class="gamp-reset" onclick="gampReset()">Start over</button>
 </div>
 <div class="gamp-answer hidden" id="gamp-cat4">
 <div class="gamp-cat cat4">Category 4, Configured Software</div>
 <div class="gamp-cat-desc"><span class="gc-line"><strong>What it is:</strong> COTS applications configured to your business process without changing the underlying code.</span><span class="gc-line"><strong>Examples:</strong> LIMS, ELN, MES, QMS, EDMS, chromatography data systems, ERP modules.</span><span class="gc-line"><strong>Validation effort:</strong> moderate to high, scaled to the risk and complexity of the configuration.</span><span class="gc-line"><strong>Key deliverables:</strong> URS, functional/configuration specification, risk assessment, IQ/OQ/PQ, requirements-to-test traceability, configuration management, and change control over configuration after go-live.</span><span class="gc-line"><strong>Watch-out:</strong> custom code, macros, scripts or bespoke interfaces added on top are Category 5 components and need full-lifecycle controls even inside a Category 4 system.</span></div>
 <button class="gamp-reset" onclick="gampReset()">Start over</button>
 </div>
 <div class="gamp-answer hidden" id="gamp-cat5">
 <div class="gamp-cat cat5">Category 5, Custom Software</div>
 <div class="gamp-cat-desc"><span class="gc-line"><strong>What it is:</strong> bespoke or heavily customized software developed for your specific need, including custom interfaces, scripts and macros.</span><span class="gc-line"><strong>Examples:</strong> a custom-built application, bespoke integration/middleware, a complex spreadsheet with custom macros, custom code inside an otherwise configured system.</span><span class="gc-line"><strong>Validation effort:</strong> highest, a full software development lifecycle.</span><span class="gc-line"><strong>Key deliverables:</strong> a defined and controlled SDLC, design specifications, code review, unit/integration/system testing, full traceability, and comprehensive documentation.</span><span class="gc-line"><strong>Watch-out:</strong> custom components inside an otherwise Category 4 system still demand this rigor, do not let them ride on the lower category.</span></div>
 <button class="gamp-reset" onclick="gampReset()">Start over</button>
 </div>
 </div>
 </div>

 <!-- 483 Response Checklist -->
 <div class="tool-panel checklist-card" id="fda483-card">
 <div class="tool-panel-tab"><span class="tool-tab-num">03</span><span class="tool-tab-kind">Completeness Check</span></div>
 <div class="checklist-header">
 <h3>483 Response Completeness Check</h3>
 <span class="checklist-count" id="fda483-count">0 / 10</span>
 </div>
 <p class="checklist-desc">Before submitting a 483 response, verify each element is present and substantive. Check only items that are genuinely complete, not just drafts.</p>
 <div class="checklist-items" id="fda483-items">
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Acknowledgment</strong>, Each observation is addressed individually with a clear statement of agreement or disagreement.</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Root cause analysis</strong>, Goes beyond the symptom to identify the underlying system failure (procedure gap, training gap, oversight gap, system design gap).</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Immediate correction</strong>, Specific action taken to fix the observed condition. Completed before submission if possible.</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Systemic CAPA</strong>, Preventive action addresses not just the cited instance but all similar situations across the site.</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Specific timelines</strong>, Each action has a specific completion date. No vague language ("in the coming months").</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Evidence attached</strong>, Completed actions are supported by evidence (SOPs, training records, validation documentation).</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Scope assessment</strong>, Response addresses whether similar issues exist in other systems, products, or sites beyond what was directly cited.</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Data integrity retrospective</strong>, If applicable: historical data affected by the finding has been assessed for impact on prior quality decisions.</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Effectiveness monitoring</strong>, Plan is in place to verify that corrective actions are working (not just implemented).</span></label>
 <label class="cl-item"><input type="checkbox" data-group="fda483" /><span class="cl-label"><strong>Senior management acknowledgment</strong>, Response reflects management understanding of the issue and organizational commitment to corrective action.</span></label>
 </div>
 <div class="checklist-progress">
 <div class="progress-bar"><div class="progress-fill" id="fda483-fill" style="width:0%"></div></div>
 <span class="progress-label" id="fda483-label">Not assessed</span>
 </div>
 </div>

 <!-- Validation Deliverable Selector -->
 <div class="tool-panel checklist-card" id="vd-card">
 <div class="tool-panel-tab"><span class="tool-tab-num">04</span><span class="tool-tab-kind">Deliverable Selector</span></div>
 <div class="checklist-header">
 <h3>Validation Deliverable Selector</h3>
 <span class="checklist-result" id="vd-result"></span>
 </div>
 <p class="checklist-desc">Select validation type to see required and recommended deliverables. Based on GAMP 5 Second Edition and FDA/EMA expectations.</p>
 <div class="vd-selector">
 <div class="vd-type-btns">
 <button class="vd-type-btn active" onclick="selectVDType('csv', this)">Computer System (CSV)</button>
 <button class="vd-type-btn" onclick="selectVDType('equipment', this)">Equipment / Instrument</button>
 <button class="vd-type-btn" onclick="selectVDType('process', this)">Process Validation</button>
 <button class="vd-type-btn" onclick="selectVDType('cleaning', this)">Cleaning Validation</button>
 </div>
 <div class="vd-list" id="vd-content">
 <!-- populated by JS -->
 </div>
 </div>
 </div>

 </div>
 </div>
 </section>
</Layout>

<script is:inline>
 // ── ALCOA+ and 483 progress bars ──────────────────────────────────────────
 function updateChecklistProgress(group, total) {
 var checked = document.querySelectorAll('input[data-group="' + group + '"]:checked').length;
 var fill = document.getElementById(group + '-fill');
 var countEl = document.getElementById(group + '-count');
 var labelEl = document.getElementById(group + '-label');
 if (!fill) return;
 var pct = Math.round((checked / total) * 100);
 fill.style.width = pct + '%';
 if (countEl) countEl.textContent = checked + ' / ' + total;
 if (labelEl) {
 if (checked === 0) labelEl.textContent = 'Not assessed';
 else if (checked === total) labelEl.textContent = 'All principles satisfied';
 else labelEl.textContent = pct + '%, ' + (total - checked) + ' gap(s) remain';
 }
 fill.style.background = checked === total ? '#3C6B4A' : checked >= total * 0.7 ? '#CB4B2A' : '#B26B1E';
 }

 document.addEventListener('DOMContentLoaded', function () {
 document.querySelectorAll('input[data-group="alcoa"]').forEach(function (cb) {
 cb.addEventListener('change', function () { updateChecklistProgress('alcoa', 9); });
 });
 document.querySelectorAll('input[data-group="fda483"]').forEach(function (cb) {
 cb.addEventListener('change', function () { updateChecklistProgress('fda483', 10); });
 });
 document.querySelectorAll('.cl-more').forEach(function (btn) {
 btn.addEventListener('click', function () {
 var d = btn.nextElementSibling;
 if (!d) return;
 if (d.hasAttribute('hidden')) { d.removeAttribute('hidden'); btn.textContent = 'Hide'; btn.classList.add('open'); }
 else { d.setAttribute('hidden', ''); btn.textContent = 'How to assess'; btn.classList.remove('open'); }
 });
 });
 renderVD('csv');
 });

 // ── GAMP Decision Aid ─────────────────────────────────────────────────────
 function gampAnswer(q, answer) {
 document.getElementById('gamp-q' + q).classList.add('hidden');
 if (q === 1) {
 if (answer === 'yes') { document.getElementById('gamp-cat1').classList.remove('hidden'); }
 else { document.getElementById('gamp-q2').classList.remove('hidden'); }
 } else if (q === 2) {
 if (answer === 'yes') { document.getElementById('gamp-cat3').classList.remove('hidden'); }
 else { document.getElementById('gamp-q3').classList.remove('hidden'); }
 } else if (q === 3) {
 if (answer === 'yes') { document.getElementById('gamp-cat4').classList.remove('hidden'); }
 else { document.getElementById('gamp-cat5').classList.remove('hidden'); }
 }
 }

 function gampReset() {
 ['gamp-q2','gamp-q3','gamp-cat1','gamp-cat3','gamp-cat4','gamp-cat5'].forEach(function (id) {
 document.getElementById(id).classList.add('hidden');
 });
 document.getElementById('gamp-q1').classList.remove('hidden');
 }

 // ── Validation Deliverables ───────────────────────────────────────────────
 var vdData = {
 csv: {
 required: [
 ['Validation Plan / Master Validation Plan','Defines scope, approach, roles and acceptance criteria, the contract for the whole effort.'],
 ['User Requirements Specification (URS)','What the system must do; everything downstream traces back to it.'],
 ['Functional Requirements Specification (FRS)','How the system delivers each requirement; the basis for OQ tests.'],
 ['System Design Specification (SDS)','The technical/configuration design; needed for configured and custom systems and for change impact.'],
 ['Installation Qualification (IQ)','Proves the system is installed correctly in the qualified environment.'],
 ['Operational Qualification (OQ)','Proves each function works across its operating range, against the FRS.'],
 ['Performance Qualification (PQ)','Proves the system performs in your real process and workflow.'],
 ['Traceability Matrix (URS to test scripts)','Shows every requirement is tested; inspectors check this first for coverage gaps.'],
 ['Validation Summary Report','Concludes fit for use and authorizes go-live; summarizes deviations and residual risk.'],
 ['SOPs for system use and administration','Keep the system in a validated state in daily operation.'],
 ],
 recommended: [
 ['Supplier Assessment / Audit Report','Lets you rely on vendor testing and right-size your own work under CSA.'],
 ['Hardware and Software Design Review','Catches design gaps before testing and supports later change impact.'],
 ['Risk Assessment (GAMP 5 risk-based)','Drives where you test deeply vs lightly, the core of a risk-based approach.'],
 ['Data Migration Validation (if applicable)','Proves data moved completely and accurately, with metadata and audit trail intact.'],
 ['Periodic Review SOP and schedule','Confirms the system stays validated over time.'],
 ['User Acceptance Testing (UAT)','Confirms real users can do real tasks; supporting evidence for PQ.'],
 ],
 },
 equipment: {
 required: [
 ['Instrument Qualification Plan','Scope, approach and acceptance criteria for the qualification.'],
 ['User Requirements Specification (URS)','Defines the performance the instrument must meet for its intended use.'],
 ['Installation Qualification (IQ)','Confirms correct installation, utilities and documentation.'],
 ['Operational Qualification (OQ)','Confirms the instrument operates across its specified ranges.'],
 ['Performance Qualification (PQ)','Confirms performance under real method and use conditions.'],
 ['Maintenance and calibration SOPs','Keep the instrument in a qualified state.'],
 ['Requalification trigger criteria','Define when requalification is required (move, repair, drift).'],
 ],
 recommended: [
 ['Supplier / vendor documentation review','Leverages vendor IQ/OQ to reduce duplicate effort.'],
 ['Design Qualification (DQ) for custom equipment','Confirms the design meets requirements before build or buy.'],
 ['Preventive maintenance integration','Links maintenance records to qualified status.'],
 ['Risk assessment per USP <1058>','Sets the AIQ group (A/B/C) and the depth of testing.'],
 ['Analytical Instrument Classification decision','Classifies the instrument to right-size qualification.'],
 ],
 },
 process: {
 required: [
 ['Process Validation Protocol (PPQ, stage 2)','Defines the PPQ approach, sampling plan and acceptance criteria.'],
 ['Process Design summary (stage 1)','Captures the CQAs, CPPs and control strategy the validation rests on.'],
 ['Process Performance Qualification (PPQ) report','Demonstrates the process consistently produces conforming product.'],
 ['Continued Process Verification (CPV) plan (stage 3)','Defines ongoing monitoring that keeps the process in control.'],
 ['Statistical process control criteria','The statistical limits that signal a process shift.'],
 ['Linkage to batch record and specifications','Ties validated parameters to the executed batch record.'],
 ],
 recommended: [
 ['Design of Experiments (DoE) data package','Defines the design space and proves the CPP-to-CQA relationships.'],
 ['Process risk assessment (FMEA)','Prioritizes parameters and failure modes for control.'],
 ['Scale-up / tech transfer summary','Shows the process holds across scale and site.'],
 ['Contamination control strategy','Required for sterile and aseptic processes.'],
 ['Annual Product Review integration','Feeds CPV data into the annual product review.'],
 ],
 },
