---
import Layout from '../layouts/Layout.astro';
import tool from '../data/audit_tool.json';

const cites = tool.citations || [];
const years = tool.meta?.years || [];
const wlTotal = tool.meta?.wl_total || 0;
const obsRecords = 17657;
const drugs = cites.filter((c) => c.area === 'Drugs');
const biologics = cites.filter((c) => c.area === 'Biologics');
const maxYear = Math.max(1, ...cites.flatMap((c) => Object.values(c.per_year || {}).map(Number)));
const domains = Array.from(new Set(cites.map((c) => c.domain))).sort();
const trendLabel = { rising: 'Rising', steady: 'Steady', falling: 'Falling' };
const asOf = '25 June 2026';
const spark = (c) => years.map((y) => {
  const v = Number((c.per_year || {})[String(y)] || 0);
  return { y, v, h: Math.round((v / maxYear) * 100) };
});
---
<Layout title="FDA Audit Readiness" wide={true}
  description="A free FDA audit-readiness tool built on 3,580 real Warning Letters and 17,657 Form 483 observations. A comprehensive 1,100+ question self-assessment, the most-cited findings decoded, and a searchable library of every Warning Letter and 483 citation, updated regularly.">

  <header class="ar-hero">
    <div class="wrap ar-hero-in">
      <div class="page-label ar-eyebrow">Tool / Audit Readiness</div>
      <h1 class="ar-h1">Are you ready for an FDA inspection?</h1>
      <p class="ar-lead">A free, hands-on readiness check built on what FDA actually cites. Run a comprehensive self-assessment, see the findings drug and biologics companies receive most, and search every Warning Letter and 483 citation, all decoded into plain language.</p>
      <div class="ar-stats">
        <div class="ar-stat"><span class="ar-stat-n">1,122</span><span class="ar-stat-l">self-check questions</span></div>
        <div class="ar-stat"><span class="ar-stat-n">{wlTotal.toLocaleString()}</span><span class="ar-stat-l">Warning Letters</span></div>
        <div class="ar-stat"><span class="ar-stat-n">{obsRecords.toLocaleString()}</span><span class="ar-stat-l">483 observations, {years.length} yrs</span></div>
      </div>
      <p class="ar-disc">Educational pattern analysis from public FDA data, not legal, regulatory, or compliance advice, and not a prediction of any inspection outcome. See the <a href="/disclaimer">Disclaimer and Terms</a>.</p>
    </div>
  </header>

  <div class="ar-tabs-wrap">
    <div class="wrap ar-tabs" role="tablist">
      <button class="ar-tab is-on" id="tab-check" role="tab">Self-assessment</button>
      <button class="ar-tab" id="tab-explore" role="tab">Top observations</button>
      <button class="ar-tab" id="tab-library" role="tab">Findings library</button>
    </div>
  </div>

  <!-- ============ TAB 1: SELF-ASSESSMENT ============ -->
  <section class="wrap ar-panel" id="panel-check">
    <p class="ar-panel-intro">A comprehensive self-check across every area an FDA investigator probes, 1,122 questions over 29 sections. Tell us what applies to you and the rest is marked Not applicable and left out of your score. Answer honestly, it all runs in your browser and saves as you go. A confident "Yes" is good; "No" is a gap.</p>

    <div class="ar-profile">
      <div class="ar-profile-h">What applies to your operation? <span>(turns whole sections on or off)</span></div>
      <div class="ar-profile-opts" id="ar-profile">
        <label><input type="checkbox" value="computerized" checked /> Computerized systems</label>
        <label><input type="checkbox" value="sterile" /> Sterile / aseptic manufacturing</label>
        <label><input type="checkbox" value="biologics" /> Biologics</label>
        <label><input type="checkbox" value="cgt" /> Cell &amp; gene therapy / tissue</label>
        <label><input type="checkbox" value="api" /> API / drug substance</label>
        <label><input type="checkbox" value="combination" /> Combination products</label>
        <label><input type="checkbox" value="packaging" /> Packaging &amp; labeling</label>
        <label><input type="checkbox" value="clinical" /> Sponsor / run clinical trials</label>
      </div>
    </div>

    <div class="ar-prog" id="ar-prog"><div class="ar-prog-bar"><span id="ar-prog-fill"></span></div><span id="ar-prog-txt">Loading questions...</span></div>

    <div id="ar-sections" class="ar-sections"></div>

    <div class="ar-actions">
      <button type="button" id="ar-score-btn" class="ar-btn">See my readiness report</button>
      <button type="button" id="ar-reset-btn" class="ar-btn ar-btn-ghost">Reset answers</button>
    </div>
    <div id="ar-result" class="ar-result" hidden></div>
  </section>

  <!-- ============ TAB 2: TOP OBSERVATIONS EXPLORER ============ -->
  <section class="wrap ar-panel" id="panel-explore" hidden>
    <p class="ar-panel-intro">The CFR citations FDA issues most to drug and biologics makers, ranked over {years.length} years, each decoded with what to verify and a real Warning Letter example. For the full searchable set, see the Findings library.</p>
    <div class="ar-filters">
      <div class="ar-filter-group" id="ar-area">
        <button class="ar-chip is-on" data-area="all">All</button>
        <button class="ar-chip" data-area="Drugs">Drugs ({drugs.length})</button>
        <button class="ar-chip" data-area="Biologics">Biologics ({biologics.length})</button>
      </div>
      <select id="ar-domain" class="ar-select"><option value="all">All domains</option>{domains.map((d) => <option value={d}>{d}</option>)}</select>
    </div>
    <div class="ar-cards" id="ar-cards">
      {cites.map((c) => (
        <article class="ar-card" data-area={c.area} data-domain={c.domain}>
          <div class="ar-card-head">
            <div><span class="ar-ref">{c.reference}</span><span class={`ar-trend ar-${c.trend}`}>{trendLabel[c.trend] || c.trend}</span></div>
            <span class="ar-count">{c.total.toLocaleString()} citations</span>
          </div>
          <div class="ar-card-meta"><span class="ar-domain-tag">{c.domain}</span><span class="ar-area-tag">{c.area}</span></div>
          <div class="ar-spark" aria-hidden="true">{spark(c).map((s) => (<span class="ar-bar" style={`height:${Math.max(3, s.h)}%`} title={`FY${s.y}: ${s.v}`}></span>))}</div>
          <p class="ar-mean">{c.plain_meaning}</p>
          <details class="ar-more">
            <summary>What to verify and a real example</summary>
            <p class="ar-sub"><strong>Why it matters.</strong> {c.why_matters}</p>
            <p class="ar-sub"><strong>How it shows up.</strong> {c.how_it_shows_up}</p>
            {c.biologics_note && <p class="ar-bionote"><strong>Biologics note.</strong> {c.biologics_note}</p>}
            <p class="ar-sub"><strong>Self-check:</strong></p>
            <ul class="ar-checks">{(c.self_check_questions || []).map((q) => <li>{q}</li>)}</ul>
            {c.example && c.example.snippet && (
              <div class="ar-example">
                <div class="ar-example-h">Real Warning Letter, {c.example.company} ({c.example.date})</div>
                <p class="ar-example-q">{c.example.snippet}</p>
                {c.example.url && <a class="ar-example-link" href={c.example.url} target="_blank" rel="noopener nofollow">Read the FDA letter →</a>}
              </div>
            )}
          </details>
        </article>
      ))}
    </div>
  </section>

  <!-- ============ TAB 3: FINDINGS LIBRARY ============ -->
  <section class="wrap ar-panel" id="panel-library" hidden>
    <p class="ar-panel-intro">A searchable repository of every FDA Warning Letter and Form 483 citation in scope for drug and biologics makers, each decoded into plain language. Current as of <strong>{asOf}</strong>, refreshed regularly.</p>
    <div class="ar-lib-toggle">
      <button class="ar-chip is-on" id="lib-wl">Warning Letters</button>
      <button class="ar-chip" id="lib-obs">483 Observations</button>
    </div>
    <div class="ar-lib-controls">
      <input type="search" id="lib-search" class="ar-search" placeholder="Search company, subject, CFR, or text..." />
      <select id="lib-filter" class="ar-select"></select>
      <span class="ar-lib-count" id="lib-count"></span>
    </div>
    <div id="lib-list" class="ar-lib-list"><p class="ar-loading">Loading the FDA library...</p></div>
    <div class="ar-lib-more-wrap"><button type="button" id="lib-more" class="ar-btn ar-btn-ghost" hidden>Show more</button></div>
  </section>

  <script is:inline>
  (function () {
    var T = { check: ['tab-check','panel-check'], explore: ['tab-explore','panel-explore'], library: ['tab-library','panel-library'] };
    function show(which) {
      Object.keys(T).forEach(function (k) {
        var on = k === which;
        document.getElementById(T[k][0]).classList.toggle('is-on', on);
        document.getElementById(T[k][1]).hidden = !on;
      });
      if (which === 'check') loadQuestions();
      if (which === 'library') loadLibrary();
    }
    document.getElementById('tab-check').addEventListener('click', function () { show('check'); });
    document.getElementById('tab-explore').addEventListener('click', function () { show('explore'); });
    document.getElementById('tab-library').addEventListener('click', function () { show('library'); });

    // ---- explorer filtering ----
    var cards = Array.prototype.slice.call(document.querySelectorAll('.ar-card'));
    var area = 'all', domain = 'all';
    function filt() { cards.forEach(function (c) { c.style.display = ((area==='all'||c.dataset.area===area)&&(domain==='all'||c.dataset.domain===domain))?'':'none'; }); }
    document.getElementById('ar-area').addEventListener('click', function (e) { var b=e.target.closest('.ar-chip'); if(!b)return; document.querySelectorAll('#ar-area .ar-chip').forEach(function(x){x.classList.remove('is-on');}); b.classList.add('is-on'); area=b.dataset.area; filt(); });
    document.getElementById('ar-domain').addEventListener('change', function (e) { domain=e.target.value; filt(); });

    // ================= SELF-ASSESSMENT =================
    var QB = null, ANSWERS = {}, LS = 'ar-answers-v1', LSP = 'ar-profile-v1';
    try { ANSWERS = JSON.parse(localStorage.getItem(LS) || '{}') || {}; } catch (e) { ANSWERS = {}; }
    function activeTags() {
      var s = { general: true };
      document.querySelectorAll('#ar-profile input:checked').forEach(function (c) { s[c.value] = true; });
      return s;
    }
    function saveAnswers() { try { localStorage.setItem(LS, JSON.stringify(ANSWERS)); } catch (e) {} }
    function saveProfile() {
      var p = []; document.querySelectorAll('#ar-profile input:checked').forEach(function (c) { p.push(c.value); });
      try { localStorage.setItem(LSP, JSON.stringify(p)); } catch (e) {}
    }
    (function restoreProfile() {
      try { var p = JSON.parse(localStorage.getItem(LSP) || 'null'); if (p) {
        document.querySelectorAll('#ar-profile input').forEach(function (c) { c.checked = p.indexOf(c.value) >= 0; });
      } } catch (e) {}
    })();

    function loadQuestions() {
      if (QB) return Promise.resolve(QB);
      return fetch('/data/audit_questions.json').then(function (r) { return r.json(); }).then(function (d) {
        QB = d; renderSections(); return d;
      }).catch(function () { document.getElementById('ar-prog-txt').textContent = 'Could not load questions, please reload.'; });
    }
    function renderSections() {
      var tags = activeTags(), host = document.getElementById('ar-sections'), html = '';
      QB.sections.forEach(function (s, si) {
        var applicable = s.questions.filter(function (q) { return q.tag === 'general' || tags[q.tag]; });
        var na = applicable.length === 0;
        html += '<details class="ar-sect" data-si="' + si + '"' + (na ? ' data-na="1"' : '') + '>';
        html += '<summary class="ar-sect-sum"><span class="ar-sect-name">' + s.name + '</span>';
        html += na ? '<span class="ar-sect-na">Not applicable</span>' : '<span class="ar-sect-meta" id="sm-' + si + '">' + applicable.length + ' questions</span>';
        html += '</summary><div class="ar-sect-body" data-loaded="0"><p class="ar-sect-intro">' + s.intro + '</p></div></details>';
      });
      host.innerHTML = html;
      host.querySelectorAll('.ar-sect').forEach(function (d) {
        d.addEventListener('toggle', function () { if (d.open) buildSection(d); });
      });
      updateProgress();
    }
    function buildSection(d) {
      var body = d.querySelector('.ar-sect-body');
      if (body.dataset.loaded === '1') return;
      var si = +d.dataset.si, s = QB.sections[si], tags = activeTags(), html = '';
      s.questions.forEach(function (q, qi) {
        var applicable = q.tag === 'general' || tags[q.tag];
        var key = s.key + '::' + qi, cur = applicable ? (ANSWERS[key] || '') : 'na';
        html += '<div class="ar-q' + (applicable ? '' : ' ar-q-na') + '" data-key="' + key + '">';
        html += '<p class="ar-q-text">' + q.q + (q.tag !== 'general' ? ' <span class="ar-q-tag">' + q.tag + '</span>' : '') + '</p>';
        if (applicable) {
          html += '<div class="ar-q-opts">';
          [['1','Yes'],['0.5','Partly'],['0','No'],['na','N/A']].forEach(function (o) {
            html += '<label><input type="radio" name="' + key + '" value="' + o[0] + '"' + (cur === o[0] ? ' checked' : '') + '/> ' + o[1] + '</label>';
          });
          html += '</div>';
        } else { html += '<div class="ar-q-naflag">Not applicable to your profile</div>'; }
        html += '</div>';
      });
      body.insertAdjacentHTML('beforeend', html);
      body.dataset.loaded = '1';
      body.querySelectorAll('input[type=radio]').forEach(function (inp) {
        inp.addEventListener('change', function () { ANSWERS[inp.name] = inp.value; saveAnswers(); updateProgress(); });
      });
    }
    function computeApplicable() {
      var tags = activeTags(), totalApp = 0, answered = 0;
      QB.sections.forEach(function (s) {
        s.questions.forEach(function (q, qi) {
          if (!(q.tag === 'general' || tags[q.tag])) return;
          totalApp++;
          var a = ANSWERS[s.key + '::' + qi];
          if (a && a !== 'na') answered++;
        });
      });
      return { totalApp: totalApp, answered: answered };
    }
    function updateProgress() {
      if (!QB) return;
      var c = computeApplicable(), pct = c.totalApp ? Math.round((c.answered / c.totalApp) * 100) : 0;
      document.getElementById('ar-prog-fill').style.width = pct + '%';
      document.getElementById('ar-prog-txt').textContent = c.answered + ' of ' + c.totalApp + ' applicable questions answered (' + pct + '%)';
    }
    document.getElementById('ar-profile').addEventListener('change', function () { saveProfile(); if (QB) renderSections(); });
    document.getElementById('ar-reset-btn').addEventListener('click', function () {
      if (!confirm('Clear all your answers?')) return;
      ANSWERS = {}; saveAnswers(); if (QB) renderSections();
      document.getElementById('ar-result').hidden = true;
    });
    document.getElementById('ar-score-btn').addEventListener('click', function () {
      if (!QB) { loadQuestions(); return; }
      var tags = activeTags(), result = document.getElementById('ar-result');
      var per = [], overallSum = 0, overallN = 0, totalApp = 0, answered = 0;
      QB.sections.forEach(function (s) {
        var sum = 0, n = 0, app = 0, nos = [];
        s.questions.forEach(function (q, qi) {
          if (!(q.tag === 'general' || tags[q.tag])) return;
          app++; totalApp++;
          var a = ANSWERS[s.key + '::' + qi];
          if (a === undefined || a === '' || a === 'na') return;
          var v = parseFloat(a); sum += v; n++; answered++; overallSum += v; overallN++;
          if (v === 0) nos.push(q.q);
        });
        if (app > 0) per.push({ name: s.name, pct: n ? Math.round((sum / n) * 100) : null, answered: n, app: app, nos: nos });
      });
      if (overallN === 0) { result.hidden = false; result.innerHTML = '<p class="ar-warn">Answer some questions first, then generate your report.</p>'; result.scrollIntoView({behavior:'smooth'}); return; }
      var overall = Math.round((overallSum / overallN) * 100);
      var band = overall >= 80 ? ['Strong','#1a7f4b'] : overall >= 55 ? ['Developing','#b8860b'] : ['At risk','#b3261e'];
      var html = '<div class="ar-score-top"><div class="ar-gauge" style="--p:' + overall + '"><span>' + overall + '<small>%</small></span></div>';
      html += '<div class="ar-score-side"><div class="ar-band" style="color:' + band[1] + '">' + band[0] + '</div>';
      html += '<p>Readiness across the areas you marked applicable, scored only on the ' + answered + ' questions you answered. This is a directional self-check on public FDA citation patterns, not a guarantee. Verify everything against the current regulations and your own records.</p>';
      if (answered < totalApp) html += '<p class="ar-note">' + (totalApp - answered) + ' applicable questions are still unanswered. Finish them for a complete picture.</p>';
      html += '</div></div>';
      var sorted = per.filter(function (p) { return p.pct !== null; }).sort(function (a, b) { return a.pct - b.pct; });
      html += '<h3 class="ar-rh">By section</h3><div class="ar-bars">';
      per.forEach(function (p) {
        if (p.pct === null) { html += '<div class="ar-barrow"><span class="ar-barlbl">' + p.name + '</span><span class="ar-bartrk"></span><span class="ar-barpct ar-todo">0/' + p.app + '</span></div>'; return; }
        var col = p.pct >= 80 ? '#1a7f4b' : p.pct >= 55 ? '#b8860b' : '#b3261e';
        html += '<div class="ar-barrow"><span class="ar-barlbl">' + p.name + '</span><span class="ar-bartrk"><span class="ar-barfill" style="width:' + p.pct + '%;background:' + col + '"></span></span><span class="ar-barpct">' + p.pct + '%</span></div>';
      });
      html += '</div>';
      var gaps = sorted.filter(function (p) { return p.pct < 70; }).slice(0, 6);
      if (gaps.length) {
        html += '<h3 class="ar-rh">Where to focus first</h3>';
        gaps.forEach(function (g) {
          html += '<details class="ar-gap"><summary><strong>' + g.name + '</strong> (' + g.pct + '%, ' + g.nos.length + ' gaps)</summary>';
          if (g.nos.length) { html += '<ul class="ar-gap-list">'; g.nos.slice(0, 12).forEach(function (q) { html += '<li>' + q + '</li>'; }); if (g.nos.length > 12) html += '<li>+ ' + (g.nos.length - 12) + ' more</li>'; html += '</ul>'; }
          else { html += '<p class="ar-note">Lower score from Partly answers, tighten these to full compliance.</p>'; }
          html += '</details>';
        });
      }
      html += '<p class="ar-note">Tip: open the <button type="button" class="ar-inline-link" id="ar-go-lib">Findings library</button> to see the real Warning Letters and 483 citations behind these areas.</p>';
      result.innerHTML = html; result.hidden = false;
      var g = document.getElementById('ar-go-lib'); if (g) g.addEventListener('click', function () { show('library'); window.scrollTo({top:0,behavior:'smooth'}); });
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // ================= FINDINGS LIBRARY =================
    var LIB = { wl: null, obs: null }, libMode = 'wl', libShown = 0, libFiltered = [], PAGE = 25;
    function loadLibrary() {
      if (LIB[libMode]) { renderLib(); return; }
      var url = libMode === 'wl' ? '/data/fda_wl.json' : '/data/fda_obs.json';
      document.getElementById('lib-list').innerHTML = '<p class="ar-loading">Loading the FDA library...</p>';
      fetch(url).then(function (r) { return r.json(); }).then(function (d) { LIB[libMode] = d; buildFilter(); renderLib(); })
        .catch(function () { document.getElementById('lib-list').innerHTML = '<p class="ar-warn">Could not load the library, please reload.</p>'; });
    }
    function buildFilter() {
      var sel = document.getElementById('lib-filter');
      if (libMode === 'wl') {
        var offices = {}; LIB.wl.items.forEach(function (x) { var o = (x.office || '').replace('Center for ','').trim(); if (o) offices[o] = (offices[o]||0)+1; });
        var opts = Object.keys(offices).sort(function (a,b){return offices[b]-offices[a];}).slice(0, 12);
        sel.innerHTML = '<option value="all">All issuing offices</option>' + opts.map(function (o) { return '<option value="' + o.replace(/"/g,'') + '">' + o + ' (' + offices[o] + ')</option>'; }).join('');
      } else {
        sel.innerHTML = '<option value="all">All areas</option><option value="Drugs">Drugs</option><option value="Biologics">Biologics</option>';
      }
    }
    function renderLib() {
      var q = (document.getElementById('lib-search').value || '').toLowerCase().trim();
      var fv = document.getElementById('lib-filter').value;
      var items = LIB[libMode].items;
      libFiltered = items.filter(function (x) {
        if (libMode === 'wl') {
          if (fv !== 'all' && (x.office || '').indexOf(fv) < 0) return false;
          if (!q) return true;
          var hay = (x.company + ' ' + x.subject + ' ' + x.office + ' ' + x.lead + ' ' + (x.cfr||[]).map(function(c){return c.ref+' '+c.label;}).join(' ')).toLowerCase();
          return hay.indexOf(q) >= 0;
        } else {
          if (fv !== 'all' && x.area !== fv) return false;
          if (!q) return true;
          return (x.ref + ' ' + x.short + ' ' + x.meaning + ' ' + x.long).toLowerCase().indexOf(q) >= 0;
        }
      });
      libShown = 0;
      document.getElementById('lib-list').innerHTML = '';
      document.getElementById('lib-count').textContent = libFiltered.length.toLocaleString() + (libMode === 'wl' ? ' letters' : ' citations');
      appendLib();
    }
    function appendLib() {
      var host = document.getElementById('lib-list'), slice = libFiltered.slice(libShown, libShown + PAGE), html = '';
      slice.forEach(function (x) {
        if (libMode === 'wl') {
          html += '<article class="lib-card"><div class="lib-head"><span class="lib-co">' + esc(x.company) + '</span><span class="lib-date">' + esc(x.issue_date) + '</span></div>';
          html += '<div class="lib-sub">' + esc(x.subject) + '</div><div class="lib-office">' + esc(x.office) + '</div>';
          if (x.cfr && x.cfr.length) { html += '<div class="lib-cfr">' + x.cfr.map(function (c) { return '<span class="lib-chip" title="' + esc(c.label) + '">' + esc(c.ref) + (c.label ? ': ' + esc(c.label) : '') + '</span>'; }).join('') + '</div>'; }
          if (x.lead) html += '<p class="lib-lead">' + esc(x.lead) + '</p>';
          if (x.url) html += '<a class="lib-link" href="' + esc(x.url) + '" target="_blank" rel="noopener nofollow">Read the full FDA letter →</a>';
          html += '</article>';
        } else {
          html += '<article class="lib-card"><div class="lib-head"><span class="lib-ref">' + esc(x.ref) + '</span><span class="lib-area">' + esc(x.area) + ' · ' + x.total.toLocaleString() + ' citations · ' + esc(x.trend) + '</span></div>';
          html += '<div class="lib-short">' + esc(x.short) + '</div>';
          if (x.meaning) html += '<p class="lib-lead">' + esc(x.meaning) + '</p>'; else if (x.long) html += '<p class="lib-lead">' + esc(x.long) + '</p>';
          html += '</article>';
        }
      });
      host.insertAdjacentHTML('beforeend', html);
      libShown += slice.length;
      document.getElementById('lib-more').hidden = libShown >= libFiltered.length;
      if (!libFiltered.length) host.innerHTML = '<p class="ar-warn">No matches.</p>';
    }
    function esc(s) { return (s == null ? '' : String(s)).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    document.getElementById('lib-wl').addEventListener('click', function () { if (libMode==='wl') return; libMode='wl'; this.classList.add('is-on'); document.getElementById('lib-obs').classList.remove('is-on'); document.getElementById('lib-search').value=''; loadLibrary(); });
    document.getElementById('lib-obs').addEventListener('click', function () { if (libMode==='obs') return; libMode='obs'; this.classList.add('is-on'); document.getElementById('lib-wl').classList.remove('is-on'); document.getElementById('lib-search').value=''; loadLibrary(); });
    var st; document.getElementById('lib-search').addEventListener('input', function () { clearTimeout(st); st = setTimeout(function () { if (LIB[libMode]) renderLib(); }, 180); });
    document.getElementById('lib-filter').addEventListener('change', function () { if (LIB[libMode]) renderLib(); });
    document.getElementById('lib-more').addEventListener('click', appendLib);

    // preload the self-assessment questions on first paint (default tab)
    loadQuestions();
  })();
  </script>

  <style>
    .ar-hero { background: var(--navy); color: #fff; border-bottom: 4px solid var(--gold); }
    .ar-hero-in { padding: 3.2rem 0 2.6rem; }
    .ar-eyebrow { color: #ffd98a; margin-bottom: 1rem; }
