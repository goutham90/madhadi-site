---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const tagMap: Record<string, typeof allArticles> = {};
for (const article of allArticles) {
  for (const tag of article.data.tags) {
    if (!tagMap[tag]) tagMap[tag] = [];
    tagMap[tag].push(article);
  }
}

const sortedTags = Object.entries(tagMap).sort((a, b) => b[1].length - a[1].length);
---
<Layout title="Topics" description="Browse data integrity articles by topic — ALCOA+, 21 CFR Part 11, FDA, Cell & Gene Therapy, and more.">
  <div class="page-header">
    <div class="page-label">Browse</div>
    <h1>Topics</h1>
    <p>All articles organized by subject area.</p>
  </div>

  <div class="topics-list">
    {sortedTags.map(([tag, articles]) => (
      <section class="topic-section" id={tag.toLowerCase().replace(/\s+/g, '-')}>
        <div class="topic-header">
          <h2>{tag}</h2>
          <span class="topic-count">{articles.length} article{articles.length !== 1 ? 's' : ''}</span>
        </div>
        <ul class="article-list">
          {articles
            .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
            .map(post => (
              <li>
                <a href={`/articles/${post.slug}`} class="article-row">
                  <span class="article-title">{post.data.title}</span>
                  <span class="article-date">
                    {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
                  </span>
                </a>
              </li>
            ))}
        </ul>
      </section>
    ))}
  </div>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  .page-label {
    font-size: 0.72rem;
    font-family: var(--mono);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }

  .page-header h1 {
    font-size: 2.25rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .page-header p { color: var(--muted); }

  .topics-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .topic-section {
    padding: 2rem 0;
    border-bottom: 1px solid var(--border-dim);
  }

  .topic-section:last-child { border-bottom: none; }

  .topic-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .topic-header h2 {
    font-size: 1.05rem;
    font-weight: 600;
  }

  .topic-count {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--mono);
  }

  .article-list { list-style: none; padding: 0; }

  .article-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.6rem 0;
    color: var(--muted-light);
    font-size: 0.9rem;
    border-bottom: 1px solid var(--border-dim);
    gap: 1rem;
    transition: color 0.15s;
  }

  .article-row:last-child { border-bottom: none; }
  .article-row:hover { color: var(--text); }
  .article-row:hover .article-title { color: var(--accent); }

  .article-title { transition: color 0.15s; }

  .article-date {
    font-size: 0.75rem;
    color: var(--muted);
    font-family: var(--mono);
    flex-shrink: 0;
  }
</style>
