 const result = document.getElementById(`${scenarioId}-result-${choice}`);
 if (result) result.classList.remove('hidden');
 }

 function reset(scenarioId) {
 // Show options again
 const options = document.getElementById(`${scenarioId}-options`);
 options.style.display = 'flex';

 // Reset all button states
 const btns = options.querySelectorAll('.option-btn');
 btns.forEach(btn => {
 btn.classList.remove('selected', 'correct', 'wrong');
 });

 // Hide all results
 ['A','B','C','D'].forEach(c => {
 const r = document.getElementById(`${scenarioId}-result-${c}`);
 if (r) r.classList.add('hidden');
 });
 }
</script>

