---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'equipment-qualification');
const sorted = all.sort((a, b) => {
 const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
 return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});

const tierColors: Record<string, string> = {
 Beginner: '#3C6B4A',
 Intermediate: '#B26B1E',
 Advanced: '#7A2E23',
};
---
<Layout title="Equipment & Instrument Qualification" description="DQ/IQ/OQ/PQ, USP 1058 analytical instrument qualification, calibration, and risk-based qualification across instrument classes." wide={true}>
 <!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
 <header class="pillar-hero duotone">
 <img src="/images/instrument-bench.jpg" alt="" loading="eager" />
 <div class="pillar-hero-grad"></div>
 <div class="wrap pillar-hero-inner">
 <a href="/pillars" class="back-link">← All Pillars</a>
 <div class="pillar-hero-top">
 <span class="emblem pillar-emblem" style="--src:url('/brand/emblems/pillar-equipment-qualification.svg')"></span>
 <span class="kicker pillar-kick">Pillar 03</span>
 </div>
 <h1 class="pillar-title">Equipment &amp; Instrument Qualification</h1>
 <p class="pillar-intro">
 Equipment is qualified. Processes and systems are validated. This distinction is not pedantic, it determines which lifecycle framework you apply, which regulatory requirements govern the work, and how you write and execute the documentation. Getting it right from the design phase avoids the most common qualification failures.
 </p>
 <div class="reg-basis">
 <span class="reg-label">Regulatory basis</span>
 <div class="reg-links">
 <a href="https://www.usp.org/harmonization-standards/pdg/general-chapters/1058-analytical-instrument-qualification" target="_blank" rel="noopener">USP &lt;1058&gt; AIQ</a>
 <a href="https://www.ema.europa.eu/en/documents/scientific-guideline/ich-q2-r1-validation-analytical-procedures-step-5_en.pdf" target="_blank" rel="noopener">EU GMP Annex 15 (2015)</a>
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-211" target="_blank" rel="noopener">21 CFR Part 211</a>
 </div>
 </div>
 </div>
 </header>

 <!-- ═══════════ BODY: editorial index + sidebar ═══════════ -->
 <section class="section-tight pillar-body-section">
 <div class="wrap pillar-body">
 <div class="articles-section">
 <div class="articles-head">
 <span class="kicker">The record</span>
 <h2 class="display-2">Articles in this pillar</h2>
 <img class="articles-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />
 </div>
 {sorted.length === 0 ? (
 <p class="empty">Articles coming soon.</p>
 ) : (
 <ul class="index-list article-list">
 {sorted.map((post, i) => {
 const wordCount = post.body?.split(/\s+/).length ?? 0;
 const readTime = Math.max(1, Math.ceil(wordCount / 220));
 const tier = post.data.tier ?? 'Intermediate';
 const color = tierColors[tier] ?? '#837B69';
 return (
 <li>
 <a href={`/articles/${post.slug}`} class="article-row">
 <span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
 <div class="article-main">
 <div class="article-top">
 <span class="tier-badge" style={`background:${color}; color:#F7F3EA; border-color:${color}`}>{tier}</span>
 <h3 class="ix-title">{post.data.title}</h3>
 </div>
 <p class="article-desc">{post.data.description}</p>
 </div>
 <span class="ix-meta">{readTime} min →</span>
 </a>
 </li>
 );
 })}
 </ul>
 )}
 </div>

 <aside class="pillar-sidebar">
 <div class="sidebar-block">
 <div class="sidebar-label">What this pillar covers</div>
 <ul class="covers-list">
 <li>Qualification vs. validation, why the distinction matters</li>
 <li>DQ, IQ, OQ, PQ: what each phase proves</li>
 <li>USP &lt;1058&gt; AIQ: Groups A, B, C and the 4Qs</li>
 <li>Integration of AIQ with CSV and data integrity</li>
 <li>EU GMP Annex 15 qualification requirements</li>
 <li>Calibration vs. qualification: the practical difference</li>
 <li>Requalification triggers and risk-based scope</li>
 <li>Instrument-class guidance: HPLC/CDS, balances, autoclaves, incubators, freezers, bioreactors</li>
 </ul>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Related pillars</div>
 <a href="/pillars/csv-csa" class="related-pill">CSV &amp; CSA →</a>
 <a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
 <a href="/pillars/manufacturing-automation" class="related-pill">Manufacturing Systems →</a>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Learning tracks</div>
 <a href="/tracks/foundations" class="track-link">Foundations Track</a>
 <a href="/tracks/implementation" class="track-link">Implementation Track</a>
 </div>
 <img class="sidebar-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 </aside>
 </div>
 </section>
</Layout>

<style>
 /* ════════════ HEADER BAND ════════════ */
 .pillar-hero {
 position: relative;
 display: flex;
 align-items: flex-end;
 border-bottom: 3px solid var(--vermilion);
 margin-top: -3.5rem; /* counter main.wide top padding so band is true full-bleed */
 }
 .pillar-hero > img { position: absolute; inset: 0; }
 .pillar-hero-grad {
 position: absolute; inset: 0; z-index: 2;
 background: linear-gradient(175deg, rgba(22,19,13,0.30) 0%, rgba(22,19,13,0.50) 45%, rgba(22,19,13,0.88) 100%);
 }
 .pillar-hero-inner {
 position: relative; z-index: 3;
 padding-top: 5rem; padding-bottom: 3.25rem;
 }

 .back-link {
 display: inline-block;
 font-family: var(--mono);
 font-size: 0.72rem;
 text-transform: uppercase;
 letter-spacing: 0.14em;
 color: var(--on-ink-dim);
 margin-bottom: 2rem;
 transition: color 0.15s;
 }
 .back-link:hover { color: var(--on-ink); }

 .pillar-hero-top { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.1rem; }
 .pillar-emblem { color: var(--on-ink); width: 44px; height: 44px; }
 .pillar-kick { color: #F2C9B8; }

 .pillar-title {
 font-family: var(--display);
 font-weight: 500;
 color: var(--on-ink);
 font-size: clamp(2.3rem, 5.2vw, 4.2rem);
 line-height: 1.0;
 letter-spacing: -0.025em;
 max-width: 16ch;
 margin-bottom: 1.25rem;
 }
 .pillar-intro {
 font-family: var(--display);
 font-style: italic;
 font-weight: 400;
 color: var(--on-ink-dim);
 font-size: clamp(1.1rem, 1.9vw, 1.4rem);
 line-height: 1.45;
 max-width: 48ch;
 margin-bottom: 2rem;
 }

 .reg-basis {
 display: flex;
 flex-wrap: wrap;
 align-items: center;
 gap: 0.6rem 0.9rem;
 padding-top: 1.5rem;
 border-top: 1px solid var(--line-ink);
 }
 .reg-label {
 font-family: var(--mono);
 font-size: 0.68rem;
 color: var(--vermilion);
 text-transform: uppercase;
 letter-spacing: 0.14em;
 font-weight: 700;
 flex-shrink: 0;
 }
 .reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
 .reg-links a {
 font-family: var(--mono);
 font-size: 0.7rem;
 letter-spacing: 0.02em;
 color: var(--on-ink-dim);
 padding: 0.22rem 0.6rem;
 border: 1px solid var(--line-ink);
 border-radius: var(--radius);
 transition: border-color 0.15s, color 0.15s, background 0.15s;
 }
 .reg-links a:hover {
 border-color: var(--vermilion);
 color: var(--on-ink);
 background: rgba(203, 75, 42, 0.18);
 }

 /* ════════════ BODY ════════════ */
 .pillar-body-section { padding-top: 3.5rem; }
 .pillar-body {
 display: grid;
 grid-template-columns: minmax(0, 1fr) 280px;
 gap: 4rem;
 align-items: start;
 }

 .articles-head { margin-bottom: 0.5rem; }
 .articles-head .kicker { margin-bottom: 0.6rem; }
 .articles-head .display-2 { margin-bottom: 1.5rem; }
 .articles-rule { display: block; width: 100%; height: 14px; color: var(--line); }
 .empty { color: var(--muted); font-size: 0.95rem; margin-top: 1.25rem; }

 /* Editorial index rows (reuse .index-list, override grid for description + tier) */
 .article-list { border-top: none; margin-top: 0.5rem; }
 .article-row {
 display: grid;
 grid-template-columns: 3.25rem 1fr auto;
 gap: 1.5rem;
 align-items: baseline;
 padding: 1.6rem 0;
 border-bottom: 1px solid var(--line);
 color: inherit;
 transition: padding-left 0.15s, background 0.15s;
 }
 .article-list li:first-child .article-row { border-top: 2px solid var(--ink); }
 .article-row:hover { background: rgba(226, 219, 201, 0.35); padding-left: 0.6rem; }
 .ix-num {
 font-family: var(--mono);
 font-size: 0.82rem;
 color: var(--vermilion);
 padding-top: 0.3rem;
 }
 .article-main { min-width: 0; }
 .article-top { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.4rem; flex-wrap: wrap; }
 .ix-title {
 font-family: var(--display);
 font-size: 1.3rem;
 font-weight: 500;
 color: var(--ink);
 line-height: 1.18;
 transition: color 0.15s;
 }
 .article-row:hover .ix-title { color: var(--vermilion-2); }
 .article-desc {
 font-size: 0.92rem;
 color: var(--graphite);
 line-height: 1.6;
 margin: 0;
 max-width: 52ch;
 }
 .ix-meta {
 font-family: var(--mono);
 font-size: 0.74rem;
 color: var(--muted);
 white-space: nowrap;
 padding-top: 0.35rem;
 transition: color 0.15s;
 }
 .article-row:hover .ix-meta { color: var(--vermilion-2); }

 /* ════════════ SIDEBAR (editorial, not heavy cards) ════════════ */
 .pillar-sidebar { display: flex; flex-direction: column; gap: 2.25rem; position: relative; }
 .sidebar-block { border-top: 2px solid var(--ink); padding-top: 1rem; }
 .sidebar-label {
 font-family: var(--mono);
 font-size: 0.7rem;
 color: var(--vermilion);
 text-transform: uppercase;
 letter-spacing: 0.12em;
 font-weight: 700;
 margin-bottom: 0.9rem;
 }
 .covers-list {
 list-style: none;
 padding: 0;
 margin: 0;
 color: var(--graphite);
 font-size: 0.84rem;
 line-height: 1.55;
 }
 .covers-list li {
 padding: 0.4rem 0 0.4rem 1.1rem;
 position: relative;
 border-bottom: 1px solid var(--line);
 margin: 0;
 }
 .covers-list li:last-child { border-bottom: none; }
 .covers-list li::before {
 content: '·';
 position: absolute;
 left: 0;
 color: var(--vermilion);
 font-weight: 700;
 }
 .related-pill, .track-link {
 display: block;
 font-family: var(--sans);
 font-size: 0.88rem;
 color: var(--graphite);
 padding: 0.5rem 0;
 border-bottom: 1px solid var(--line);
 transition: color 0.15s, padding-left 0.15s;
 }
 .related-pill:last-child, .track-link:last-child { border-bottom: none; }
 .related-pill:hover, .track-link:hover { color: var(--vermilion-2); padding-left: 0.35rem; }

 .sidebar-seal { width: 64px; color: var(--line); align-self: flex-start; margin-top: 0.5rem; }

 /* ════════════ RESPONSIVE ════════════ */
 @media (max-width: 860px) {
 .pillar-body { grid-template-columns: 1fr; gap: 2.75rem; }
 .pillar-sidebar { order: 1; }
 .sidebar-seal { display: none; }
 }
 @media (max-width: 560px) {
 .pillar-hero-inner { padding-top: 3.25rem; padding-bottom: 2.5rem; }
 .article-row { grid-template-columns: 2.25rem 1fr; }
 .ix-meta { grid-column: 2; padding-top: 0.5rem; }
 }
</style>
