---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'data-integrity');
const sorted = all.sort((a, b) => {
 const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
 const ta = tierOrder[a.data.tier ?? 'Intermediate'] ?? 1;
 const tb = tierOrder[b.data.tier ?? 'Intermediate'] ?? 1;
 return ta - tb;
});

const PILLAR_ACCENT = '#CB4B2A';

const tierColors: Record<string, string> = {
 Beginner: '#3C6B4A',
 Intermediate: '#B26B1E',
 Advanced: '#7A2E23',
};

const relatedPillars = [
 { slug: 'csv-csa', title: 'CSV & CSA', color: '#3C6B4A' },
 { slug: 'audits-inspection', title: 'Audits & Inspection', color: '#7A2E23' },
 { slug: 'manufacturing-automation', title: 'Manufacturing Systems', color: '#B26B1E' },
];

const regLinks = [
 { href: 'https://www.fda.gov/regulatory-information/search-fda-guidance-documents/data-integrity-and-compliance-drug-cgmp-guidance-industry', label: 'FDA DI Guidance (Dec 2018)' },
 { href: 'https://www.gov.uk/government/publications/guidance-on-gxp-data-integrity', label: 'MHRA GXP DI Guidance (Mar 2018)' },
 { href: 'https://www.who.int/publications/m/item/WHO-TRS-996-annex-5', label: 'WHO TRS 996 Annex 5' },
 { href: 'https://www.picscheme.org/en/publication?id=14', label: 'PIC/S PI 041' },
];
---
<Layout wide={true} title="Data Integrity" description="Complete coverage of pharmaceutical data integrity, ALCOA+, audit trails, data lifecycle, regulatory basis, and program architecture for FDA/EMA compliance.">
 <!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
 <header class="pillar-hero duotone">
 <img src="/images/records-review.jpg" alt="" loading="eager" />
 <div class="pillar-hero-grad"></div>
 <div class="wrap pillar-hero-inner">
 <a href="/pillars" class="back-link">← All Pillars</a>

 <div class="pillar-hero-top">
 <span class="emblem pillar-emblem" style="--src:url('/brand/emblems/pillar-data-integrity.svg')"></span>
 <div class="pillar-hero-lede">
 <div class="page-label pillar-label" style={`--pc:${PILLAR_ACCENT}`}>Pillar 01 · Data Integrity</div>
 <h1 class="pillar-title">Data Integrity</h1>
 </div>
 </div>

 <p class="lead pillar-lead">
 Data integrity is not a compliance checkbox, it is a fundamental property of every quality decision a pharmaceutical company makes. When an inspector opens a LIMS audit trail, they are not looking for evidence of fraud. They are looking for evidence that the data cannot be trusted, for any reason. Understanding this distinction is the starting point for building programs that hold.
 </p>

 <div class="reg-basis">
 <div class="reg-label">Regulatory basis</div>
 <div class="reg-links">
 {regLinks.map(r => (
 <a href={r.href} target="_blank" rel="noopener">{r.label}</a>
 ))}
 </div>
 </div>
 </div>
 </header>

 <!-- ═══════════ BODY — editorial index + slim sidebar ═══════════ -->
 <section class="section-tight">
 <div class="wrap pillar-body">
 <div class="articles-section">
 <div class="articles-head">
 <span class="kicker">Articles in this pillar</span>
 <span class="marginalia articles-count">{sorted.length} record{sorted.length === 1 ? '' : 's'} · sorted by depth</span>
 </div>
 {sorted.length === 0 ? (
 <p class="empty">Articles coming soon.</p>
 ) : (
 <ol class="index-list article-list">
 {sorted.map((post, i) => {
 const wordCount = post.body?.split(/\s+/).length ?? 0;
 const readTime = Math.max(1, Math.ceil(wordCount / 220));
 const tier = post.data.tier ?? 'Intermediate';
 const color = tierColors[tier] ?? '#837B69';
 return (
 <li>
 <a href={`/articles/${post.slug}`} class="article-row">
 <span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
 <div class="ix-title-cell">
 <div class="article-row-top">
 <span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}40`}>{tier}</span>
 <h3 class="ix-title">{post.data.title}</h3>
 </div>
 <p class="article-row-desc">{post.data.description}</p>
 </div>
 <span class="ix-meta">{readTime} min<span class="arrow"> →</span></span>
 </a>
 </li>
 );
 })}
 </ol>
 )}
 </div>

 <aside class="pillar-sidebar">
 <div class="sidebar-block covers-block">
 <div class="sidebar-label">What this pillar covers</div>
 <ul class="covers-list">
 <li>ALCOA+, each principle, its failure modes, and how to assess it</li>
 <li>Regulatory framework: FDA, MHRA, WHO, PIC/S, EMA</li>
 <li>Data lifecycle: generation through archival and destruction</li>
 <li>Audit trail design, review, and review-by-exception</li>
 <li>Static vs. dynamic records; metadata as part of the record</li>
 <li>Data governance: ownership, system inventory, criticality tiers</li>
 <li>Paper, hybrid, and electronic system risks</li>
 <li>Warning letter patterns and program-level remediation</li>
 </ul>
 </div>

 <img class="sidebar-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />

 <div class="sidebar-block">
 <div class="sidebar-label">Related pillars</div>
 <div class="related-list">
 {relatedPillars.map(p => (
 <a href={`/pillars/${p.slug}`} class="related-pill" style={`--rc: ${p.color}`}>
 <span class="related-tick" aria-hidden="true"></span>{p.title}<span class="related-go"> →</span>
 </a>
 ))}
 </div>
 </div>

 <div class="sidebar-block tracks-block">
 <div class="sidebar-label">Learning tracks</div>
 <a href="/tracks/foundations" class="track-link"><span class="track-n">01</span>Foundations Track, start here</a>
 <a href="/tracks/implementation" class="track-link"><span class="track-n">02</span>Implementation Track</a>
 <a href="/tracks/advanced" class="track-link"><span class="track-n">03</span>Advanced Track</a>
 </div>

 <img class="sidebar-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 </aside>
 </div>
 </section>
</Layout>

<style>
 /* ═══════════ HEADER BAND ═══════════ */
 .pillar-hero {
 position: relative;
 min-height: 52vh;
 display: flex;
 align-items: flex-end;
 border-bottom: 3px solid var(--vermilion);
 }
 .pillar-hero > img { position: absolute; inset: 0; }
 .pillar-hero-grad {
 position: absolute; inset: 0; z-index: 2;
 background: linear-gradient(180deg, rgba(22,19,13,0.20) 0%, rgba(22,19,13,0.45) 45%, rgba(22,19,13,0.88) 100%);
 }
 .pillar-hero-inner {
 position: relative; z-index: 3;
 padding-top: 4.5rem; padding-bottom: 3rem;
 }

 .back-link {
 font-family: var(--mono);
 font-size: 0.74rem;
 letter-spacing: 0.06em;
 text-transform: uppercase;
 color: var(--on-ink-dim);
 display: inline-block;
 margin-bottom: 2rem;
 transition: color 0.15s;
 }
 .back-link:hover { color: var(--on-ink); }

 .pillar-hero-top { display: flex; align-items: center; gap: 1.25rem; margin-bottom: 1.5rem; }
 .pillar-emblem { color: var(--on-ink); width: 56px; height: 56px; flex-shrink: 0; }
 .pillar-label {
 color: #F2C9B8;
 margin-bottom: 0.5rem;
 }
 .pillar-title {
 font-family: var(--display); font-weight: 500; color: var(--on-ink);
 font-size: clamp(2.4rem, 6vw, 4.4rem); line-height: 0.98; letter-spacing: -0.025em;
 }

 .pillar-lead {
 color: var(--on-ink-dim);
 max-width: 60ch;
 margin-bottom: 1.75rem;
 }

 /* Regulatory basis — mono chips over the image */
 .reg-basis {
 display: flex;
 flex-wrap: wrap;
 align-items: center;
 gap: 0.6rem 0.85rem;
 }
 .reg-label {
 font-family: var(--mono);
 font-size: 0.7rem;
 color: #F2C9B8;
 text-transform: uppercase;
 letter-spacing: 0.13em;
 font-weight: 700;
 flex-shrink: 0;
 }
 .reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
 .reg-links a {
 font-family: var(--mono);
 font-size: 0.72rem;
 color: var(--on-ink);
 padding: 0.28rem 0.65rem;
 background: rgba(236, 230, 216, 0.08);
 border: 1px solid var(--line-ink);
 border-radius: var(--radius);
 transition: border-color 0.15s, color 0.15s, background 0.15s;
 }
 .reg-links a:hover { border-color: var(--vermilion); color: var(--on-ink); background: rgba(203, 75, 42, 0.22); }

 /* ═══════════ BODY GRID ═══════════ */
 .pillar-body {
 display: grid;
 grid-template-columns: 1fr 300px;
 gap: 4rem;
 align-items: start;
 }

 .articles-head {
 display: flex;
 justify-content: space-between;
 align-items: baseline;
 gap: 1.5rem;
 margin-bottom: 1.5rem;
 padding-bottom: 1rem;
 border-bottom: 2px solid var(--ink);
 }
 .articles-count { white-space: nowrap; }
 .empty { color: var(--muted); font-size: 0.9rem; }

 /* ── Editorial article index ── */
 .article-list { list-style: none; border-top: none; }
 .article-row {
 display: grid;
 grid-template-columns: 3.5rem 1fr auto;
 gap: 1.5rem;
 align-items: baseline;
 padding: 1.5rem 0;
 border-bottom: 1px solid var(--line);
 color: inherit;
 transition: background 0.15s, padding-left 0.15s;
 }
 .article-row:hover { background: rgba(226, 219, 201, 0.35); padding-left: 0.6rem; }
 .article-row .ix-num { font-family: var(--mono); font-size: 0.78rem; color: var(--vermilion); padding-top: 0.2rem; }

 .article-row-top {
 display: flex;
 align-items: center;
 gap: 0.65rem;
 margin-bottom: 0.4rem;
 flex-wrap: wrap;
 }
 .article-row .ix-title {
 font-family: var(--display);
 font-weight: 500;
 font-size: 1.3rem;
 line-height: 1.15;
 color: var(--ink);
 transition: color 0.15s;
 }
 .article-row:hover .ix-title { color: var(--vermilion-2); }

 .article-row-desc {
 font-size: 0.9rem;
 color: var(--muted);
 line-height: 1.6;
 margin: 0;
 max-width: 54ch;
 }

 .article-row .ix-meta {
 font-family: var(--mono);
 font-size: 0.74rem;
 color: var(--muted);
 white-space: nowrap;
 padding-top: 0.25rem;
 }
 .arrow { transition: color 0.15s; }
 .article-row:hover .arrow { color: var(--vermilion); }

 /* ═══════════ SIDEBAR — editorial / mono blocks (not heavy cards) ═══════════ */
 .pillar-sidebar { display: flex; flex-direction: column; gap: 2rem; position: relative; }

 .sidebar-block { }

 .sidebar-label {
 font-family: var(--mono);
 font-size: 0.7rem;
 color: var(--vermilion);
 text-transform: uppercase;
 letter-spacing: 0.14em;
 font-weight: 700;
 margin-bottom: 1rem;
 padding-bottom: 0.65rem;
 border-bottom: 1px solid var(--line);
 }

 .covers-list {
 padding-left: 0;
 list-style: none;
 color: var(--graphite);
 font-size: 0.85rem;
 line-height: 1.55;
 }
 .covers-list li {
 position: relative;
 padding-left: 1.1rem;
 margin-bottom: 0.6rem;
 }
 .covers-list li::before {
 content: '—';
 position: absolute;
 left: 0;
 color: var(--vermilion);
 }

 .sidebar-rule { display: block; width: 100%; height: 12px; color: var(--line); }

 .related-list { display: flex; flex-direction: column; }
 .related-pill {
 display: flex;
 align-items: center;
 gap: 0.55rem;
 font-family: var(--sans);
 font-size: 0.9rem;
 font-weight: 500;
 color: var(--graphite);
 padding: 0.55rem 0;
 border-bottom: 1px solid var(--line);
 transition: color 0.15s, padding-left 0.15s;
 }
 .related-list .related-pill:last-child { border-bottom: none; }
 .related-tick { width: 6px; height: 6px; background: var(--rc, var(--vermilion)); border-radius: 1px; flex-shrink: 0; }
 .related-go { margin-left: auto; font-family: var(--mono); font-size: 0.78rem; color: var(--muted); transition: color 0.15s; }
 .related-pill:hover { color: var(--rc, var(--vermilion-2)); padding-left: 0.3rem; }
 .related-pill:hover .related-go { color: var(--rc, var(--vermilion-2)); }

 .tracks-block { display: flex; flex-direction: column; }
 .track-link {
 display: flex;
 align-items: baseline;
 gap: 0.7rem;
 font-family: var(--sans);
 font-size: 0.875rem;
 color: var(--graphite);
 padding: 0.55rem 0;
 border-bottom: 1px solid var(--line);
 transition: color 0.15s;
 }
 .tracks-block .track-link:last-of-type { border-bottom: none; }
 .track-link .track-n { font-family: var(--mono); font-size: 0.72rem; color: var(--vermilion); flex-shrink: 0; }
 .track-link:hover { color: var(--vermilion-2); }

 .sidebar-seal { width: 84px; color: var(--vermilion); opacity: 0.85; margin-top: 0.5rem; align-self: flex-start; }

 @media (max-width: 860px) {
 .pillar-hero { min-height: 44vh; }
 .pillar-hero-inner { padding-top: 3rem; }
 .pillar-hero-top { gap: 1rem; }
 .pillar-emblem { width: 44px; height: 44px; }
 .pillar-body { grid-template-columns: 1fr; gap: 2.75rem; }
 .pillar-sidebar { order: -1; }
 .sidebar-seal { display: none; }
 }
 @media (max-width: 560px) {
 .article-row { grid-template-columns: 2.25rem 1fr; }
 .article-row .ix-meta { grid-column: 2; padding-top: 0.4rem; }
 }
</style>
