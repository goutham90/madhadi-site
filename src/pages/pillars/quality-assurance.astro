---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'quality-assurance');
const sorted = all.sort((a, b) => {
	const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
	return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});

const tierColors: Record<string, string> = {
	Beginner: '#3C6B4A',
	Intermediate: '#B26B1E',
	Advanced: '#7A2E23',
};

const relatedPillars = [
	{ slug: 'data-integrity', title: 'Data Integrity', color: '#3C6B4A' },
	{ slug: 'audits-inspection', title: 'Audits & Inspection', color: '#7A2E23' },
	{ slug: 'csv-csa', title: 'CSV & CSA', color: '#B26B1E' },
];

const regLinks = [
	{ href: 'https://www.ich.org/page/quality-guidelines', label: 'ICH Q10 (Pharmaceutical Quality System)' },
	{ href: 'https://www.ich.org/page/quality-guidelines', label: 'ICH Q9(R1) (Quality Risk Management, 2023)' },
	{ href: 'https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-211', label: '21 CFR Part 211' },
	{ href: 'https://www.ema.europa.eu/en/documents/other/eudralex-volume-4-eu-guidelines-good-manufacturing-practice-medicinal-products-human-veterinary-use_en.pdf', label: 'EU GMP Part I' },
];
---
<Layout wide={true} title="Quality Assurance & QMS" description="ICH Q10 pharmaceutical quality system, ICH Q9(R1) risk management, CAPA, deviations, and how QA, QC, validation, and data integrity actually fit together.">
	<!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
	<header class="qa-hero duotone">
		<img src="/images/audit-signing.jpg" alt="" loading="eager" />
		<div class="qa-hero-grad"></div>
		<div class="wrap qa-hero-inner">
			<a href="/pillars" class="qa-back">← All Pillars</a>
			<div class="qa-hero-grid">
				<div class="qa-hero-text">
					<div class="qa-kick">
						<span class="emblem qa-emblem" style="--src:url('/brand/emblems/pillar-quality-assurance.svg')"></span>
						<span class="kicker">Pillar 04 · Quality Assurance</span>
					</div>
					<h1 class="qa-title">Quality Assurance <span class="amp">&amp;</span> QMS</h1>
					<p class="qa-intro">
						A quality management system is the organizational framework inside which data integrity, validation, and all other GxP disciplines operate. ICH Q10 describes the pharmaceutical quality system; ICH Q9(R1) provides the risk framework that lets you allocate effort proportionally. Without these foundations, DI and validation programs become disconnected compliance exercises rather than integrated quality functions.
					</p>
				</div>
				<div class="qa-hero-side">
					<div class="qa-reg-label">Regulatory basis</div>
					<div class="qa-reg-links">
						{regLinks.map(r => (
							<a href={r.href} target="_blank" rel="noopener">{r.label}</a>
						))}
					</div>
				</div>
			</div>
		</div>
	</header>

	<div class="wrap">
		<div class="pillar-body">
			<!-- ═══════════ ARTICLE INDEX (editorial list) ═══════════ -->
			<section class="articles-section">
				<div class="articles-head">
					<span class="kicker">The record · this pillar</span>
					<h2 class="display-2">Articles in Quality Assurance</h2>
				</div>
				{sorted.length === 0 ? (
					<p class="empty">Articles coming soon.</p>
				) : (
					<ol class="index-list qa-index">
						{sorted.map((post, i) => {
							const wordCount = post.body?.split(/\s+/).length ?? 0;
							const readTime = Math.max(1, Math.ceil(wordCount / 220));
							const tier = post.data.tier ?? 'Intermediate';
							const color = tierColors[tier] ?? '#837B69';
							return (
								<li>
									<a href={`/articles/${post.slug}`} class="qa-row">
										<span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
										<div class="qa-row-main">
											<div class="qa-row-top">
												<span class="tier-badge" style={`background:${color}; color:#F7F3EA; border-color:${color}`}>{tier}</span>
												<h3 class="ix-title">{post.data.title}</h3>
											</div>
											<p class="qa-row-desc">{post.data.description}</p>
										</div>
										<span class="ix-meta">{readTime} min →</span>
									</a>
								</li>
							);
						})}
					</ol>
				)}
			</section>

			<!-- ═══════════ SIDEBAR (editorial / mono blocks) ═══════════ -->
			<aside class="pillar-sidebar">
				<div class="side-block side-covers">
					<div class="side-label">What this pillar covers</div>
					<ul class="side-list">
						<li>ICH Q10 pharmaceutical quality system framework</li>
						<li>ICH Q9(R1) quality risk management (2023 revision)</li>
						<li>Document control, change control, deviation management</li>
						<li>CAPA: structure, investigation depth, effectiveness verification</li>
						<li>OOS/OOT: investigation protocol and documentation</li>
						<li>Supplier quality and vendor management</li>
						<li>Training systems and competency management</li>
						<li>Internal audit and management review</li>
						<li>Risk tools: FMEA/FMECA, HACCP, risk ranking</li>
						<li>How QA, QC, validation, and DI fit together</li>
					</ul>
				</div>

				<div class="side-block">
					<div class="side-label">Related pillars</div>
					<div class="side-related">
						{relatedPillars.map(p => (
							<a href={`/pillars/${p.slug}`} class="related-pill" style={`--rc: ${p.color}`}>
								<span class="related-dot"></span>{p.title} <span class="related-arrow">→</span>
							</a>
						))}
					</div>
				</div>

				<div class="side-block">
					<div class="side-label">Learning tracks</div>
					<div class="side-tracks">
						<a href="/tracks/foundations" class="track-link"><span class="track-n">01</span>Foundations Track</a>
						<a href="/tracks/implementation" class="track-link"><span class="track-n">02</span>Implementation Track</a>
						<a href="/tracks/advanced" class="track-link"><span class="track-n">03</span>Advanced Track</a>
					</div>
				</div>

				<img class="side-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />
				<img class="side-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
			</aside>
		</div>
	</div>
</Layout>

<style>
	/* ════════════ HEADER BAND ════════════ */
	.qa-hero {
		position: relative;
		min-height: 56vh;
		display: flex;
		align-items: flex-end;
		border-bottom: 3px solid var(--vermilion);
	}
	.qa-hero > img { position: absolute; inset: 0; }
	.qa-hero-grad {
		position: absolute; inset: 0; z-index: 2;
		background: linear-gradient(180deg, rgba(22,19,13,0.20) 0%, rgba(22,19,13,0.40) 45%, rgba(22,19,13,0.88) 100%);
	}
	.qa-hero-inner { position: relative; z-index: 3; padding-top: 4.5rem; padding-bottom: 3rem; width: 100%; }

	.qa-back {
		display: inline-block;
		font-family: var(--mono);
		font-size: 0.74rem;
		letter-spacing: 0.08em;
		color: var(--on-ink-dim);
		margin-bottom: 2rem;
		transition: color 0.15s;
	}
	.qa-back:hover { color: var(--on-ink); }

	.qa-hero-grid {
		display: grid;
		grid-template-columns: 1.5fr 0.95fr;
		gap: 3.5rem;
		align-items: end;
	}

	.qa-kick { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.4rem; }
	.qa-emblem { color: var(--on-ink); width: 40px; height: 40px; flex-shrink: 0; }
	.qa-kick .kicker { color: #F2C9B8; }

	.qa-title {
		font-family: var(--display);
		font-weight: 500;
		color: var(--on-ink);
		font-size: clamp(2.4rem, 5.4vw, 4.4rem);
		line-height: 1.0;
		letter-spacing: -0.025em;
		margin-bottom: 1.35rem;
	}
	.qa-title .amp { color: var(--vermilion); font-style: italic; }

	.qa-intro {
		color: var(--on-ink-dim);
		font-size: 1.08rem;
		line-height: 1.62;
		max-width: 46ch;
	}

	/* Regulatory basis — mono chips over the image */
	.qa-hero-side {
		border-left: 1px solid var(--line-ink);
		padding-left: 2rem;
	}
	.qa-reg-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--vermilion);
		margin-bottom: 1rem;
	}
	.qa-reg-links { display: flex; flex-direction: column; gap: 0.55rem; }
	.qa-reg-links a {
		font-family: var(--mono);
		font-size: 0.74rem;
		line-height: 1.35;
		color: var(--on-ink);
		padding: 0.5rem 0.75rem;
		background: rgba(236, 230, 216, 0.06);
		border: 1px solid var(--line-ink);
		border-radius: var(--radius);
		transition: border-color 0.15s, background 0.15s, color 0.15s;
	}
	.qa-reg-links a:hover {
		border-color: var(--vermilion);
		background: rgba(203, 75, 42, 0.14);
		color: var(--on-ink);
	}

	/* ════════════ BODY (asymmetric two-column) ════════════ */
	.pillar-body {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 4rem;
		align-items: start;
		padding: 4rem 0 6rem;
	}

	/* ── Article index ── */
	.articles-head { margin-bottom: 2rem; }
	.articles-head .display-2 { margin-top: 0.6rem; }

	.empty { color: var(--muted); font-size: 0.95rem; font-family: var(--mono); }

	.qa-index { border-top: 2px solid var(--ink); }
	.qa-index li { margin: 0; }

	.qa-row {
		display: grid;
		grid-template-columns: 3.25rem 1fr auto;
		gap: 1.5rem;
		align-items: baseline;
		padding: 1.6rem 0;
		border-bottom: 1px solid var(--line);
		color: inherit;
		transition: background 0.15s, padding-left 0.15s;
	}
	.qa-row:hover { background: rgba(226, 219, 201, 0.35); padding-left: 0.6rem; }

	.qa-row .ix-num { font-family: var(--mono); font-size: 0.82rem; color: var(--vermilion); padding-top: 0.2rem; }

	.qa-row-main { min-width: 0; }
	.qa-row-top {
		display: flex;
		align-items: center;
		gap: 0.7rem;
		margin-bottom: 0.45rem;
		flex-wrap: wrap;
	}
	.qa-row .ix-title { font-size: 1.3rem; }
	.qa-row:hover .ix-title { color: var(--vermilion-2); }

	.qa-row-desc {
		font-size: 0.92rem;
		color: var(--graphite);
		line-height: 1.6;
		margin: 0;
		max-width: 52rem;
	}

	.qa-row .ix-meta { padding-top: 0.25rem; transition: color 0.15s; }
	.qa-row:hover .ix-meta { color: var(--vermilion-2); }

	/* ════════════ SIDEBAR (mono / editorial blocks) ════════════ */
	.pillar-sidebar { display: flex; flex-direction: column; gap: 2.25rem; }

	.side-block { border-top: 1px solid var(--ink); padding-top: 1rem; }

	.side-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		color: var(--vermilion);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-weight: 700;
		margin-bottom: 1rem;
	}

	.side-list {
		list-style: none;
		padding: 0;
		margin: 0;
		color: var(--graphite);
		font-size: 0.86rem;
		line-height: 1.5;
	}
	.side-list li {
		position: relative;
		padding-left: 1.1rem;
		margin-bottom: 0.6rem;
	}
	.side-list li::before {
		content: '—';
		position: absolute;
		left: 0;
		color: var(--vermilion);
		font-family: var(--mono);
	}

	.side-related { display: flex; flex-direction: column; }
	.related-pill {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--sans);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--graphite);
		padding: 0.6rem 0;
		border-bottom: 1px solid var(--line);
		transition: color 0.15s, padding-left 0.15s;
	}
	.related-pill:last-child { border-bottom: none; }
	.related-dot {
		width: 8px; height: 8px; border-radius: 50%;
		background: var(--rc, var(--vermilion));
		flex-shrink: 0;
	}
	.related-arrow { margin-left: auto; color: var(--muted); transition: transform 0.15s, color 0.15s; }
	.related-pill:hover { color: var(--rc, var(--vermilion-2)); padding-left: 0.3rem; }
	.related-pill:hover .related-arrow { color: var(--rc, var(--vermilion-2)); transform: translateX(2px); }

	.side-tracks { display: flex; flex-direction: column; }
	.track-link {
		display: flex;
		align-items: baseline;
		gap: 0.7rem;
		font-family: var(--sans);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--graphite);
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--line);
		transition: color 0.15s;
	}
	.track-link:last-child { border-bottom: none; }
	.track-link .track-n { font-family: var(--mono); font-size: 0.74rem; color: var(--vermilion); }
	.track-link:hover { color: var(--vermilion-2); }

	.side-rule { display: block; width: 100%; height: 14px; color: var(--line); }
	.side-seal { width: 84px; color: var(--vermilion); opacity: 0.5; align-self: flex-start; }

	/* ════════════ RESPONSIVE ════════════ */
	@media (max-width: 980px) {
		.qa-hero-grid { grid-template-columns: 1fr; gap: 2rem; }
		.qa-hero-side { border-left: none; padding-left: 0; border-top: 1px solid var(--line-ink); padding-top: 1.5rem; }
		.qa-reg-links { flex-direction: row; flex-wrap: wrap; }
		.qa-reg-links a { flex: 1 1 14rem; }
	}

	@media (max-width: 860px) {
		.pillar-body { grid-template-columns: 1fr; gap: 3rem; padding: 3rem 0 4.5rem; }
		.pillar-sidebar { order: -1; }
		.side-seal { display: none; }
	}

	@media (max-width: 560px) {
		.qa-hero { min-height: 50vh; }
		.qa-hero-inner { padding-top: 3rem; }
		.qa-row { grid-template-columns: 2.5rem 1fr; }
		.qa-row .ix-meta { display: none; }
		.qa-reg-links a { flex: 1 1 100%; }
	}
</style>
