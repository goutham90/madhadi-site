---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'manufacturing-automation');
const sorted = all.sort((a, b) => {
 const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
 return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});
const tierColors: Record<string, string> = { Beginner: '#2F6E4F', Intermediate: '#1C4E80', Advanced: '#7A3B57' };
const accent = '#46566E';
---
<Layout title="Manufacturing & Automation Systems" description="MES, electronic batch records, SCADA, DCS, PLCs, process historians, LIMS, ELN, and 21 CFR Part 11 on the shop floor." wide={true}>
 <div class="pillar-header">
 <a href="/pillars" class="back-link">← All Pillars</a>
 <div class="pillar-label" style={`color:${accent}`}>Pillar 07</div>
 <h1>Manufacturing &amp; Automation Systems</h1>
 <p class="pillar-intro lead">
 The shop floor generates more GxP data than any other area of a pharmaceutical facility, and it is frequently the weakest point in a data integrity program. PLCs, historians, and SCADA systems often predate modern Part 11 compliance expectations. MES and EBR implementations are complex, and data transfer between systems creates verification gaps. This pillar covers how to manage data integrity across manufacturing automation realistically.
 </p>
 <div class="reg-basis">
 <div class="reg-label">Regulatory basis</div>
 <div class="reg-links">
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11" target="_blank" rel="noopener">21 CFR Part 11</a>
 <a href="https://www.gmp-compliance.org/gmp-news/eu-gmp-annex-11-computerised-systems" target="_blank" rel="noopener">EU GMP Annex 11</a>
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-211" target="_blank" rel="noopener">21 CFR Part 211</a>
 </div>
 </div>
 </div>

 <div class="pillar-body">
 <div class="articles-section">
 <h2>Articles in this pillar</h2>
 {sorted.length === 0 ? (
 <p class="empty">Articles coming soon.</p>
 ) : (
 <div class="article-list">
 {sorted.map(post => {
 const readTime = Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 220));
 const tier = post.data.tier ?? 'Intermediate';
 const color = tierColors[tier] ?? '#756B5B';
 return (
 <a href={`/articles/${post.slug}`} class="article-row">
 <div class="article-row-main">
 <div class="article-row-top">
 <span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}40`}>{tier}</span>
 <h3>{post.data.title}</h3>
 </div>
 <p>{post.data.description}</p>
 </div>
 <div class="article-row-meta"><span>{readTime} min</span><span class="arrow">→</span></div>
 </a>
 );
 })}
 </div>
 )}
 </div>
 <aside class="pillar-sidebar">
 <div class="sidebar-block">
 <div class="sidebar-label" style={`color:${accent}`}>What this pillar covers</div>
 <ul>
 <li>MES and electronic batch records (EBR)</li>
 <li>SCADA, DCS, and PLC data integrity</li>
 <li>Process historians and data retrieval</li>
 <li>LIMS, ELN, and chromatography data systems</li>
 <li>21 CFR Part 11 on the shop floor</li>
 <li>Review-by-exception in manufacturing</li>
 <li>Time synchronization across systems</li>
 <li>Audit trails on PLCs and historians</li>
 <li>Data transfer validation between shop-floor systems</li>
 </ul>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label" style={`color:${accent}`}>Related pillars</div>
 <a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
 <a href="/pillars/csv-csa" class="related-pill">CSV &amp; CSA →</a>
 <a href="/pillars/equipment-qualification" class="related-pill">Equipment Qualification →</a>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label" style={`color:${accent}`}>Learning tracks</div>
 <a href="/tracks/implementation" class="track-link">Implementation Track</a>
 <a href="/tracks/advanced" class="track-link">Advanced Track</a>
 </div>
 </aside>
 </div>
</Layout>

<style>
 /* ── Pillar header ── */
 .pillar-header { margin-bottom: 3.5rem; padding-bottom: 2.25rem; border-bottom: 1px solid var(--line); }
 .back-link { font-size: 0.72rem; color: var(--muted); font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.12em; display: inline-block; margin-bottom: 1.75rem; transition: color 0.15s; }
 .back-link:hover { color: var(--navy); }
 .pillar-label { font-size: 0.72rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.16em; font-weight: 500; margin-bottom: 0.7rem; }
 h1 { font-family: var(--serif); font-weight: 500; font-size: clamp(2rem, 4vw, 2.9rem); letter-spacing: -0.02em; line-height: 1.1; margin-bottom: 1.1rem; color: var(--ink); }
 .pillar-intro { font-size: 1.15rem; color: var(--muted); line-height: 1.65; max-width: 42rem; margin-bottom: 2rem; }

 /* ── Regulatory basis panel ── */
 .reg-basis { display: flex; flex-wrap: wrap; align-items: center; gap: 0.85rem; padding: 1.1rem 1.35rem; background: var(--paper-2); border: 1px solid var(--line); border-radius: var(--radius); }
 .reg-label { font-size: 0.7rem; font-family: var(--mono); color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 500; flex-shrink: 0; }
 .reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
 .reg-links a {
 display: inline-flex; align-items: center;
 font-family: var(--mono); font-size: 0.68rem; font-weight: 500; letter-spacing: 0.02em;
 color: var(--muted);
 padding: 0.18rem 0.5rem;
 background: var(--surface);
 border: 1px solid var(--line-2);
 border-radius: var(--radius-sm);
 transition: border-color 0.15s, color 0.15s;
 }
 .reg-links a:hover { border-color: var(--navy); color: var(--navy); }

 /* ── Body grid ── */
 .pillar-body { display: grid; grid-template-columns: 1fr 280px; gap: 3.5rem; align-items: start; }

 /* ── Articles section ── */
 .articles-section h2 {
 font-family: var(--serif); font-weight: 500;
 font-size: 1.4rem; letter-spacing: -0.01em; color: var(--ink);
 margin-bottom: 1.25rem; padding-bottom: 0.75rem;
 border-bottom: 1px solid var(--line);
 }
 .empty { color: var(--muted); font-size: 0.92rem; }
 .article-list { display: flex; flex-direction: column; }
 .article-row {
 display: flex; justify-content: space-between; align-items: flex-start; gap: 1.25rem;
 padding: 1.35rem 0;
 border-bottom: 1px solid var(--line);
 text-decoration: none; color: inherit;
 transition: background 0.15s, padding 0.15s;
 border-radius: var(--radius);
 }
 .article-row:last-child { border-bottom: none; }
 .article-row:hover { background: var(--surface); padding-left: 0.85rem; padding-right: 0.85rem; }
 .article-row-main { flex: 1; }
 .article-row-top { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.4rem; }
 .tier-badge {
 font-size: 0.62rem; font-family: var(--mono); font-weight: 600;
 text-transform: uppercase; letter-spacing: 0.06em;
 padding: 0.16rem 0.5rem; border-radius: var(--radius-sm); border: 1px solid; flex-shrink: 0;
 }
 .article-row-main h3 {
 font-family: var(--serif); font-weight: 500;
 font-size: 1.15rem; color: var(--ink); line-height: 1.3;
 transition: color 0.15s;
 }
 .article-row:hover .article-row-main h3 { color: var(--link); }
 .article-row-main p { font-size: 0.9rem; color: var(--muted); line-height: 1.55; margin: 0; }
 .article-row-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; flex-shrink: 0; }
 .article-row-meta span { font-size: 0.72rem; color: var(--muted); font-family: var(--mono); }
 .arrow { color: var(--line-2); transition: color 0.15s; }
 .article-row:hover .arrow { color: var(--link); }

 /* ── Sidebar ── */
 .pillar-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
 .sidebar-block { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow-sm); padding: 1.35rem; }
 .sidebar-label { font-size: 0.7rem; font-family: var(--mono); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 500; margin-bottom: 0.9rem; }
 .sidebar-block ul { padding-left: 1.1rem; list-style: disc; color: var(--body); font-size: 0.85rem; line-height: 1.6; }
 .sidebar-block li { margin-bottom: 0.35rem; }
 .sidebar-block li::marker { color: var(--brass); }
 .related-pill, .track-link {
 display: block; font-family: var(--sans); font-size: 0.85rem; color: var(--body);
 padding: 0.45rem 0; border-bottom: 1px solid var(--line);
 transition: color 0.15s;
 }
 .related-pill:last-child, .track-link:last-child { border-bottom: none; }
 .related-pill:hover, .track-link:hover { color: var(--link); }

 @media (max-width: 860px) {
 .pillar-body { grid-template-columns: 1fr; gap: 2.5rem; }
 .pillar-sidebar { order: -1; }
 }
</style>
