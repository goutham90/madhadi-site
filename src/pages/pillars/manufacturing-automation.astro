---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'manufacturing-automation');
const sorted = all.sort((a, b) => {
 const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
 return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});
const tierColors: Record<string, string> = { Beginner: '#3C6B4A', Intermediate: '#B26B1E', Advanced: '#7A2E23' };
---
<Layout title="Manufacturing & Automation Systems" description="MES, electronic batch records, SCADA, DCS, PLCs, process historians, LIMS, ELN, and 21 CFR Part 11 on the shop floor." wide={true}>

 <!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
 <header class="pillar-hero duotone">
 <img src="/images/manufacturing-cleanroom.jpg" alt="Pharmaceutical cleanroom manufacturing line" loading="eager" />
 <div class="pillar-hero-grad"></div>
 <div class="wrap pillar-hero-inner">
 <a href="/pillars" class="back-link">← All Pillars</a>
 <div class="pillar-hero-top">
 <span class="emblem pillar-emblem" style="--src:url('/brand/emblems/pillar-manufacturing-automation.svg')"></span>
 <span class="kicker">Pillar 07 · The Shop Floor</span>
 </div>
 <h1 class="pillar-title">Manufacturing &amp; Automation Systems</h1>
 <p class="pillar-intro lead">
 The shop floor generates more GxP data than any other area of a pharmaceutical facility, and it is frequently the weakest point in a data integrity program. PLCs, historians, and SCADA systems often predate modern Part 11 compliance expectations. MES and EBR implementations are complex, and data transfer between systems creates verification gaps. This pillar covers how to manage data integrity across manufacturing automation realistically.
 </p>
 <div class="reg-basis">
 <span class="reg-label">Regulatory basis</span>
 <div class="reg-links">
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11" target="_blank" rel="noopener">21 CFR Part 11</a>
 <a href="https://www.gmp-compliance.org/gmp-news/eu-gmp-annex-11-computerised-systems" target="_blank" rel="noopener">EU GMP Annex 11</a>
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-211" target="_blank" rel="noopener">21 CFR Part 211</a>
 </div>
 </div>
 </div>
 </header>

 <!-- ═══════════ BODY: editorial index + sidebar ═══════════ -->
 <section class="section-tight">
 <div class="wrap">
 <div class="pillar-body">
 <div class="articles-section">
 <div class="articles-head">
 <span class="kicker">The records</span>
 <h2 class="display-2">Articles in this pillar</h2>
 </div>
 {sorted.length === 0 ? (
 <p class="empty marginalia">Articles coming soon.</p>
 ) : (
 <ol class="index-list article-list">
 {sorted.map((post, i) => {
 const readTime = Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 220));
 const tier = post.data.tier ?? 'Intermediate';
 const color = tierColors[tier] ?? '#837B69';
 return (
 <li>
 <a href={`/articles/${post.slug}`} class="index-row article-row">
 <span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
 <div class="ix-title-wrap">
 <span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}55`}>{tier}</span>
 <span class="ix-title">{post.data.title}</span>
 <p class="article-desc">{post.data.description}</p>
 </div>
 <span class="ix-meta">{readTime} min<span class="ix-arrow">→</span></span>
 </a>
 </li>
 );
 })}
 </ol>
 )}
 </div>

 <aside class="pillar-sidebar">
 <div class="sidebar-block">
 <div class="sidebar-label">What this pillar covers</div>
 <ul class="covers-list">
 <li>MES and electronic batch records (EBR)</li>
 <li>SCADA, DCS, and PLC data integrity</li>
 <li>Process historians and data retrieval</li>
 <li>LIMS, ELN, and chromatography data systems</li>
 <li>21 CFR Part 11 on the shop floor</li>
 <li>Review-by-exception in manufacturing</li>
 <li>Time synchronization across systems</li>
 <li>Audit trails on PLCs and historians</li>
 <li>Data transfer validation between shop-floor systems</li>
 </ul>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Related pillars</div>
 <a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
 <a href="/pillars/csv-csa" class="related-pill">CSV &amp; CSA →</a>
 <a href="/pillars/equipment-qualification" class="related-pill">Equipment Qualification →</a>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Learning tracks</div>
 <a href="/tracks/implementation" class="track-link">Implementation Track</a>
 <a href="/tracks/advanced" class="track-link">Advanced Track</a>
 </div>
 <img class="sidebar-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 </aside>
 </div>
 </div>
 </section>
</Layout>

<style>
 /* ── Full-bleed duotone header band ── */
 .pillar-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; border-bottom: 3px solid var(--vermilion); }
 .pillar-hero > img { position: absolute; inset: 0; height: 100%; }
 .pillar-hero-grad { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(22,19,13,0.20) 0%, rgba(22,19,13,0.42) 45%, rgba(22,19,13,0.88) 100%); }
 .pillar-hero-inner { position: relative; z-index: 3; padding-top: 4.5rem; padding-bottom: 3rem; }

 .back-link { font-family: var(--mono); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--on-ink-dim); display: inline-block; margin-bottom: 2rem; transition: color 0.15s; }
 .back-link:hover { color: var(--on-ink); }

 .pillar-hero-top { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.1rem; }
 .pillar-emblem { color: var(--on-ink); width: 42px; height: 42px; }
 .pillar-hero .kicker { color: #F2C9B8; }

 .pillar-title { font-family: var(--display); font-weight: 500; color: var(--on-ink); font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.0; letter-spacing: -0.025em; max-width: 18ch; margin-bottom: 1.25rem; }
 .pillar-intro { color: var(--on-ink-dim); max-width: 44rem; margin-bottom: 1.85rem; }

 /* Reg-basis as mono chips over the image */
 .reg-basis { display: flex; flex-wrap: wrap; align-items: center; gap: 0.7rem 0.85rem; }
 .reg-label { font-family: var(--mono); font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--on-ink-dim); flex-shrink: 0; }
 .reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
 .reg-links a {
 display: inline-flex; align-items: center;
 font-family: var(--mono); font-size: 0.68rem; font-weight: 700; letter-spacing: 0.03em;
 color: var(--on-ink);
 padding: 0.3rem 0.6rem;
 background: rgba(236,230,216,0.08);
 border: 1px solid var(--line-ink);
 border-radius: var(--radius);
 transition: border-color 0.15s, background 0.15s, color 0.15s;
 }
 .reg-links a:hover { border-color: var(--vermilion); background: rgba(203,75,42,0.18); color: var(--on-ink); }

 /* ── Body grid: editorial index + slim sidebar ── */
 .pillar-body { display: grid; grid-template-columns: 1fr 290px; gap: 4rem; align-items: start; }

 /* ── Articles editorial index ── */
 .articles-head { margin-bottom: 1.75rem; }
 .articles-head .kicker { margin-bottom: 0.5rem; }
 .empty { margin-top: 1rem; }

 .article-list { border-top: 2px solid var(--ink); }
 .article-row { align-items: start; }
 .article-row .ix-num { font-family: var(--display); font-size: 1.6rem; font-weight: 500; color: var(--vermilion); line-height: 1; padding-top: 0.1rem; }
 .ix-title-wrap { display: flex; flex-direction: column; gap: 0.5rem; }
 .ix-title-wrap .tier-badge { align-self: flex-start; }
 .article-row .ix-title { font-family: var(--display); font-size: 1.3rem; font-weight: 500; color: var(--ink); line-height: 1.18; transition: color 0.15s; }
 .article-row:hover .ix-title { color: var(--vermilion-2); }
 .article-desc { font-size: 0.92rem; color: var(--graphite); line-height: 1.55; margin: 0; max-width: 46rem; }
 .article-row .ix-meta { display: inline-flex; align-items: baseline; gap: 0.6rem; }
 .ix-arrow { color: var(--line); transition: color 0.15s, transform 0.15s; }
 .article-row:hover .ix-arrow { color: var(--vermilion-2); }

 /* ── Sidebar: mono / editorial blocks (no heavy cards) ── */
 .pillar-sidebar { display: flex; flex-direction: column; gap: 2.25rem; position: relative; }
 .sidebar-block { border-top: 1px solid var(--ink); padding-top: 1rem; }
 .sidebar-label { font-family: var(--mono); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.13em; color: var(--vermilion); margin-bottom: 0.95rem; }

 .covers-list { list-style: none; padding: 0; margin: 0; }
 .covers-list li { position: relative; padding-left: 1.1rem; font-size: 0.86rem; color: var(--graphite); line-height: 1.5; margin-bottom: 0.55rem; }
 .covers-list li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 5px; height: 5px; background: var(--vermilion); }

 .related-pill, .track-link {
 display: block; font-family: var(--sans); font-size: 0.88rem; color: var(--graphite);
 padding: 0.5rem 0; border-bottom: 1px solid var(--line);
 transition: color 0.15s, padding-left 0.15s;
 }
 .related-pill:last-child, .track-link:last-child { border-bottom: none; }
 .related-pill:hover, .track-link:hover { color: var(--vermilion-2); padding-left: 0.3rem; }

 .sidebar-seal { width: 88px; color: var(--line); align-self: flex-end; margin-top: 0.5rem; opacity: 0.7; }

 @media (max-width: 900px) {
 .pillar-hero { min-height: 48vh; }
 .pillar-hero-inner { padding-top: 3rem; }
 .pillar-body { grid-template-columns: 1fr; gap: 3rem; }
 .pillar-sidebar { order: 2; }
 .sidebar-seal { display: none; }
 }
 @media (max-width: 560px) {
 .article-row { grid-template-columns: 2.4rem 1fr; }
 .article-row .ix-meta { grid-column: 2; padding-top: 0.4rem; }
 }
</style>
