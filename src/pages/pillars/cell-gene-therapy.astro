---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'cell-gene-therapy');
const sorted = all.sort((a, b) => {
	const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
	return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});
const tierColors: Record<string, string> = { Beginner: '#3C6B4A', Intermediate: '#B26B1E', Advanced: '#7A2E23' };
---
<Layout title="Cell & Gene Therapy Data Integrity" description="Why CGT data integrity is structurally harder, novel assays, autologous chain of custody, BLA-level scrutiny, real-time release, and program design for CGT manufacturers." wide={true}>
	<!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
	<header class="pillar-hero duotone">
		<img src="/images/microscopy-blue.jpg" alt="" loading="eager" />
		<div class="pillar-hero-grad"></div>
		<div class="wrap pillar-hero-inner">
			<div class="pillar-hero-top">
				<a href="/pillars" class="back-link">← All Pillars</a>
				<span class="emblem pillar-emblem" style="--src:url('/brand/emblems/pillar-cell-gene-therapy.svg')"></span>
			</div>
			<div class="pillar-kick">
				<span class="kicker">Pillar 06</span>
				<span class="pillar-kick-line"></span>
				<span class="marginalia">Cell · Gene · Autologous</span>
			</div>
			<h1 class="pillar-title">Cell &amp; Gene Therapy</h1>
			<p class="pillar-intro">
				ALCOA+ applies equally to a small molecule tablet and an autologous CAR-T product. But the complexity of applying it is not equal. CGT manufacturers deal with novel and variable assays, patient-specific chain-of-custody data, manufacturing platforms with no established validation playbooks, and the expectation of BLA-quality data from early in clinical development. This pillar covers what makes CGT data integrity structurally different and what mature programs actually look like.
			</p>
			<div class="reg-basis">
				<span class="reg-label">Regulatory basis</span>
				<div class="reg-links">
					<a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-L/part-1271" target="_blank" rel="noopener" class="reg-chip">21 CFR Part 1271 (HCT/Ps)</a>
					<a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-F/part-600" target="_blank" rel="noopener" class="reg-chip">21 CFR Parts 600-610 (Biologics)</a>
					<a href="https://www.fda.gov/vaccines-blood-biologics/cellular-gene-therapy-products" target="_blank" rel="noopener" class="reg-chip">FDA CGT Guidance Documents</a>
					<a href="https://www.fda.gov/regulatory-information/search-fda-guidance-documents/data-integrity-and-compliance-drug-cgmp-guidance-industry" target="_blank" rel="noopener" class="reg-chip">FDA DI Guidance (Dec 2018)</a>
				</div>
			</div>
		</div>
	</header>

	<!-- ═══════════ BODY: editorial index + editorial sidebar ═══════════ -->
	<section class="section pillar-body-section">
		<div class="wrap pillar-body">
			<div class="articles-section">
				<div class="articles-head">
					<span class="kicker">In this pillar</span>
					<h2 class="display-2">Articles in this pillar</h2>
				</div>
				{sorted.length === 0 ? (
					<p class="empty">Articles coming soon.</p>
				) : (
					<ol class="index-list article-index">
						{sorted.map((post, i) => {
							const readTime = Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 220));
							const tier = post.data.tier ?? 'Intermediate';
							const color = tierColors[tier] ?? '#837B69';
							return (
								<li>
									<a href={`/articles/${post.slug}`} class="article-row index-row">
										<span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
										<div class="ix-body">
											<div class="article-row-top">
												<span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}40`}>{tier}</span>
												<h3 class="ix-title">{post.data.title}</h3>
											</div>
											<p class="ix-desc">{post.data.description}</p>
										</div>
										<span class="ix-meta">{readTime} min<span class="ix-arrow">→</span></span>
									</a>
								</li>
							);
						})}
					</ol>
				)}
			</div>

			<aside class="pillar-sidebar">
				<div class="sidebar-block">
					<div class="sidebar-label">What this pillar covers</div>
					<ul class="covers-list">
						<li>Why CGT DI is harder: novel assays, small batches, autologous logistics</li>
						<li>Potency assay data challenges and variability</li>
						<li>Vector/viral manufacturing data management</li>
						<li>Single-use systems and manual operations as DI risk</li>
						<li>Chain of identity and chain of custody: patient material</li>
						<li>BLA data-package integrity and retrospective audits</li>
						<li>Real-time release in compressed timelines</li>
						<li>Novel technology qualification pathways</li>
						<li>FDA CGT inspection expectations and enforcement trends</li>
					</ul>
				</div>
				<div class="sidebar-block">
					<div class="sidebar-label">Related pillars</div>
					<a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
					<a href="/pillars/audits-inspection" class="related-pill">Audits &amp; Inspection →</a>
					<a href="/pillars/manufacturing-automation" class="related-pill">Manufacturing Systems →</a>
				</div>
				<div class="sidebar-block sidebar-block-seal">
					<img class="sidebar-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
					<div class="sidebar-label">Learning tracks</div>
					<a href="/tracks/implementation" class="track-link">Implementation Track</a>
					<a href="/tracks/advanced" class="track-link">Advanced Track</a>
				</div>
			</aside>
		</div>
	</section>
</Layout>

<style>
	/* ════════════ HEADER BAND ════════════ */
	.pillar-hero {
		position: relative;
		min-height: 52vh;
		display: flex;
		align-items: flex-end;
		border-bottom: 3px solid var(--vermilion);
	}
	.pillar-hero > img { position: absolute; inset: 0; }
	.pillar-hero-grad {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, rgba(22,19,13,0.20) 0%, rgba(22,19,13,0.40) 45%, rgba(22,19,13,0.88) 100%);
		z-index: 2;
	}
	.pillar-hero-inner {
		position: relative;
		z-index: 3;
		padding-top: 4.5rem;
		padding-bottom: 3rem;
	}

	.pillar-hero-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 2rem;
	}
	.back-link {
		font-family: var(--mono);
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--on-ink-dim);
		transition: color 0.15s;
	}
	.back-link:hover { color: var(--on-ink); }
	.pillar-emblem {
		color: var(--on-ink);
		width: 48px;
		height: 48px;
		opacity: 0.92;
	}

	.pillar-kick { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.1rem; }
	.pillar-kick .kicker { color: #F2C9B8; }
	.pillar-kick-line { width: 64px; height: 1px; background: var(--line-ink); }
	.pillar-kick .marginalia { color: var(--on-ink-dim); }

	.pillar-title {
		font-family: var(--display);
		font-weight: 500;
		color: var(--on-ink);
		font-size: clamp(2.4rem, 5.6vw, 4.4rem);
		line-height: 1.0;
		letter-spacing: -0.025em;
		margin-bottom: 1.35rem;
		max-width: 16ch;
	}
	.pillar-intro {
		font-family: var(--sans);
		font-size: 1.12rem;
		line-height: 1.62;
		color: var(--on-ink-dim);
		max-width: 56ch;
		margin-bottom: 2rem;
	}

	.reg-basis {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.65rem 1.25rem;
		padding-top: 1.5rem;
		border-top: 1px solid var(--line-ink);
	}
	.reg-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 700;
		color: #F2C9B8;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		flex-shrink: 0;
	}
	.reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.reg-chip {
		display: inline-flex;
		align-items: center;
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.03em;
		padding: 0.28rem 0.6rem;
		color: var(--on-ink-dim);
		border: 1px solid var(--line-ink);
		border-radius: var(--radius);
		background: rgba(236,230,216,0.04);
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.reg-chip:hover {
		color: var(--on-ink);
		border-color: var(--vermilion);
		background: rgba(203,75,42,0.18);
	}

	/* ════════════ BODY GRID ════════════ */
	.pillar-body {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 4rem;
		align-items: start;
	}

	.articles-head { margin-bottom: 1.75rem; }
	.articles-head .kicker { margin-bottom: 0.6rem; }
	.empty { color: var(--muted); font-size: 0.95rem; }

	/* ── Article editorial index ── */
	.article-index { border-top: 2px solid var(--ink); list-style: none; }
	.article-row {
		display: grid;
		grid-template-columns: 3.25rem 1fr auto;
		gap: 1.5rem;
		align-items: start;
		text-decoration: none;
		color: inherit;
	}
	.article-row .ix-num {
		font-family: var(--mono);
		font-size: 0.82rem;
		color: var(--vermilion);
		padding-top: 0.35rem;
	}
	.ix-body { min-width: 0; }
	.article-row-top {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		flex-wrap: wrap;
		margin-bottom: 0.45rem;
	}
	.article-row .ix-title {
		font-family: var(--display);
		font-weight: 500;
		font-size: 1.3rem;
		color: var(--ink);
		line-height: 1.18;
		transition: color 0.15s;
	}
	.article-row:hover .ix-title { color: var(--vermilion-2); }
	.ix-desc {
		font-size: 0.92rem;
		color: var(--graphite);
		line-height: 1.6;
		margin: 0;
		max-width: 52ch;
	}
	.article-row .ix-meta {
		display: inline-flex;
		align-items: baseline;
		gap: 0.6rem;
		font-family: var(--mono);
		font-size: 0.74rem;
		color: var(--muted);
		white-space: nowrap;
		padding-top: 0.35rem;
	}
	.ix-arrow { transition: transform 0.15s, color 0.15s; }
	.article-row:hover .ix-arrow { color: var(--vermilion-2); transform: translateX(3px); }

	/* ════════════ SIDEBAR (editorial blocks, not heavy cards) ════════════ */
	.pillar-sidebar { display: flex; flex-direction: column; gap: 2.5rem; }
	.sidebar-block {
		border-top: 1px solid var(--ink);
		padding-top: 1.1rem;
		position: relative;
	}
	.sidebar-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--vermilion);
		margin-bottom: 1rem;
	}
	.covers-list {
		padding-left: 1.05rem;
		list-style: none;
		color: var(--graphite);
		font-size: 0.86rem;
		line-height: 1.55;
		margin: 0;
	}
	.covers-list li {
		position: relative;
		margin-bottom: 0.7rem;
		padding-left: 0.1rem;
	}
	.covers-list li::before {
		content: '—';
		position: absolute;
		left: -1.05rem;
		color: var(--vermilion);
		font-family: var(--mono);
	}

	.related-pill, .track-link {
		display: block;
		font-family: var(--sans);
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--graphite);
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--line);
		transition: color 0.15s, padding-left 0.15s;
	}
	.related-pill:last-child, .track-link:last-child { border-bottom: none; }
	.related-pill:hover, .track-link:hover { color: var(--vermilion-2); padding-left: 0.3rem; }

	.sidebar-block-seal { overflow: hidden; }
	.sidebar-seal {
		position: absolute;
		right: -28px;
		top: 0.6rem;
		width: 92px;
		color: var(--vermilion);
		opacity: 0.12;
		pointer-events: none;
	}

	/* ════════════ RESPONSIVE ════════════ */
	@media (max-width: 900px) {
		.pillar-body { grid-template-columns: 1fr; gap: 3rem; }
		.pillar-sidebar { order: 1; }
		.pillar-hero { min-height: 46vh; }
		.pillar-hero-inner { padding-top: 3rem; }
	}
	@media (max-width: 560px) {
		.article-row { grid-template-columns: 2.5rem 1fr; }
		.article-row .ix-meta { grid-column: 2; padding-top: 0.5rem; }
		.reg-basis { gap: 0.75rem; }
	}
</style>
