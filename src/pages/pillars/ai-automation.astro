---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'ai-automation');
const sorted = all.sort((a, b) => {
 const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
 return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});
const tierColors: Record<string, string> = { Beginner: '#3C6B4A', Intermediate: '#B26B1E', Advanced: '#7A2E23' };
const accent = '#CB4B2A';
---
<Layout title="AI & Automation in Compliance" description="Building Part 11-compliant AI tooling for GxP, validating AI-enabled systems, audit trail triage, and where AI genuinely helps in quality and compliance workflows." wide={true}>
 <!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
 <header class="pillar-band duotone">
 <img src="/images/instrument-machine.jpg" alt="" loading="eager" />
 <div class="pillar-band-grad"></div>
 <div class="wrap pillar-band-inner">
 <a href="/pillars" class="back-link">← All Pillars</a>
 <div class="band-lockup">
 <span class="emblem band-emblem" style="--src:url('/brand/emblems/pillar-ai-automation.svg')"></span>
 <span class="kicker band-kicker">Cross-Cutting</span>
 </div>
 <h1 class="band-title">AI &amp; Automation in Compliance</h1>
 <p class="band-intro">
 AI is genuinely useful in compliance, for specific, bounded tasks where the risk of error is caught downstream by a human reviewer. It is not useful as an autonomous decision-maker in regulated workflows. Building AI tools for GxP requires understanding this distinction from the start, then designing the validation infrastructure around it before writing a line of code.
 </p>
 <div class="reg-basis">
 <span class="reg-label">Regulatory basis</span>
 <div class="reg-links">
 <a href="https://www.fda.gov/regulatory-information/search-fda-guidance-documents/computer-software-assurance-production-and-quality-system-software" target="_blank" rel="noopener">FDA CSA Draft Guidance (Sep 2022)</a>
 <a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11" target="_blank" rel="noopener">21 CFR Part 11</a>
 <a href="https://www.fda.gov/medical-devices/software-medical-device-samd/artificial-intelligence-and-machine-learning-software-medical-device" target="_blank" rel="noopener">FDA AI/ML Framework</a>
 </div>
 </div>
 </div>
 </header>

 <!-- ═══════════ BODY: editorial index + editorial sidebar ═══════════ -->
 <section class="section pillar-shell">
 <div class="wrap pillar-body">
 <div class="articles-section">
 <div class="articles-head">
 <span class="kicker">The record</span>
 <h2 class="display-2 articles-title">Articles in this pillar</h2>
 </div>
 {sorted.length === 0 ? (
 <p class="empty marginalia">Articles coming soon.</p>
 ) : (
 <ul class="index-list article-index">
 {sorted.map((post, i) => {
 const readTime = Math.max(1, Math.ceil((post.body?.split(/\s+/).length ?? 0) / 220));
 const tier = post.data.tier ?? 'Intermediate';
 const color = tierColors[tier] ?? '#837B69';
 return (
 <li>
 <a href={`/articles/${post.slug}`} class="article-row index-row">
 <span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
 <div class="ix-title-wrap">
 <span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}40`}>{tier}</span>
 <h3 class="ix-title">{post.data.title}</h3>
 <p class="ix-desc">{post.data.description}</p>
 </div>
 <span class="ix-meta">{readTime} min<span class="ix-arrow"> →</span></span>
 </a>
 </li>
 );
 })}
 </ul>
 )}
 </div>

 <aside class="pillar-sidebar">
 <div class="sidebar-block">
 <div class="sidebar-label">What this pillar covers</div>
 <ul>
 <li>What AI tools actually work in GxP (and what doesn't)</li>
 <li>Building Part 11-compliant AI tooling</li>
 <li>Validation of AI-enabled GxP systems</li>
 <li>Audit trail anomaly detection with AI</li>
 <li>Document gap analysis and deviation triage</li>
 <li>Logging and human review requirements for AI outputs</li>
 <li>Validating AI/ML and dynamic systems</li>
 <li>CSA's approach to higher-complexity software</li>
 </ul>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Related pillars</div>
 <a href="/pillars/csv-csa" class="related-pill">CSV &amp; CSA →</a>
 <a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
 <a href="/pillars/manufacturing-automation" class="related-pill">Manufacturing Systems →</a>
 </div>
 <div class="sidebar-block">
 <div class="sidebar-label">Learning tracks</div>
 <a href="/tracks/implementation" class="track-link">Implementation Track</a>
 <a href="/tracks/advanced" class="track-link">Advanced Track</a>
 </div>
 <div class="sidebar-seal">
 <img class="seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 <span class="marginalia">Verified for human-in-the-loop use.</span>
 </div>
 </aside>
 </div>
 </section>
</Layout>

<style define:vars={{ accent }}>
 /* ── HEADER BAND (full-bleed duotone) ── */
 .pillar-band {
 position: relative;
 min-height: 56vh;
 display: flex;
 align-items: flex-end;
 border-bottom: 3px solid var(--vermilion);
 }
 .pillar-band > img { position: absolute; inset: 0; }
 .pillar-band-grad {
 position: absolute; inset: 0; z-index: 2;
 background: linear-gradient(180deg, rgba(22,19,13,0.2) 0%, rgba(22,19,13,0.42) 45%, rgba(22,19,13,0.88) 100%);
 }
 .pillar-band-inner { position: relative; z-index: 3; padding-top: 4.5rem; padding-bottom: 3rem; }

 .back-link {
 font-family: var(--mono);
 font-size: 0.74rem;
 letter-spacing: 0.06em;
 text-transform: uppercase;
 color: var(--on-ink-dim);
 display: inline-block;
 margin-bottom: 2rem;
 transition: color 0.15s;
 }
 .back-link:hover { color: var(--on-ink); }

 .band-lockup { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1.1rem; }
 .band-emblem { color: var(--on-ink); width: 40px; height: 40px; }
 .band-kicker { color: var(--vermilion); }

 .band-title {
 font-family: var(--display);
 font-weight: 500;
 color: var(--on-ink);
 font-size: clamp(2.3rem, 5vw, 4rem);
 line-height: 1.0;
 letter-spacing: -0.025em;
 max-width: 20ch;
 margin-bottom: 1.25rem;
 }

 .band-intro {
 font-family: var(--display);
 font-style: italic;
 font-weight: 400;
 color: var(--on-ink-dim);
 font-size: clamp(1.1rem, 1.9vw, 1.45rem);
 line-height: 1.45;
 max-width: 46rem;
 margin-bottom: 1.85rem;
 }

 .reg-basis {
 display: flex;
 flex-wrap: wrap;
 align-items: center;
 gap: 0.7rem 0.85rem;
 }
 .reg-label {
 font-family: var(--mono);
 font-size: 0.68rem;
 font-weight: 700;
 color: var(--on-ink-dim);
 text-transform: uppercase;
 letter-spacing: 0.12em;
 flex-shrink: 0;
 }
 .reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
 .reg-links a {
 display: inline-flex;
 align-items: center;
 font-family: var(--mono);
 font-size: 0.7rem;
 font-weight: 400;
 color: var(--on-ink);
 letter-spacing: 0.02em;
 padding: 0.28rem 0.6rem;
 background: rgba(236, 230, 216, 0.08);
 border: 1px solid var(--line-ink);
 border-radius: var(--radius);
 transition: border-color 0.15s, background 0.15s, color 0.15s;
 }
 .reg-links a:hover { border-color: var(--vermilion); background: rgba(203, 75, 42, 0.18); color: var(--on-ink); }

 /* ── BODY SHELL ── */
 .pillar-shell { padding-top: 3.5rem; }
 .pillar-body {
 display: grid;
 grid-template-columns: 1fr 290px;
 gap: 4rem;
 align-items: start;
 }

 .articles-head { margin-bottom: 1.5rem; }
 .articles-head .kicker { display: block; margin-bottom: 0.6rem; }
 .articles-title { color: var(--ink); }

 .empty { color: var(--muted); }

 /* ── ARTICLE INDEX (editorial list, not cards) ── */
 .article-index { border-top: 2px solid var(--ink); margin-top: 1.5rem; }
 .article-row {
 grid-template-columns: 3.25rem 1fr auto;
 align-items: start;
 padding: 1.6rem 0;
 text-decoration: none;
 color: inherit;
 }
 .ix-num { padding-top: 0.35rem; }
 .ix-title-wrap { display: flex; flex-direction: column; align-items: flex-start; gap: 0.5rem; }
 .ix-title-wrap .tier-badge { margin-bottom: 0.1rem; }
 .article-row .ix-title { font-size: 1.4rem; }
 .ix-desc {
 font-family: var(--sans);
 font-size: 0.95rem;
 color: var(--graphite);
 line-height: 1.6;
 margin: 0;
 max-width: 48rem;
 }
 .ix-meta { display: flex; align-items: baseline; gap: 0.1rem; }
 .ix-arrow { transition: transform 0.15s, color 0.15s; }
 .article-row:hover .ix-arrow { color: var(--vermilion-2); transform: translateX(2px); display: inline-block; }
 .article-row:hover .ix-meta { color: var(--graphite); }

 /* ── SIDEBAR (editorial/mono blocks, not heavy cards) ── */
 .pillar-sidebar {
 display: flex;
 flex-direction: column;
 gap: 2rem;
 border-left: 1px solid var(--line);
 padding-left: 2rem;
 }
 .sidebar-block { }
 .sidebar-label {
 font-family: var(--mono);
 font-size: 0.7rem;
 font-weight: 700;
 color: var(--vermilion);
 text-transform: uppercase;
 letter-spacing: 0.14em;
 margin-bottom: 0.9rem;
 padding-bottom: 0.55rem;
 border-bottom: 1px solid var(--line);
 }
 .sidebar-block ul {
 padding-left: 1.05rem;
 list-style: none;
 color: var(--graphite);
 font-size: 0.86rem;
 line-height: 1.55;
 margin: 0;
 }
 .sidebar-block li { margin-bottom: 0.5rem; position: relative; }
 .sidebar-block li::before {
 content: '—';
 position: absolute;
 left: -1.05rem;
 color: var(--vermilion);
 }

 .related-pill, .track-link {
 display: block;
 font-family: var(--sans);
 font-size: 0.88rem;
 font-weight: 500;
 color: var(--graphite);
 padding: 0.55rem 0;
 border-bottom: 1px solid var(--line);
 transition: color 0.15s, padding-left 0.15s;
 }
 .related-pill:last-child, .track-link:last-child { border-bottom: none; }
 .related-pill:hover, .track-link:hover { color: var(--vermilion-2); padding-left: 0.3rem; }

 .sidebar-seal { display: flex; flex-direction: column; align-items: flex-start; gap: 0.7rem; padding-top: 0.5rem; }
 .sidebar-seal .seal { width: 64px; color: var(--vermilion); }
 .sidebar-seal .marginalia { max-width: 16rem; }

 @media (max-width: 980px) {
 .pillar-body { grid-template-columns: 1fr; gap: 2.75rem; }
 .pillar-sidebar { border-left: none; padding-left: 0; border-top: 1px solid var(--line); padding-top: 2rem; }
 }
 @media (max-width: 560px) {
 .pillar-band { min-height: 50vh; }
 .pillar-band-inner { padding-top: 3rem; }
 .article-row { grid-template-columns: 2.25rem 1fr; }
 .ix-meta { grid-column: 2; padding-top: 0.4rem; }
 }
</style>
