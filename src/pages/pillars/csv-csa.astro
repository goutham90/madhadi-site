---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'csv-csa');
const sorted = all.sort((a, b) => {
	const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
	return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});

const tierColors: Record<string, string> = {
	Beginner: '#2F6E4F',
	Intermediate: '#1C4E80',
	Advanced: '#7A3B57',
};

const accent = '#2F6E4F';
---
<Layout title="CSV & Computer Software Assurance" description="Complete coverage of computer system validation and FDA's CSA framework, GAMP 5, lifecycle, Part 11, Annex 11, cloud/SaaS, and AI system validation." wide={true}>
	<div class="pillar-header">
		<a href="/pillars" class="back-link">← All Pillars</a>
		<div class="pillar-label">Pillar 02</div>
		<h1>CSV & Computer Software Assurance</h1>
		<p class="pillar-intro lead">
			Computerized system validation has been the dominant framework for GxP software compliance since the 1990s. FDA's 2022 Computer Software Assurance (CSA) draft guidance marks a genuine shift, from documentation-heavy compliance to risk-based critical thinking. Understanding both frameworks, and how they relate, is essential for anyone building or maintaining GxP systems.
		</p>
		<div class="reg-basis">
			<div class="reg-label">Regulatory basis</div>
			<div class="reg-links">
				<a href="https://www.fda.gov/regulatory-information/search-fda-guidance-documents/computer-software-assurance-production-and-quality-system-software" target="_blank" rel="noopener">FDA CSA Draft Guidance (Sep 2022)</a>
				<a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11" target="_blank" rel="noopener">21 CFR Part 11</a>
				<a href="https://www.gmp-compliance.org/gmp-news/eu-gmp-annex-11-computerised-systems" target="_blank" rel="noopener">EU GMP Annex 11 (2011)</a>
				<a href="https://ispe.org/publications/guidance-documents/gamp-5-guide-2nd-edition" target="_blank" rel="noopener">GAMP 5 (2nd ed., 2022)</a>
			</div>
		</div>
	</div>

	<div class="pillar-body">
		<div class="articles-section">
			<h2>Articles in this pillar</h2>
			{sorted.length === 0 ? (
				<p class="empty">Articles coming soon.</p>
			) : (
				<div class="article-list">
					{sorted.map(post => {
						const wordCount = post.body?.split(/\s+/).length ?? 0;
						const readTime = Math.max(1, Math.ceil(wordCount / 220));
						const tier = post.data.tier ?? 'Intermediate';
						const color = tierColors[tier] ?? '#756B5B';
						return (
							<a href={`/articles/${post.slug}`} class="article-row">
								<div class="article-row-main">
									<div class="article-row-top">
										<span class="tier-badge" style={`background:${color}1A;color:${color};border-color:${color}40`}>{tier}</span>
										<h3>{post.data.title}</h3>
									</div>
									<p>{post.data.description}</p>
								</div>
								<div class="article-row-meta">
									<span>{readTime} min</span>
									<span class="arrow">→</span>
								</div>
							</a>
						);
					})}
				</div>
			)}
		</div>

		<aside class="pillar-sidebar">
			<div class="sidebar-block">
				<div class="sidebar-label">What this pillar covers</div>
				<ul>
					<li>GAMP 5 (2nd ed.): software categories 1, 3, 4, 5</li>
					<li>V-model and validation lifecycle</li>
					<li>URS, FRS, design specs, and requirements traceability</li>
					<li>IQ/OQ/PQ and their relationship to UAT</li>
					<li>FDA CSA vs. traditional CSV, the practical differences</li>
					<li>21 CFR Part 11 and EU Annex 11 requirements</li>
					<li>Vendor assessment and leveraging supplier documentation</li>
					<li>Periodic review, change control, configuration management</li>
					<li>Cloud, SaaS, and shared-responsibility qualification</li>
					<li>Data migration validation and decommissioning</li>
					<li>AI/ML system validation (emerging)</li>
				</ul>
			</div>
			<div class="sidebar-block">
				<div class="sidebar-label">Related pillars</div>
				<a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
				<a href="/pillars/equipment-qualification" class="related-pill">Equipment Qualification →</a>
				<a href="/pillars/manufacturing-automation" class="related-pill">Manufacturing Systems →</a>
			</div>
			<div class="sidebar-block">
				<div class="sidebar-label">Learning tracks</div>
				<a href="/tracks/foundations" class="track-link">Foundations Track</a>
				<a href="/tracks/implementation" class="track-link">Implementation Track</a>
				<a href="/tracks/advanced" class="track-link">Advanced Track</a>
			</div>
		</aside>
	</div>
</Layout>

<style define:vars={{ accent }}>
	.pillar-header {
		margin-bottom: 3.5rem;
		padding-bottom: 2.25rem;
		border-bottom: 1px solid var(--line);
	}

	.back-link {
		font-size: 0.78rem;
		color: var(--muted);
		font-family: var(--mono);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		display: inline-block;
		margin-bottom: 1.75rem;
		transition: color 0.15s;
	}
	.back-link:hover { color: var(--navy); }

	.pillar-label {
		font-family: var(--mono);
		font-size: 0.72rem;
		font-weight: 500;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.16em;
		margin-bottom: 0.9rem;
	}

	.pillar-header h1 {
		font-size: clamp(2rem, 4vw, 2.9rem);
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin-bottom: 1rem;
	}

	.pillar-intro {
		max-width: 44rem;
		margin-bottom: 2rem;
	}

	.reg-basis {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		padding: 1.1rem 1.35rem;
		background: var(--paper-2);
		border: 1px solid var(--line);
		border-radius: var(--radius);
	}
	.reg-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--muted);
		text-transform: uppercase;
		letter-spacing: 0.13em;
		flex-shrink: 0;
		margin-right: 0.35rem;
	}
	.reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.reg-links a {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--muted);
		letter-spacing: 0.02em;
		padding: 0.18rem 0.5rem;
		background: var(--surface);
		border: 1px solid var(--line-2);
		border-radius: var(--radius-sm);
		transition: border-color 0.15s, color 0.15s;
	}
	.reg-links a:hover { border-color: var(--navy); color: var(--navy); }

	.pillar-body {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 4rem;
		align-items: start;
	}

	.articles-section h2 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: clamp(1.4rem, 2.2vw, 1.7rem);
		letter-spacing: -0.01em;
		color: var(--ink);
		margin-bottom: 1.5rem;
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--line-2);
	}

	.empty { color: var(--muted); font-size: 0.95rem; }

	.article-list { display: flex; flex-direction: column; }
	.article-row {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1.25rem;
		padding: 1.5rem 0;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		transition: background 0.15s, padding 0.15s, border-color 0.15s;
		border-radius: var(--radius);
	}
	.article-row:last-child { border-bottom: none; }
	.article-row:hover {
		background: var(--surface);
		border-color: var(--surface);
		padding-left: 1rem;
		padding-right: 1rem;
		box-shadow: var(--shadow-sm);
	}

	.article-row-main { flex: 1; }
	.article-row-top { display: flex; align-items: center; gap: 0.65rem; margin-bottom: 0.5rem; }

	.tier-badge {
		font-family: var(--mono);
		font-size: 0.64rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		padding: 0.16rem 0.5rem;
		border-radius: var(--radius-sm);
		border: 1px solid;
		flex-shrink: 0;
	}

	.article-row-main h3 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.2rem;
		color: var(--ink);
		line-height: 1.3;
		letter-spacing: -0.01em;
		transition: color 0.15s;
	}
	.article-row:hover .article-row-main h3 { color: var(--link); }
	.article-row-main p {
		font-family: var(--sans);
		font-size: 0.9rem;
		color: var(--muted);
		line-height: 1.6;
		margin: 0;
	}

	.article-row-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
		flex-shrink: 0;
	}
	.article-row-meta span { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); }
	.arrow { transition: color 0.15s; }
	.article-row:hover .arrow { color: var(--link); }

	.pillar-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }
	.sidebar-block {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		box-shadow: var(--shadow-sm);
		padding: 1.35rem;
	}
	.sidebar-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 500;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.13em;
		margin-bottom: 0.9rem;
	}
	.sidebar-block ul {
		padding-left: 1.1rem;
		list-style: disc;
		color: var(--body);
		font-size: 0.85rem;
		line-height: 1.6;
	}
	.sidebar-block li { margin-bottom: 0.4rem; }
	.sidebar-block li::marker { color: var(--brass); }

	.related-pill, .track-link {
		display: block;
		font-family: var(--sans);
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--body);
		padding: 0.45rem 0;
		border-bottom: 1px solid var(--line);
		transition: color 0.15s;
	}
	.related-pill:last-child, .track-link:last-child { border-bottom: none; }
	.related-pill:hover, .track-link:hover { color: var(--link); }

	@media (max-width: 860px) {
		.pillar-body { grid-template-columns: 1fr; gap: 3rem; }
		.pillar-sidebar { order: -1; }
	}
</style>
