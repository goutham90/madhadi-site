---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles', ({ data }) => !data.draft && data.pillar === 'csv-csa');
const sorted = all.sort((a, b) => {
	const tierOrder = { Beginner: 0, Intermediate: 1, Advanced: 2 };
	return (tierOrder[a.data.tier ?? 'Intermediate'] ?? 1) - (tierOrder[b.data.tier ?? 'Intermediate'] ?? 1);
});

const tierColors: Record<string, string> = {
	Beginner: '#3C6B4A',
	Intermediate: '#B26B1E',
	Advanced: '#7A2E23',
};
---
<Layout title="CSV & Computer Software Assurance" description="Complete coverage of computer system validation and FDA's CSA framework, GAMP 5, lifecycle, Part 11, Annex 11, cloud/SaaS, and AI system validation." wide={true}>
	<!-- ═══════════ HEADER BAND (full-bleed duotone) ═══════════ -->
	<header class="pillar-band duotone">
		<img src="/images/records-server.jpg" alt="" loading="eager" />
		<div class="pillar-band-grad"></div>
		<div class="wrap pillar-band-inner">
			<a href="/pillars" class="back-link">← All Pillars</a>
			<div class="band-lockup">
				<span class="emblem band-emblem" style="--src:url('/brand/emblems/pillar-csv-csa.svg')"></span>
				<span class="kicker band-kicker">Pillar 02</span>
			</div>
			<h1 class="band-title">CSV &amp; Computer Software Assurance</h1>
			<p class="pillar-intro band-intro">
				Computerized system validation has been the dominant framework for GxP software compliance since the 1990s. FDA's 2022 Computer Software Assurance (CSA) draft guidance marks a genuine shift, from documentation-heavy compliance to risk-based critical thinking. Understanding both frameworks, and how they relate, is essential for anyone building or maintaining GxP systems.
			</p>
			<div class="reg-basis">
				<div class="reg-label">Regulatory basis</div>
				<div class="reg-links">
					<a href="https://www.fda.gov/regulatory-information/search-fda-guidance-documents/computer-software-assurance-production-and-quality-system-software" target="_blank" rel="noopener">FDA CSA Draft Guidance (Sep 2022)</a>
					<a href="https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11" target="_blank" rel="noopener">21 CFR Part 11</a>
					<a href="https://www.gmp-compliance.org/gmp-news/eu-gmp-annex-11-computerised-systems" target="_blank" rel="noopener">EU GMP Annex 11 (2011)</a>
					<a href="https://ispe.org/publications/guidance-documents/gamp-5-guide-2nd-edition" target="_blank" rel="noopener">GAMP 5 (2nd ed., 2022)</a>
				</div>
			</div>
		</div>
	</header>

	<!-- ═══════════ BODY: editorial index + sidebar ═══════════ -->
	<section class="section pillar-section">
		<div class="wrap pillar-body">
			<div class="articles-section">
				<div class="articles-head">
					<span class="kicker">The record</span>
					<h2 class="display-2">Articles in this pillar</h2>
				</div>
				{sorted.length === 0 ? (
					<p class="empty marginalia">Articles coming soon.</p>
				) : (
					<ol class="index-list article-list">
						{sorted.map((post, i) => {
							const wordCount = post.body?.split(/\s+/).length ?? 0;
							const readTime = Math.max(1, Math.ceil(wordCount / 220));
							const tier = post.data.tier ?? 'Intermediate';
							const color = tierColors[tier] ?? '#837B69';
							return (
								<li>
									<a href={`/articles/${post.slug}`} class="index-row article-row">
										<span class="ix-num">{String(i + 1).padStart(2, '0')}</span>
										<div class="ix-title article-row-main">
											<div class="article-row-top">
												<span class="tier-badge" style={`background:${color}; color:#F7F3EA; border-color:${color}`}>{tier}</span>
												<h3>{post.data.title}</h3>
											</div>
											<p>{post.data.description}</p>
										</div>
										<span class="ix-meta article-row-meta">{readTime} min<span class="arrow"> →</span></span>
									</a>
								</li>
							);
						})}
					</ol>
				)}
			</div>

			<aside class="pillar-sidebar">
				<div class="sidebar-block">
					<div class="sidebar-label">What this pillar covers</div>
					<ul>
						<li>GAMP 5 (2nd ed.): software categories 1, 3, 4, 5</li>
						<li>V-model and validation lifecycle</li>
						<li>URS, FRS, design specs, and requirements traceability</li>
						<li>IQ/OQ/PQ and their relationship to UAT</li>
						<li>FDA CSA vs. traditional CSV, the practical differences</li>
						<li>21 CFR Part 11 and EU Annex 11 requirements</li>
						<li>Vendor assessment and leveraging supplier documentation</li>
						<li>Periodic review, change control, configuration management</li>
						<li>Cloud, SaaS, and shared-responsibility qualification</li>
						<li>Data migration validation and decommissioning</li>
						<li>AI/ML system validation (emerging)</li>
					</ul>
				</div>
				<div class="sidebar-block sidebar-related">
					<div class="sidebar-label">Related pillars</div>
					<a href="/pillars/data-integrity" class="related-pill">Data Integrity →</a>
					<a href="/pillars/equipment-qualification" class="related-pill">Equipment Qualification →</a>
					<a href="/pillars/manufacturing-automation" class="related-pill">Manufacturing Systems →</a>
				</div>
				<div class="sidebar-block sidebar-tracks">
					<div class="sidebar-label">Learning tracks</div>
					<a href="/tracks/foundations" class="track-link">Foundations Track</a>
					<a href="/tracks/implementation" class="track-link">Implementation Track</a>
					<a href="/tracks/advanced" class="track-link">Advanced Track</a>
				</div>
				<img class="sidebar-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
			</aside>
		</div>
	</section>
</Layout>

<style>
	/* ════════════ HEADER BAND ════════════ */
	.pillar-band {
		position: relative;
		min-height: 56vh;
		display: flex;
		align-items: flex-end;
		border-bottom: 3px solid var(--vermilion);
	}
	.pillar-band > img { position: absolute; inset: 0; }
	.pillar-band-grad {
		position: absolute; inset: 0; z-index: 2;
		background: linear-gradient(180deg, rgba(22,19,13,0.20) 0%, rgba(22,19,13,0.40) 45%, rgba(22,19,13,0.88) 100%);
	}
	.pillar-band-inner {
		position: relative; z-index: 3;
		padding-top: 5rem;
		padding-bottom: 3rem;
	}

	.back-link {
		font-family: var(--mono);
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--on-ink-dim);
		display: inline-block;
		margin-bottom: 1.75rem;
		transition: color 0.15s;
	}
	.back-link:hover { color: var(--on-ink); }

	.band-lockup { display: flex; align-items: center; gap: 0.85rem; margin-bottom: 1rem; }
	.band-emblem { color: var(--on-ink); width: 42px; height: 42px; }
	.band-kicker { color: #F2C9B8; }

	.band-title {
		font-family: var(--display);
		font-weight: 500;
		color: var(--on-ink);
		font-size: clamp(2.2rem, 5.2vw, 4rem);
		line-height: 1.0;
		letter-spacing: -0.025em;
		max-width: 20ch;
		margin-bottom: 1.1rem;
	}

	.band-intro {
		font-family: var(--display);
		font-style: italic;
		font-weight: 400;
		color: var(--on-ink-dim);
		font-size: clamp(1.1rem, 1.9vw, 1.42rem);
		line-height: 1.45;
		max-width: 46rem;
		margin-bottom: 2rem;
	}

	/* reg basis as mono chips over the dark image */
	.reg-basis {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.7rem;
	}
	.reg-label {
		font-family: var(--mono);
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--vermilion);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		flex-shrink: 0;
		margin-right: 0.25rem;
	}
	.reg-links { display: flex; flex-wrap: wrap; gap: 0.5rem; }
	.reg-links a {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 400;
		color: var(--on-ink-dim);
		letter-spacing: 0.02em;
		padding: 0.28rem 0.6rem;
		background: rgba(22,19,13,0.45);
		border: 1px solid var(--line-ink);
		border-radius: var(--radius);
		transition: border-color 0.15s, color 0.15s, background 0.15s;
	}
	.reg-links a:hover { border-color: var(--vermilion); color: var(--on-ink); background: rgba(203,75,42,0.22); }

	/* ════════════ BODY GRID ════════════ */
	.pillar-section { padding-top: 4rem; }
	.pillar-body {
		display: grid;
		grid-template-columns: 1fr 290px;
		gap: 4.5rem;
		align-items: start;
	}

	.articles-head { margin-bottom: 2rem; }
	.articles-head .kicker { display: block; margin-bottom: 0.6rem; }

	.empty { font-size: 0.95rem; }

	/* article index rows (extends global .index-list / .index-row) */
	.article-list { border-top: 2px solid var(--ink); }
	.article-list li { margin: 0; }
	.article-row {
		align-items: start;
		padding: 1.75rem 0;
		text-decoration: none;
	}
	.article-row .ix-num {
		font-family: var(--mono);
		font-size: 0.9rem;
		color: var(--vermilion);
		padding-top: 0.3rem;
	}
	.article-row-top { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.55rem; flex-wrap: wrap; }
	.article-row-main h3 {
		font-family: var(--display);
		font-weight: 500;
		font-size: 1.3rem;
		color: var(--ink);
		line-height: 1.18;
		letter-spacing: -0.01em;
		transition: color 0.15s;
		margin: 0;
	}
	.article-row:hover .article-row-main h3 { color: var(--vermilion-2); }
	.article-row-main p {
		font-family: var(--sans);
		font-size: 0.92rem;
		color: var(--graphite);
		line-height: 1.6;
		margin: 0;
		max-width: 48rem;
	}

	.article-row-meta {
		font-family: var(--mono);
		font-size: 0.74rem;
		color: var(--muted);
		white-space: nowrap;
		padding-top: 0.35rem;
	}
	.arrow { color: var(--vermilion); transition: color 0.15s; }
	.article-row:hover .arrow { color: var(--vermilion-2); }

	/* ════════════ SIDEBAR (editorial, mono, low-chrome) ════════════ */
	.pillar-sidebar { display: flex; flex-direction: column; gap: 2.25rem; position: relative; }
	.sidebar-block { border-top: 1px solid var(--ink); padding-top: 1.1rem; }
	.sidebar-label {
		font-family: var(--mono);
		font-size: 0.7rem;
		font-weight: 700;
		color: var(--vermilion);
		text-transform: uppercase;
		letter-spacing: 0.14em;
		margin-bottom: 1rem;
	}
	.sidebar-block ul {
		padding-left: 1.05rem;
		list-style: none;
		color: var(--graphite);
		font-size: 0.84rem;
		line-height: 1.55;
		margin: 0;
	}
	.sidebar-block li { margin-bottom: 0.55rem; position: relative; }
	.sidebar-block li::before {
		content: '—';
		position: absolute;
		left: -1.05rem;
		color: var(--vermilion);
		font-family: var(--mono);
	}

	.related-pill, .track-link {
		display: block;
		font-family: var(--sans);
		font-size: 0.86rem;
		font-weight: 500;
		color: var(--graphite);
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--line);
		transition: color 0.15s, padding-left 0.15s;
	}
	.related-pill:last-child, .track-link:last-child { border-bottom: none; }
	.related-pill:hover, .track-link:hover { color: var(--vermilion-2); padding-left: 0.35rem; }

	.track-link { font-family: var(--mono); font-size: 0.8rem; letter-spacing: 0.02em; }

	.sidebar-seal { width: 84px; color: var(--vermilion); opacity: 0.85; align-self: flex-start; margin-top: 0.5rem; }

	@media (max-width: 860px) {
		.pillar-band { min-height: 48vh; }
		.pillar-band-inner { padding-top: 3.25rem; }
		.pillar-body { grid-template-columns: 1fr; gap: 3rem; }
		.pillar-sidebar { order: 2; }
		.sidebar-seal { display: none; }
	}
</style>
