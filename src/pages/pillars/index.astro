---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { PILLARS } from '../../data/pillars';

const all = await getCollection('articles', ({ data }) => !data.draft);
const count = (slug: string) => all.filter(a => a.data.pillar === slug).length;
const total = all.length;
---
<Layout title="Topics" description="Twelve topic areas covering the full scope of GxP quality, data integrity, validation, and compliance across biotech, pharma, and life sciences, from foundations to program-level depth." wide={true}>
  <header class="hub-hero">
    <div class="wrap hub-inner">
      <nav class="crumb"><a href="/">Home</a> <span>›</span> Topics</nav>
      <span class="overline" style="color:#ffd98a">The reference, by area</span>
      <h1 class="hub-h1">Twelve topic areas. End-to-end coverage.</h1>
      <p class="hub-lead">{total} articles across the full scope of regulated quality, data integrity, validation, the quality system, sterility, devices, clinical, supply chain, and more. Pitched for beginners through advanced practitioners.</p>
    </div>
  </header>

  <div class="wrap hub-grid">
    {PILLARS.map((p, i) => (
      <a href={`/pillars/${p.slug}`} class="pcard">
        <div class="pcard-img"><img src={p.image} alt="" loading="lazy" /><span class="pcard-n">{String(i+1).padStart(2,'0')}</span></div>
        <div class="pcard-body">
          <h2 class="pcard-title">{p.short}</h2>
          <p class="pcard-blurb">{p.blurb}</p>
          <span class="pcard-count">{count(p.slug)} article{count(p.slug) === 1 ? '' : 's'} →</span>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .hub-hero { background: var(--navy); color: #fff; }
  .hub-inner { padding: 3.4rem 0 2.8rem; }
  .crumb { font-size: 0.82rem; color: var(--on-navy-dim); margin-bottom: 1.2rem; } .crumb a { color: var(--on-navy-dim); } .crumb a:hover { color:#fff; } .crumb span { opacity:.6; margin:0 3px; }
  .hub-h1 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); margin: 8px 0 14px; letter-spacing: -0.025em; }
  .hub-lead { color: var(--on-navy); font-family: var(--serif); font-size: clamp(1.05rem,1.5vw,1.28rem); line-height: 1.5; max-width: 62ch; }

  .hub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; padding: 56px 28px; }
  .pcard { background: #fff; border: 1px solid var(--line-strong); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; transition: box-shadow .15s, transform .15s; }
  .pcard:hover { box-shadow: var(--shadow); transform: translateY(-3px); text-decoration: none; }
  .pcard-img { position: relative; height: 150px; overflow: hidden; background: var(--navy); }
  .pcard-img img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
  .pcard-n { position: absolute; top: 10px; left: 12px; font-family: var(--display); font-weight: 800; font-size: 1.1rem; color: #fff; background: rgba(11,46,79,0.85); padding: 2px 9px; border-radius: 3px; }
  .pcard-body { padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1; }
  .pcard-title { font-size: 1.3rem; color: var(--navy); margin-bottom: 8px; }
  .pcard-blurb { font-size: 0.93rem; color: var(--muted); flex: 1; margin-bottom: 14px; }
  .pcard-count { font-size: 0.85rem; font-weight: 700; color: var(--blue); }

  @media (max-width: 900px) { .hub-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .hub-grid { grid-template-columns: 1fr; } }
</style>
