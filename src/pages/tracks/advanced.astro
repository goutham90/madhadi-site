---
import Layout from '../../layouts/Layout.astro';

const accent = 'var(--oxblood)'; // Advanced tier, oxblood #7A2E23

// Pillar name → slug, for emblem line-art lookup
const pillarSlug = {
 'Data Integrity': 'data-integrity',
 'CSV & CSA': 'csv-csa',
 'Cell & Gene Therapy': 'cell-gene-therapy',
 'Audits & Inspection': 'audits-inspection',
 'Equipment Qualification': 'equipment-qualification',
 'Quality Assurance': 'quality-assurance',
};

const steps = [
 {
 num: '01',
 title: 'Building a DI program: architecture and governance',
 desc: 'What a mature, enterprise-level data integrity program looks like, system inventory and tiering, governance model, ownership structures, data-flow mapping, and how to assess where you are versus where you need to be.',
 articles: [
 { title: 'Building a Data Integrity Program: Architecture, Governance, and the Gap Assessment', slug: 'di-program-architecture' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '02',
 title: 'FDA\'s Computer Software Assurance shift',
 desc: 'FDA\'s September 2022 CSA draft guidance is the most significant change to GxP software compliance in decades. Understanding what it actually changes, and what it doesn\'t, is critical for senior practitioners advising programs.',
 articles: [
 { title: "FDA Computer Software Assurance: What Changed and What Didn't", slug: 'computer-software-assurance-fda' },
 ],
 pillar: 'CSV & CSA',
 color: 'var(--green)',
 },
 {
 num: '03',
 title: 'Cloud and SaaS validation in GxP',
 desc: 'Cloud-hosted systems are now standard in GxP environments. The shared-responsibility model, IaaS/PaaS/SaaS qualification implications, SOC 2 reports, and how to build and maintain a defensible qualification posture for cloud infrastructure.',
 articles: [
 { title: 'Cloud and SaaS Validation in GxP: The Shared-Responsibility Model', slug: 'cloud-saas-validation' },
 ],
 pillar: 'CSV & CSA',
 color: 'var(--green)',
 },
 {
 num: '04',
 title: 'CGT data integrity: structural challenges and program design',
 desc: 'Cell and gene therapy creates data integrity challenges that don\'t exist in conventional manufacturing, and building programs that address them requires understanding why they\'re different, not just applying the standard framework harder.',
 articles: [
 { title: 'Cell & Gene Therapy: Why Data Integrity Is Structurally Different', slug: 'cell-gene-therapy-data-integrity' },
 { title: 'Data Integrity in Gene Therapy: What FDA Really Expects', slug: 'data-integrity-in-gene-therapy' },
 ],
 pillar: 'Cell & Gene Therapy',
 color: 'var(--oxblood)',
 },
 {
 num: '05',
 title: 'Handling a 483 and responding to Warning Letters',
 desc: 'A 483 observation is the start of a process, not the end of an inspection. The quality of your response, root cause analysis, CAPA, realistic commitments, determines whether the matter stays as a 483 or escalates. This covers what good responses look like.',
 articles: [
 { title: 'FDA Form 483 and Warning Letters: How to Respond Effectively', slug: '483-warning-letter-response' },
 ],
 pillar: 'Audits & Inspection',
 color: 'var(--vermilion-2)',
 },
 {
 num: '06',
 title: 'Warning letter patterns: what the enforcement record tells you',
 desc: 'The public FDA enforcement record is one of the most useful training datasets in the industry. The same failures appear in different companies because they reflect the same underlying system weaknesses.',
 articles: [
 { title: 'FDA Data Integrity Warning Letters: 8 Patterns That Repeat', slug: 'fda-warning-letters-patterns' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '07',
 title: 'USP 1058 and analytical instrument qualification at scale',
 desc: 'USP 1058 provides the AIQ framework that integrates instrument qualification with CSV and data integrity. Understanding how to apply it proportionally across a diverse instrument fleet is an advanced program management challenge.',
 articles: [
 { title: 'Analytical Instrument Qualification: USP <1058> and the 4Qs Framework', slug: 'analytical-instrument-qualification' },
 ],
 pillar: 'Equipment Qualification',
 color: 'var(--vermilion-2)',
 },
 {
 num: '08',
 title: 'DI gap assessment: running one that finds something',
 desc: 'The methodology for a comprehensive data integrity gap assessment, five layers from infrastructure through culture, system-by-system evaluation, finding classification, and turning findings into a prioritized remediation roadmap.',
 articles: [
 { title: 'Data Integrity Gap Assessment Methodology', slug: 'di-gap-assessment-methodology' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '09',
 title: 'Running a DI remediation program',
 desc: 'What happens after a data integrity warning letter, organizing the program, retrospective data review, rebuilding regulatory trust, managing the follow-up inspection, and transitioning to sustainable compliance.',
 articles: [
 { title: 'DI Remediation Program: From Warning Letter to Sustainable Compliance', slug: 'di-remediation-program' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '10',
 title: 'FDA vs. EMA: inspection dynamics and strategic differences',
 desc: 'Operating globally means managing two different inspection frameworks simultaneously. Structural differences in investigator authority, deficiency classification, pre-inspection notification, and enforcement consequences.',
 articles: [
 { title: 'FDA vs EMA Inspection Dynamics', slug: 'fda-vs-ema-inspection-dynamics' },
 ],
 pillar: 'Audits & Inspection',
 color: 'var(--vermilion-2)',
 },
 {
 num: '11',
 title: 'BLA readiness: architecting the CMC data package',
 desc: 'The CMC data package is the most scrutinized section of a biologics application. Data traceability requirements, pre-BLA data integrity audit methodology, what PLI investigators actually examine, and CGT-specific data architecture.',
 articles: [
 { title: 'BLA Readiness: Architecting the Data Package', slug: 'bla-readiness-data-package' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '12',
 title: 'Quality culture and the behavioral science of DI failures',
 desc: 'Why data integrity violations happen in organizations with good procedures. Organizational pressure, normalization of deviance, diffusion of responsibility, and the management behaviors that enable or prevent falsification.',
 articles: [
 { title: 'Quality Culture and DI Failures: The Behavioral Science', slug: 'quality-culture-di-failures' },
 ],
 pillar: 'Data Integrity',
 color: 'var(--ink)',
 },
 {
 num: '13',
 title: 'Process validation lifecycle: Stage 1, 2, and 3',
 desc: 'The three-stage lifecycle model under FDA\'s 2011 guidance and ICH Q8-Q10, process design, process qualification (PPQ), and continued process verification with statistical process monitoring.',
 articles: [
 { title: 'Process Validation Lifecycle: Stage 1, 2, and 3', slug: 'process-validation-lifecycle' },
 ],
 pillar: 'Quality Assurance',
 color: 'var(--oxblood)',
 },
 {
 num: '14',
 title: 'Retroactive validation: when systems were never properly validated',
 desc: 'The structured approach to bringing unvalidated legacy systems into a validated state, risk assessment, retrospective data review, what retroactive validation can and can\'t accomplish, and when replacement is the right answer.',
 articles: [
 { title: 'Retroactive Validation and Legacy Systems', slug: 'retroactive-validation-legacy-systems' },
 ],
 pillar: 'CSV & CSA',
 color: 'var(--green)',
 },
];
---
<Layout title="Advanced Track" description="Program-level depth for senior GxP practitioners, DI program architecture, CSA, cloud validation, CGT, 483 response, and inspection defense." wide={true}>

 <!-- ═══════════ HEADER, duotone band ═══════════ -->
 <header class="track-hero duotone" style={`--accent: ${accent}`}>
 <img src="/images/records-server.jpg" alt="" loading="eager" />
 <div class="track-hero-grad"></div>
 <div class="wrap track-hero-inner">
 <a href="/tracks" class="back-link">← Learning Tracks</a>
 <div class="track-hero-eyebrow">
 <span class="tier-badge head-badge">Advanced</span>
 <span class="track-hero-kick">Track № 03 · Strategy &amp; Defense</span>
 </div>
 <h1 class="track-hero-title">Building Programs: Strategy &amp; Defense</h1>
 <p class="lead track-hero-lead">
 This track covers what senior practitioners need, program architecture, regulatory strategy, inspection defense, and the judgment calls that separate programs that survive scrutiny from those that don't.
 </p>
 </div>
 </header>

 <!-- ═══════════ ORIENTATION, asymmetric notes ═══════════ -->
 <section class="section-tight orient" style={`--accent: ${accent}`}>
 <div class="wrap orient-grid">
 <div class="orient-lead">
 <span class="kicker">Before you begin</span>
 <p class="orient-blurb">Fourteen records, in the order a director would actually work them, from standing up an enterprise DI program through to defending it in front of an investigator.</p>
 <img class="orient-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />
 </div>
 <div class="head-notes">
 <div class="head-note">
 <span class="note-label">For</span>
 <span class="note-text">Directors of quality, validation, and data integrity; heads of regulatory affairs; quality VPs; anyone leading a GxP program rather than executing within one.</span>
 </div>
 <div class="head-note">
 <span class="note-label">Prerequisites</span>
 <span class="note-text">This track assumes working familiarity with GxP quality and validation. Start with <a href="/tracks/foundations">Foundations</a> or <a href="/tracks/implementation">Implementation</a> if you're earlier in your career.</span>
 </div>
 </div>
 </div>
 </section>

 <!-- ═══════════ THE SEQUENCE, editorial step index ═══════════ -->
 <section class="section-tight sequence" style={`--accent: ${accent}`}>
 <div class="wrap">
 <div class="sequence-head">
 <span class="kicker">The sequence</span>
 <h2 class="display-2">Fourteen steps, program-level.</h2>
 </div>
 <ol class="steps">
 {steps.map(step => (
 <li class="step" style={`--step-color: ${step.color}`}>
 <div class="step-rail">
 <span class="step-num">{step.num}</span>
 <span class="emblem step-emblem" style={`--src:url('/brand/emblems/pillar-${pillarSlug[step.pillar]}.svg')`}></span>
 </div>
 <div class="step-content">
 <div class="step-pillar">{step.pillar}</div>
 <h3 class="step-title">{step.title}</h3>
 <p class="step-desc">{step.desc}</p>
 <div class="step-articles">
 {step.articles.map(a => (
 <a href={`/articles/${a.slug}`} class="step-article-link">
 <span class="article-icon" aria-hidden="true">→</span>
 <span class="article-title">{a.title}</span>
 </a>
 ))}
 </div>
 </div>
 </li>
 ))}
 </ol>
 </div>
 </section>

 <!-- ═══════════ CLOSING, dark plate, browse by discipline ═══════════ -->
 <section class="section section-dark all-pillars">
 <img class="all-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 <div class="wrap all-inner">
 <div class="all-copy">
 <span class="kicker">Browse by discipline</span>
 <h2 class="all-title display-2">Explore the full knowledge hub</h2>
 <p>All articles organized by pillar, with regulatory references, tier tags, and cross-links.</p>
 </div>
 <a href="/pillars" class="btn-accent all-cta">View all pillars →</a>
 </div>
 </section>
</Layout>

<style>
 /* ── Header, duotone band ── */
 .track-hero { position: relative; min-height: 52vh; display: flex; align-items: flex-end; border-bottom: 3px solid var(--accent); }
 .track-hero > img { position: absolute; inset: 0; }
 .track-hero-grad { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(22,19,13,0.2) 0%, rgba(22,19,13,0.4) 45%, rgba(22,19,13,0.88) 100%); }
 .track-hero-inner { position: relative; z-index: 3; padding-top: 4.5rem; padding-bottom: 3rem; }

 .back-link {
 display: inline-block;
 font-family: var(--mono);
 font-size: 0.8rem;
 color: var(--on-ink-dim);
 margin-bottom: 1.5rem;
 transition: color 0.15s;
 }
 .back-link:hover { color: var(--on-ink); }

 .track-hero-eyebrow { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.15rem; flex-wrap: wrap; }
 .head-badge { background: var(--oxblood); color: var(--on-ink); border-color: var(--oxblood); }
 .track-hero-kick { font-family: var(--mono); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; color: var(--vermilion); }

 .track-hero-title { font-family: var(--display); font-weight: 500; color: var(--on-ink); font-size: clamp(2.4rem, 5.4vw, 4.2rem); line-height: 1.0; letter-spacing: -0.025em; max-width: 18ch; margin-bottom: 1.25rem; }
 .track-hero-lead { color: var(--on-ink-dim); max-width: 42rem; }

 /* ── Orientation ── */
 .orient-grid { display: grid; grid-template-columns: 0.85fr 1.15fr; gap: 3.5rem; align-items: start; }
 .orient-lead .kicker { margin-bottom: 1rem; }
 .orient-blurb { font-family: var(--display); font-size: 1.45rem; line-height: 1.3; color: var(--ink); letter-spacing: -0.01em; }
 .orient-rule { display: block; width: 100%; height: 14px; color: var(--line); margin-top: 1.75rem; }

 .head-notes {
 display: grid;
 grid-template-columns: 1fr 1fr;
 gap: 1.25rem;
 }
 .head-note {
 padding: 1.1rem 1.25rem;
 background: var(--paper);
 border: 1px solid var(--line);
 border-left: 2px solid var(--accent);
 border-radius: var(--radius);
 font-size: 0.875rem;
 color: var(--graphite);
 line-height: 1.6;
 }
 .note-label {
 display: block;
 font-family: var(--mono);
 font-size: 0.66rem;
 font-weight: 700;
 text-transform: uppercase;
 letter-spacing: 0.14em;
 color: var(--vermilion);
 margin-bottom: 0.45rem;
 }
 .note-text { color: var(--graphite); }
 .head-note a {
 color: var(--vermilion-2);
 text-decoration: underline;
 text-underline-offset: 3px;
 text-decoration-color: var(--line);
 transition: text-decoration-color 0.15s, color 0.15s;
 }
 .head-note a:hover { color: var(--ink); text-decoration-color: var(--vermilion); }

 /* ── Sequence ── */
 .sequence-head { margin-bottom: 2.25rem; }
 .sequence-head .kicker { margin-bottom: 0.75rem; }
 .steps {
 list-style: none;
 padding: 0;
 margin: 0;
 border-top: 2px solid var(--ink);
 max-width: 60rem;
 }
 .step {
 display: grid;
 grid-template-columns: 64px 1fr;
 gap: 1.75rem;
 padding: 2.25rem 0;
 border-bottom: 1px solid var(--line);
 transition: padding-left 0.18s;
 }
 .step:hover { padding-left: 0.6rem; }
 .step::marker { content: none; }

 .step-rail { display: flex; flex-direction: column; align-items: flex-start; gap: 0.9rem; }
 .step-num {
 font-family: var(--display);
 font-size: 2rem;
 font-weight: 500;
 color: var(--step-color, var(--accent));
 line-height: 1;
 letter-spacing: -0.02em;
 }
 .step-emblem { width: 30px; height: 30px; color: var(--muted); transition: color 0.18s; }
 .step:hover .step-emblem { color: var(--vermilion); }

 .step-pillar {
 font-family: var(--mono);
 font-size: 0.7rem;
 font-weight: 700;
 text-transform: uppercase;
 letter-spacing: 0.14em;
 color: var(--vermilion);
 margin-bottom: 0.55rem;
 }

 .step-title {
 font-family: var(--display);
 font-weight: 500;
 font-size: 1.45rem;
 line-height: 1.18;
 letter-spacing: -0.01em;
 color: var(--ink);
 margin-bottom: 0.65rem;
 }
 .step:hover .step-title { color: var(--vermilion-2); }

 .step-desc {
 font-family: var(--sans);
 font-size: 0.9375rem;
 color: var(--graphite);
 line-height: 1.7;
 margin-bottom: 1.1rem;
 max-width: 46rem;
 }

 .step-articles {
 display: flex;
 flex-direction: column;
 gap: 0.5rem;
 }
 .step-article-link {
 display: inline-flex;
 align-items: baseline;
 gap: 0.65rem;
 font-family: var(--sans);
 font-size: 0.92rem;
 font-weight: 500;
 color: var(--graphite);
 width: fit-content;
 max-width: 100%;
 border-bottom: 1px solid var(--line);
 padding-bottom: 0.15rem;
 transition: color 0.15s, border-color 0.15s;
 }
 .step-article-link:hover {
 color: var(--vermilion-2);
 border-color: var(--vermilion);
 }
 .article-icon {
 font-family: var(--mono);
 font-size: 0.82rem;
 color: var(--vermilion);
 flex-shrink: 0;
 }
 .article-title { color: inherit; }

 /* ── Closing dark plate ── */
 .all-pillars { position: relative; overflow: hidden; }
 .all-seal { position: absolute; right: -50px; top: 50%; transform: translateY(-50%); width: 240px; color: rgba(236,230,216,0.06); pointer-events: none; }
 .all-inner {
 position: relative;
 z-index: 2;
 display: flex;
 justify-content: space-between;
 align-items: center;
 gap: 2.5rem;
 flex-wrap: wrap;
 }
 .all-copy { max-width: 38rem; }
 .all-copy .kicker { margin-bottom: 0.85rem; }
 .all-title {
 margin-bottom: 0.6rem;
 }
 .all-copy p { font-size: 1rem; color: var(--on-ink-dim); line-height: 1.65; }
 .all-cta { flex-shrink: 0; white-space: nowrap; }

 /* ── Responsive ── */
 @media (max-width: 900px) {
 .orient-grid { grid-template-columns: 1fr; gap: 2rem; }
 }
 @media (max-width: 720px) {
 .head-notes { grid-template-columns: 1fr; }
 .all-inner { flex-direction: column; align-items: flex-start; }
 }
 @media (max-width: 600px) {
 .track-hero { min-height: 46vh; }
 .step { grid-template-columns: 1fr; gap: 1rem; }
 .step-rail { flex-direction: row; align-items: center; gap: 0.8rem; }
 .step-num { font-size: 1.5rem; }
 .step-emblem { width: 26px; height: 26px; }
 }
</style>
