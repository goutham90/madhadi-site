---
import Layout from '../../layouts/Layout.astro';

const tracks = [
 {
 slug: 'foundations',
 icon: '◎',
 label: 'Foundations',
 title: 'Breaking In: From Zero to Competent',
 desc: 'For anyone starting in GxP quality, validation, or data integrity. Covers the regulatory map, core vocabulary, why each discipline exists, and a concrete learning roadmap for building your career.',
 color: '#34d399',
 articles: 8,
 time: '~4 hours',
 for: 'Students, career changers, new hires in their first GxP role',
 },
 {
 slug: 'implementation',
 icon: '◈',
 label: 'Implementation',
 title: 'Owning Systems: How to Execute',
 desc: 'For mid-career practitioners who own GxP systems, lead validation efforts, or run DI programs. Covers the procedures, decision frameworks, failure modes, and judgment calls that experienced practitioners develop over years.',
 color: '#4f8ef7',
 articles: 10,
 time: '~6 hours',
 for: 'Validation engineers, QA specialists, system owners, lab managers',
 },
 {
 slug: 'advanced',
 icon: '◇',
 label: 'Advanced',
 title: 'Building Programs: Strategy & Defense',
 desc: 'For senior practitioners and program leaders responsible for building DI programs, leading inspection responses, managing remediation, and setting quality strategy. Covers architecture, governance, and what "good" looks like at inspection.',
 color: '#a78bfa',
 articles: 7,
 time: '~5 hours',
 for: 'Directors of quality/validation/DI, heads of regulatory affairs, quality VPs',
 },
];
---
<Layout title="Learning Tracks" description="Three sequenced learning paths through GxP quality and data integrity, Foundations for beginners, Implementation for practitioners, Advanced for program leaders." wide={true}>
 <div class="page-hero">
 <div class="page-hero-inner">
 <div class="page-label">Learning Tracks</div>
 <h1>Find your starting point.</h1>
 <p>
 Three curated reading paths through the knowledge hub, designed for three different stages of a GxP career.
 Each track sequences the material so you build from fundamentals to application.
 </p>
 </div>
 </div>

 <div class="tracks-grid">
 {tracks.map(t => (
 <a href={`/tracks/${t.slug}`} class="track-card" style={`--tc: ${t.color}`}>
 <div class="track-icon">{t.icon}</div>
 <div class="track-level">{t.label}</div>
 <h2 class="track-title">{t.title}</h2>
 <p class="track-desc">{t.desc}</p>
 <div class="track-for">
 <span class="for-label">For:</span>
 <span class="for-text">{t.for}</span>
 </div>
 <div class="track-meta">
 <span>{t.articles} articles</span>
 <span>·</span>
 <span>{t.time} reading time</span>
 <span class="start-link">Start reading →</span>
 </div>
 </a>
 ))}
 </div>

 <div class="faq">
 <h2>Not sure which track?</h2>
 <div class="faq-grid">
 <div class="faq-item">
 <div class="faq-q">I'm starting my first QA/validation role.</div>
 <div class="faq-a">Start with <a href="/tracks/foundations">Foundations</a>. It explains the regulatory landscape and why each discipline exists before asking you to learn any procedures.</div>
 </div>
 <div class="faq-item">
 <div class="faq-q">I've been in quality for a few years and want to go deeper.</div>
 <div class="faq-a">Start with <a href="/tracks/implementation">Implementation</a>. It assumes you know the basics and focuses on execution: how to run a validation, how to design an audit trail, how to structure a CAPA.</div>
 </div>
 <div class="faq-item">
 <div class="faq-q">I'm building or rebuilding a DI program and facing inspection pressure.</div>
 <div class="faq-a">Start with <a href="/tracks/advanced">Advanced</a>. It covers program architecture, inspection defense, 483 response, and what mature programs look like under scrutiny.</div>
 </div>
 <div class="faq-item">
 <div class="faq-q">I need to understand a specific topic, not follow a path.</div>
 <div class="faq-a">Browse by <a href="/pillars">Pillar</a> or <a href="/topics">Topic</a> to go directly to what you need.</div>
 </div>
 </div>
 </div>
</Layout>

<style>
 .page-hero {
 padding: 4rem 0 3rem;
 border-bottom: 1px solid var(--border-dim);
 margin-bottom: 3.5rem;
 }

 .page-hero-inner { max-width: 680px; }

 .page-label {
 font-size: 0.72rem;
 font-family: var(--mono);
 color: var(--accent);
 text-transform: uppercase;
 letter-spacing: 0.1em;
 font-weight: 700;
 margin-bottom: 0.75rem;
 }

 h1 {
 font-size: clamp(2rem, 4vw, 3rem);
 letter-spacing: -0.03em;
 margin-bottom: 1rem;
 }

 .page-hero p {
 font-size: 1.05rem;
 color: var(--muted-light);
 line-height: 1.7;
 }

 .tracks-grid {
 display: grid;
 grid-template-columns: repeat(3, 1fr);
 gap: 1rem;
 margin-bottom: 4rem;
 }

 .track-card {
 background: var(--surface);
 border: 1px solid var(--border);
 border-radius: 14px;
 padding: 2rem;
 display: flex;
 flex-direction: column;
 gap: 0.75rem;
 text-decoration: none;
 color: inherit;
 position: relative;
 overflow: hidden;
 transition: border-color 0.2s, transform 0.2s;
 }

 .track-card::before {
 content: '';
 position: absolute;
 top: 0; left: 0; right: 0;
 height: 3px;
 background: var(--tc);
 }

 .track-card:hover {
 border-color: var(--tc);
 transform: translateY(-2px);
 }

 .track-icon {
 font-size: 1.5rem;
 color: var(--tc);
 }

 .track-level {
 font-size: 0.7rem;
 font-family: var(--mono);
 color: var(--tc);
 text-transform: uppercase;
 letter-spacing: 0.08em;
 font-weight: 700;
 }

 .track-title {
 font-size: 1.1rem;
 color: var(--text);
 line-height: 1.3;
 }

 .track-desc {
 font-size: 0.875rem;
 color: var(--muted-light);
 line-height: 1.65;
 flex: 1;
 margin: 0;
 }

 .track-for {
 font-size: 0.8rem;
 color: var(--muted);
 padding: 0.6rem 0.85rem;
 background: var(--surface2);
 border-radius: 7px;
 }

 .for-label {
 font-weight: 700;
 color: var(--muted-light);
 margin-right: 0.35rem;
 font-family: var(--mono);
 font-size: 0.72rem;
 text-transform: uppercase;
 }

 .track-meta {
 display: flex;
 align-items: center;
 gap: 0.5rem;
 font-size: 0.775rem;
 color: var(--muted);
 font-family: var(--mono);
 padding-top: 0.75rem;
 border-top: 1px solid var(--border-dim);
 }

 .start-link {
 margin-left: auto;
 color: var(--tc);
 font-weight: 600;
 transition: opacity 0.15s;
 }

 .track-card:hover .start-link { opacity: 0.8; }

 .faq {
 background: var(--surface);
 border: 1px solid var(--border);
 border-radius: 14px;
 padding: 2rem 2rem 1.5rem;
 margin-bottom: 2rem;
 }

 .faq h2 {
 font-size: 1.15rem;
 margin-bottom: 1.5rem;
 color: var(--text);
 }

 .faq-grid {
 display: grid;
 grid-template-columns: 1fr 1fr;
 gap: 1.25rem;
 }

 .faq-item {
 padding: 1rem 1.25rem;
 background: var(--surface2);
 border-radius: 10px;
 border: 1px solid var(--border-dim);
 }

 .faq-q {
 font-size: 0.875rem;
 font-weight: 600;
 color: var(--text);
 margin-bottom: 0.5rem;
 }

 .faq-a {
 font-size: 0.825rem;
 color: var(--muted-light);
 line-height: 1.6;
 }

 .faq-a a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }

 @media (max-width: 860px) {
 .tracks-grid { grid-template-columns: 1fr; }
 .faq-grid { grid-template-columns: 1fr; }
 }
</style>
