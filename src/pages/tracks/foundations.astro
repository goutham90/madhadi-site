---
import Layout from '../../layouts/Layout.astro';

const steps = [
 {
 num: '01',
 title: 'What is GMP, and why does it exist?',
 desc: 'Before learning the procedures, understand the foundation. What GMP actually requires, why it exists (the patient safety case), and how it connects to everything else in regulated manufacturing.',
 articles: [
 { title: 'What Is GMP? A Plain-Language Introduction', slug: 'what-is-gmp' },
 { title: 'Data Integrity Foundations: What It Is and Why Regulators Care', slug: 'data-integrity-foundations' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#9A3B3B',
 },
 {
 num: '02',
 title: 'Who does what, GxP roles explained',
 desc: 'QA, QC, validation, regulatory affairs, clinical QA, DI. Understanding who owns what, how the functions interact, and where each role fits in the quality system is essential before you can work effectively in any of them.',
 articles: [
 { title: 'GxP Roles Explained: Who Does What', slug: 'gxp-roles-responsibilities' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#9A3B3B',
 },
 {
 num: '03',
 title: 'The ALCOA+ principles, the language of DI',
 desc: 'ALCOA+ is cited in every data integrity document from every major regulatory agency. Understanding each principle, and the specific failure modes it addresses, gives you the vocabulary to diagnose any data integrity problem.',
 articles: [
 { title: 'ALCOA+: The Framework Behind Every Data Integrity Requirement', slug: 'alcoa-plus-deep-dive' },
 ],
 pillar: 'Data Integrity',
 pillarSlug: 'data-integrity',
 color: '#1C4E80',
 },
 {
 num: '04',
 title: 'The pharmaceutical quality system',
 desc: 'How QA, QC, validation, and data integrity actually fit together. Document control, deviations, CAPA, change control, these aren\'t separate systems. They\'re the interconnected fabric of the QMS.',
 articles: [
 { title: 'The Pharmaceutical Quality System: ICH Q10', slug: 'pharmaceutical-quality-system' },
 { title: 'Document Control Fundamentals', slug: 'document-control-fundamentals' },
 { title: 'What Is a Deviation?', slug: 'deviation-management' },
 { title: 'What Is a CAPA?', slug: 'what-is-a-capa' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#9A3B3B',
 },
 {
 num: '05',
 title: 'GxP computerized systems, the landscape',
 desc: 'LIMS, CDS, ELN, MES, EDMS, CTMS, EDC. Every system generates GxP data with specific validation and DI requirements. Understanding the landscape is the prerequisite for understanding validation.',
 articles: [
 { title: 'GxP Computerized Systems: LIMS, CDS, ELN, MES and More', slug: 'gxp-systems-overview' },
 ],
 pillar: 'CSV & CSA',
 pillarSlug: 'csv-csa',
 color: '#2F6E4F',
 },
 {
 num: '06',
 title: 'Computer system validation, the basics',
 desc: 'GAMP 5 software categories, the V-model, IQ/OQ/PQ, risk-based testing. Understanding the validation framework is foundational for any quality or validation career.',
 articles: [
 { title: 'GAMP 5 Second Edition: The Framework for Risk-Based CSV', slug: 'gamp5-csv-framework' },
 { title: 'Validation Deliverables Guide: URS, FRS, IQ/OQ/PQ', slug: 'validation-deliverables-guide' },
 ],
 pillar: 'CSV & CSA',
 pillarSlug: 'csv-csa',
 color: '#2F6E4F',
 },
 {
 num: '07',
 title: 'Equipment qualification basics',
 desc: 'Why equipment must be qualified before GxP use, what DQ/IQ/OQ/PQ involves, and how calibration and qualification interact.',
 articles: [
 { title: 'Equipment Qualification: DQ/IQ/OQ/PQ Lifecycle', slug: 'equipment-qualification-lifecycle' },
 ],
 pillar: 'Equipment Qualification',
 pillarSlug: 'equipment-qualification',
 color: '#8A5A1E',
 },
 {
 num: '08',
 title: 'How FDA inspections work, and what they find',
 desc: 'Understanding how FDA inspections are structured, what investigators look for, and what patterns show up in warning letters changes how you approach daily GxP practice.',
 articles: [
 { title: 'FDA Data Integrity Warning Letters: 8 Patterns That Repeat', slug: 'fda-warning-letters-patterns' },
 ],
 pillar: 'Audits & Inspection',
 pillarSlug: 'audits-inspection',
 color: '#8A5A1E',
 },
 {
 num: '09',
 title: 'Career roadmap: how to build expertise',
 desc: 'Where to learn, what credentials matter, how to specialize, and what a realistic career trajectory in GxP quality and validation looks like.',
 articles: [
 { title: 'Breaking Into GxP: A Realistic Career Guide', slug: 'career-guide-gxp-validation' },
 { title: 'Breaking Into GxP Quality: A Practitioner\'s Roadmap', slug: 'breaking-into-gxp-quality' },
 ],
 pillar: 'Career',
 pillarSlug: null,
 color: '#756B5B',
 },
];

// New design-system accent for this track (Foundations → forest / Beginner tier)
const trackAccent = '#2F6E4F';

// Harmonized pillar accents (DESIGN_SPEC v2). Fall back to muted for the Career step (no pillarSlug).
const pillarAccents: Record<string, string> = {
 'data-integrity': '#1C4E80',
 'csv-csa': '#2F6E4F',
 'equipment-qualification': '#8A5A1E',
 'quality-assurance': '#6B4E8A',
 'audits-inspection': '#9A3B3B',
 'cell-gene-therapy': '#2B6E73',
 'manufacturing-automation': '#46566E',
 'ai-automation': '#7A3B57',
};
const accentFor = (slug: string | null) => (slug && pillarAccents[slug]) || '#756B5B';
---
<Layout title="Foundations Track" description="A sequenced reading path for GxP beginners, the regulatory map, ALCOA+, quality systems, CSV basics, and a career roadmap. Start here if you're new to pharma quality and validation." wide={true}>
 <div class="track-shell">
 <header class="track-header">
 <a href="/tracks" class="back-link">← Learning Tracks</a>
 <div class="eyebrow">Learning Track 01 · Foundations</div>
 <h1>Breaking In: From Zero to Competent</h1>
 <p class="lead">
 This track is for anyone starting a career in GxP quality, validation, or data integrity, or anyone who wants to understand the field before diving into the technical details. It covers the regulatory landscape, core frameworks, and gives you a concrete roadmap for building expertise.
 </p>
 <div class="track-meta">
 <span class="tier-badge" style={`background:${trackAccent}1A;color:${trackAccent};border-color:${trackAccent}40`}>Beginner</span>
 <span class="track-for">
 <span class="track-for-label">For</span>
 Students, career changers, new hires entering their first GxP quality or validation role.
 </span>
 </div>
 </header>

 <ol class="steps">
 {steps.map(step => {
 const accent = accentFor(step.pillarSlug);
 return (
 <li class="step">
 <div class="step-rail">
 <div class="step-num">{step.num}</div>
 <div class="step-connector" aria-hidden="true"></div>
 </div>
 <div class="step-content">
 <div class="step-pillar" style={`color: ${accent}`}>
 <span class="step-dot" style={`background: ${accent}`}></span>
 {step.pillar}
 </div>
 <h2 class="step-title">{step.title}</h2>
 <p class="step-desc">{step.desc}</p>
 <div class="step-articles">
 {step.articles.map(a => (
 <a href={`/articles/${a.slug}`} class="step-article-link">
 <span class="article-icon" aria-hidden="true">→</span>
 <span>{a.title}</span>
 </a>
 ))}
 </div>
 </div>
 </li>
 );
 })}
 </ol>

 <section class="next-track">
 <div class="next-inner">
 <div class="next-copy">
 <div class="section-label">When you're ready</div>
 <h2>Continue to the Implementation Track</h2>
 <p>Once you have the foundations, the Implementation track takes you into execution: how to actually run validations, design audit trails, and manage GxP systems in practice.</p>
 </div>
 <a href="/tracks/implementation" class="btn-primary">Implementation Track →</a>
 </div>
 </section>
 </div>
</Layout>

<style>
 .track-shell { max-width: var(--container-narrow); margin: 0 auto; padding-top: 4rem; }

 .back-link {
 font-size: 0.8rem;
 color: var(--muted);
 font-family: var(--mono);
 display: inline-block;
 margin-bottom: 1.5rem;
 transition: color 0.15s;
 }
 .back-link:hover { color: var(--navy); }

 .track-header {
 margin-bottom: 4rem;
 padding-bottom: 2.25rem;
 border-bottom: 1px solid var(--line);
 }

 .track-header h1 {
 font-size: clamp(2rem, 4vw, 2.9rem);
 letter-spacing: -0.02em;
 line-height: 1.1;
 margin-bottom: 1rem;
 }

 .track-header .lead { margin-bottom: 1.75rem; }

 .track-meta {
 display: flex;
 align-items: flex-start;
 flex-wrap: wrap;
 gap: 1rem 1.25rem;
 }

 .track-for {
 font-size: 0.9rem;
 color: var(--body);
 line-height: 1.6;
 max-width: 36rem;
 }
 .track-for-label {
 font-family: var(--mono);
 font-size: 0.68rem;
 font-weight: 500;
 text-transform: uppercase;
 letter-spacing: 0.1em;
 color: var(--brass);
 margin-right: 0.5rem;
 }

 /* ── Numbered step list ── */
 .steps {
 list-style: none;
 padding: 0;
 margin: 0 0 5rem;
 display: flex;
 flex-direction: column;
 }

 .step {
 display: grid;
 grid-template-columns: 56px 1fr;
 gap: 1.75rem;
 padding: 0 0 2.75rem;
 margin: 0;
 }
 .step:last-child { padding-bottom: 0; }

 .step-rail {
 display: flex;
 flex-direction: column;
 align-items: center;
 }

 .step-num {
 font-family: var(--mono);
 font-size: 1.05rem;
 font-weight: 500;
 color: var(--navy);
 line-height: 1;
 padding: 0.55rem 0;
 width: 100%;
 text-align: center;
 border-top: 2px solid var(--brass);
 letter-spacing: 0.04em;
 }

 .step-connector {
 flex: 1;
 width: 1px;
 background: var(--line-2);
 margin-top: 0.35rem;
 min-height: 1rem;
 }
 .step:last-child .step-connector { display: none; }

 .step-content { padding-top: 0.1rem; }

 .step-pillar {
 display: inline-flex;
 align-items: center;
 gap: 0.45rem;
 font-family: var(--mono);
 font-size: 0.7rem;
 font-weight: 500;
 text-transform: uppercase;
 letter-spacing: 0.12em;
 margin-bottom: 0.55rem;
 }
 .step-dot {
 width: 7px;
 height: 7px;
 border-radius: var(--radius-sm);
 flex-shrink: 0;
 }

 .step-title {
 font-family: var(--serif);
 font-weight: 500;
 font-size: 1.4rem;
 color: var(--ink);
 line-height: 1.25;
 letter-spacing: -0.01em;
 margin-bottom: 0.65rem;
 }

 .step-desc {
 font-size: 0.95rem;
 color: var(--body);
 line-height: 1.7;
 margin-bottom: 1.1rem;
 max-width: 42rem;
 }

 .step-articles { display: flex; flex-direction: column; gap: 0.4rem; }

 .step-article-link {
 display: flex;
 align-items: center;
 gap: 0.6rem;
 font-family: var(--sans);
 font-size: 0.9rem;
 font-weight: 500;
 color: var(--link);
 padding: 0.6rem 0.85rem;
 background: var(--surface);
 border: 1px solid var(--line);
 border-radius: var(--radius);
 box-shadow: var(--shadow-sm);
 transition: border-color 0.15s, color 0.15s, transform 0.15s;
 text-decoration: none;
 }
 .step-article-link:hover {
 border-color: var(--line-2);
 color: var(--link-h);
 transform: translateY(-1px);
 }
 .article-icon {
 font-family: var(--mono);
 font-size: 0.8rem;
 color: var(--brass);
 flex-shrink: 0;
 }

 /* ── Next track CTA ── */
 .next-track {
 background: var(--paper-2);
 border: 1px solid var(--line);
 border-left: 3px solid var(--navy);
 border-radius: var(--radius);
 padding: 2.25rem 2rem;
 }

 .next-inner {
 display: flex;
 justify-content: space-between;
 align-items: center;
 gap: 2rem;
 }

 .next-copy h2 {
 font-family: var(--serif);
 font-weight: 500;
 font-size: 1.4rem;
 color: var(--ink);
 margin-bottom: 0.5rem;
 letter-spacing: -0.01em;
 }
 .next-copy p {
 font-size: 0.92rem;
 color: var(--body);
 line-height: 1.65;
 max-width: 34rem;
 }

 .btn-primary { white-space: nowrap; flex-shrink: 0; }

 @media (max-width: 600px) {
 .track-shell { padding-top: 2.75rem; }
 .step { grid-template-columns: 1fr; gap: 0.75rem; }
 .step-rail { flex-direction: row; align-items: center; gap: 0.75rem; }
 .step-num { width: auto; padding: 0.35rem 0; border-top: none; border-bottom: 2px solid var(--brass); }
 .step-connector { display: none; }
 .next-inner { flex-direction: column; align-items: flex-start; }
 }
</style>
