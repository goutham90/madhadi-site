---
import Layout from '../../layouts/Layout.astro';

const steps = [
 {
 num: '01',
 title: 'What is GMP, and why does it exist?',
 desc: 'Before learning the procedures, understand the foundation. What GMP actually requires, why it exists (the patient safety case), and how it connects to everything else in regulated manufacturing.',
 articles: [
 { title: 'What Is GMP? A Plain-Language Introduction', slug: 'what-is-gmp' },
 { title: 'Data Integrity Foundations: What It Is and Why Regulators Care', slug: 'data-integrity-foundations' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#7A2E23',
 },
 {
 num: '02',
 title: 'Who does what, GxP roles explained',
 desc: 'QA, QC, validation, regulatory affairs, clinical QA, DI. Understanding who owns what, how the functions interact, and where each role fits in the quality system is essential before you can work effectively in any of them.',
 articles: [
 { title: 'GxP Roles Explained: Who Does What', slug: 'gxp-roles-responsibilities' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#7A2E23',
 },
 {
 num: '03',
 title: 'The ALCOA+ principles, the language of DI',
 desc: 'ALCOA+ is cited in every data integrity document from every major regulatory agency. Understanding each principle, and the specific failure modes it addresses, gives you the vocabulary to diagnose any data integrity problem.',
 articles: [
 { title: 'ALCOA+: The Framework Behind Every Data Integrity Requirement', slug: 'alcoa-plus-deep-dive' },
 ],
 pillar: 'Data Integrity',
 pillarSlug: 'data-integrity',
 color: '#B26B1E',
 },
 {
 num: '04',
 title: 'The pharmaceutical quality system',
 desc: 'How QA, QC, validation, and data integrity actually fit together. Document control, deviations, CAPA, change control, these aren\'t separate systems. They\'re the interconnected fabric of the QMS.',
 articles: [
 { title: 'The Pharmaceutical Quality System: ICH Q10', slug: 'pharmaceutical-quality-system' },
 { title: 'Document Control Fundamentals', slug: 'document-control-fundamentals' },
 { title: 'What Is a Deviation?', slug: 'deviation-management' },
 { title: 'What Is a CAPA?', slug: 'what-is-a-capa' },
 ],
 pillar: 'Quality Assurance',
 pillarSlug: 'quality-assurance',
 color: '#7A2E23',
 },
 {
 num: '05',
 title: 'GxP computerized systems, the full set of systems',
 desc: 'LIMS, CDS, ELN, MES, EDMS, CTMS, EDC. Every system generates GxP data with specific validation and DI requirements. Understanding the full set is the prerequisite for understanding validation.',
 articles: [
 { title: 'GxP Computerized Systems: LIMS, CDS, ELN, MES and More', slug: 'gxp-systems-overview' },
 ],
 pillar: 'CSV & CSA',
 pillarSlug: 'csv-csa',
 color: '#3C6B4A',
 },
 {
 num: '06',
 title: 'Computer system validation, the basics',
 desc: 'GAMP 5 software categories, the V-model, IQ/OQ/PQ, risk-based testing. Understanding the validation framework is foundational for any quality or validation career.',
 articles: [
 { title: 'GAMP 5 Second Edition: The Framework for Risk-Based CSV', slug: 'gamp5-csv-framework' },
 { title: 'Validation Deliverables Guide: URS, FRS, IQ/OQ/PQ', slug: 'validation-deliverables-guide' },
 ],
 pillar: 'CSV & CSA',
 pillarSlug: 'csv-csa',
 color: '#3C6B4A',
 },
 {
 num: '07',
 title: 'Equipment qualification basics',
 desc: 'Why equipment must be qualified before GxP use, what DQ/IQ/OQ/PQ involves, and how calibration and qualification interact.',
 articles: [
 { title: 'Equipment Qualification: DQ/IQ/OQ/PQ Lifecycle', slug: 'equipment-qualification-lifecycle' },
 ],
 pillar: 'Equipment Qualification',
 pillarSlug: 'equipment-qualification',
 color: '#B26B1E',
 },
 {
 num: '08',
 title: 'How FDA inspections work, and what they find',
 desc: 'Understanding how FDA inspections are structured, what investigators look for, and what patterns show up in warning letters changes how you approach daily GxP practice.',
 articles: [
 { title: 'FDA Data Integrity Warning Letters: 8 Patterns That Repeat', slug: 'fda-warning-letters-patterns' },
 ],
 pillar: 'Audits & Inspection',
 pillarSlug: 'audits-inspection',
 color: '#B26B1E',
 },
 {
 num: '09',
 title: 'Career roadmap: how to build expertise',
 desc: 'Where to learn, what credentials matter, how to specialize, and what a realistic career trajectory in GxP quality and validation looks like.',
 articles: [
 { title: 'Breaking Into GxP: A Realistic Career Guide', slug: 'career-guide-gxp-validation' },
 { title: 'Breaking Into GxP Quality: A Practitioner\'s Roadmap', slug: 'breaking-into-gxp-quality' },
 ],
 pillar: 'Career',
 pillarSlug: null,
 color: '#756B5B',
 },
];

// New design-system accent for this track (Foundations → forest / Beginner tier)
const trackAccent = '#3C6B4A';

// Harmonized pillar accents (DESIGN_SPEC v2). Fall back to muted for the Career step (no pillarSlug).
const pillarAccents: Record<string, string> = {
 'data-integrity': '#B26B1E',
 'csv-csa': '#3C6B4A',
 'equipment-qualification': '#B26B1E',
 'quality-assurance': '#7A2E23',
 'audits-inspection': '#7A2E23',
 'cell-gene-therapy': '#3C6B4A',
 'manufacturing-automation': '#574F42',
 'ai-automation': '#7A2E23',
};
const accentFor = (slug: string | null) => (slug && pillarAccents[slug]) || '#756B5B';

// v3 ("The Record") tier color for the Beginner track.
const TIER_BEGINNER = '#3C6B4A';
---
<Layout title="Foundations Track" description="A sequenced reading path for GxP beginners, the regulatory map, ALCOA+, quality systems, CSV basics, and a career roadmap. Start here if you're new to pharma quality and validation." wide={true}>
 <!-- ═══════════ HEADER BAND (duotone) ═══════════ -->
 <header class="trk-hero duotone">
 <img src="/images/lab-beakers.jpg" alt="" loading="eager" />
 <div class="trk-hero-grad"></div>
 <div class="wrap trk-hero-inner">
 <a href="/tracks" class="trk-back">← Learning Tracks</a>
 <div class="trk-kick">
 <span class="kicker">Learning Track № 01</span>
 <span class="trk-kick-line" aria-hidden="true"></span>
 <span class="trk-kick-tier">
 <span class="tier-badge" style={`background:${TIER_BEGINNER}; color:#F7F3EA; border-color:${TIER_BEGINNER}`}>Beginner</span>
 </span>
 </div>
 <h1 class="trk-title">Breaking In: From Zero to Competent</h1>
 <p class="trk-standfirst">
 This track is for anyone starting a career in GxP quality, validation, or data integrity, or anyone who wants to understand the field before diving into the technical details. It covers the regulatory framework, core frameworks, and gives you a concrete roadmap for building expertise.
 </p>
 <div class="trk-hero-meta">
 <span class="trk-meta-pair"><span class="trk-meta-k">Steps</span><span class="trk-meta-v">{steps.length}</span></span>
 <span class="trk-meta-pair"><span class="trk-meta-k">Tier</span><span class="trk-meta-v">Beginner</span></span>
 <span class="trk-meta-pair"><span class="trk-meta-k">For</span><span class="trk-meta-v">Students · Career changers · New hires</span></span>
 </div>
 </div>
 </header>

 <div class="wrap trk-shell">
 <!-- ═══════════ SYLLABUS LEAD ═══════════ -->
 <div class="trk-lead-row">
 <div class="trk-lead-copy">
 <span class="kicker">The reading path</span>
 <h2 class="display-2">Nine steps, in order.</h2>
 </div>
 <p class="marginalia trk-lead-note">Each step is a checkpoint, not a chapter. Read it, understand it, then move on. The sequence is deliberate, every step assumes the one before it.</p>
 </div>

 <img class="trk-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />

 <!-- ═══════════ NUMBERED STEP SEQUENCE (editorial) ═══════════ -->
 <ol class="steps">
 {steps.map(step => {
 const accent = accentFor(step.pillarSlug);
 return (
 <li class="step">
 <div class="step-rail">
 <div class="step-num">{step.num}</div>
 <div class="step-connector" aria-hidden="true"></div>
 </div>
 <div class="step-content">
 <div class="step-pillar">
 {step.pillarSlug && (
 <span class="step-emblem emblem" style={`--src:url('/brand/emblems/pillar-${step.pillarSlug}.svg')`}></span>
 )}
 <span class="step-pillar-label">{step.pillar}</span>
 </div>
 <h3 class="step-title">{step.title}</h3>
 <p class="step-desc">{step.desc}</p>
 <ul class="step-articles">
 {step.articles.map(a => (
 <li>
 <a href={`/articles/${a.slug}`} class="step-article-link">
 <span class="article-icon" aria-hidden="true">→</span>
 <span class="article-title">{a.title}</span>
 </a>
 </li>
 ))}
 </ul>
 </div>
 </li>
 );
 })}
 </ol>
 </div>

 <!-- ═══════════ CONTINUE → NEXT TRACK (dark plate) ═══════════ -->
 <section class="section section-dark next-track">
 <img class="next-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 <div class="wrap next-inner">
 <div class="next-copy">
 <span class="kicker">When you're ready</span>
 <h2 class="next-h2">Continue to the Implementation Track</h2>
 <p>Once you have the foundations, the Implementation track takes you into execution: how to actually run validations, design audit trails, and manage GxP systems in practice.</p>
 </div>
 <a href="/tracks/implementation" class="btn-accent next-cta">Implementation Track →</a>
 </div>
 </section>
</Layout>

<style>
 /* ════════════ HEADER BAND ════════════ */
 .trk-hero { position: relative; min-height: 56vh; display: flex; align-items: flex-end; border-bottom: 3px solid var(--vermilion); }
 .trk-hero > img { position: absolute; inset: 0; }
 .trk-hero-grad { position: absolute; inset: 0; z-index: 2; background: linear-gradient(180deg, rgba(22,19,13,0.18) 0%, rgba(22,19,13,0.4) 48%, rgba(22,19,13,0.88) 100%); }
 .trk-hero-inner { position: relative; z-index: 3; padding-top: 4.5rem; padding-bottom: 3rem; }

 .trk-back {
 font-family: var(--mono); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.06em;
 text-transform: uppercase; color: var(--on-ink-dim); display: inline-block; margin-bottom: 1.5rem;
 transition: color 0.15s;
 }
 .trk-back:hover { color: var(--on-ink); }

 .trk-kick { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.25rem; }
 .trk-kick .kicker { color: var(--vermilion); }
 .trk-kick-line { flex: 0 1 70px; height: 1px; background: var(--line-ink); }

 .trk-title {
 font-family: var(--display); font-weight: 500; color: var(--on-ink);
 font-size: clamp(2.2rem, 5vw, 4rem); line-height: 1.0; letter-spacing: -0.025em;
 max-width: 18ch; margin-bottom: 1.25rem;
 }
 .trk-standfirst {
 font-family: var(--display); font-style: italic; font-weight: 400; color: var(--on-ink-dim);
 font-size: clamp(1.1rem, 1.9vw, 1.45rem); line-height: 1.45; max-width: 52ch; margin-bottom: 1.75rem;
 }

 .trk-hero-meta { display: flex; flex-wrap: wrap; gap: 1.5rem 2.5rem; border-top: 1px solid var(--line-ink); padding-top: 1.4rem; }
 .trk-meta-pair { display: flex; flex-direction: column; gap: 0.25rem; }
 .trk-meta-k { font-family: var(--mono); font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--vermilion); }
 .trk-meta-v { font-family: var(--mono); font-size: 0.8rem; color: var(--on-ink); letter-spacing: 0.02em; }

 /* ════════════ SHELL / LEAD ════════════ */
 .trk-shell { padding-top: 3.5rem; padding-bottom: 1rem; }

 .trk-lead-row { display: flex; justify-content: space-between; align-items: flex-end; gap: 2.5rem; margin-bottom: 2rem; }
 .trk-lead-copy .kicker { margin-bottom: 0.6rem; }
 .trk-lead-note { max-width: 24rem; text-align: right; }

 .trk-rule { display: block; width: 100%; height: 14px; color: var(--line); margin-bottom: 2.75rem; }

 /* ════════════ NUMBERED STEP SEQUENCE ════════════ */
 .steps { list-style: none; padding: 0; margin: 0 0 5rem; display: flex; flex-direction: column; }

 .step {
 display: grid;
 grid-template-columns: 64px 1fr;
 gap: 2rem;
 padding: 0 0 2.75rem;
 margin: 0;
 }
 .step:last-child { padding-bottom: 0; }

 .step-rail { display: flex; flex-direction: column; align-items: stretch; }

 .step-num {
 font-family: var(--mono);
 font-size: 1.05rem;
 font-weight: 700;
 color: var(--vermilion);
 line-height: 1;
 padding: 0.6rem 0;
 width: 100%;
 text-align: left;
 border-top: 2px solid var(--vermilion);
 letter-spacing: 0.04em;
 }

 .step-connector { flex: 1; width: 1px; background: var(--line); margin: 0.35rem 0 0 0; min-height: 1rem; }
 .step:last-child .step-connector { display: none; }

 .step-content { padding-top: 0.4rem; border-top: 1px solid var(--line); padding-bottom: 0.25rem; }

 .step-pillar { display: inline-flex; align-items: center; gap: 0.55rem; margin-bottom: 0.7rem; }
 .step-emblem { width: 20px; height: 20px; color: var(--vermilion); }
 .step-pillar-label {
 font-family: var(--mono); font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
 letter-spacing: 0.14em; color: var(--muted);
 }

 .step-title {
 font-family: var(--display); font-weight: 500; font-size: clamp(1.45rem, 2.4vw, 1.85rem);
 color: var(--ink); line-height: 1.12; letter-spacing: -0.015em; margin-bottom: 0.7rem; max-width: 22ch;
 }

 .step-desc { font-size: 0.98rem; color: var(--graphite); line-height: 1.7; margin-bottom: 1.25rem; max-width: 44rem; }

 .step-articles { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--line); }

 .step-article-link {
 display: flex; align-items: baseline; gap: 0.7rem;
 font-family: var(--sans); font-size: 0.95rem; font-weight: 500; color: var(--graphite);
 padding: 0.7rem 0; border-bottom: 1px solid var(--line);
 transition: color 0.15s, padding-left 0.15s;
 }
 .step-article-link:hover { color: var(--vermilion-2); padding-left: 0.5rem; }
 .article-icon { font-family: var(--mono); font-size: 0.85rem; color: var(--vermilion); flex-shrink: 0; }
 .article-title { line-height: 1.35; }

 /* ════════════ NEXT TRACK (dark plate) ════════════ */
 .next-track { position: relative; overflow: hidden; border-top: 3px solid var(--vermilion); }
 .next-seal { position: absolute; right: -56px; top: 50%; transform: translateY(-50%); width: 260px; color: rgba(236,230,216,0.05); pointer-events: none; }
 .next-inner { display: flex; justify-content: space-between; align-items: center; gap: 2.5rem; position: relative; z-index: 2; }
 .next-copy .kicker { margin-bottom: 0.85rem; }
 .next-h2 { font-family: var(--display); font-weight: 500; font-size: clamp(1.7rem, 3vw, 2.5rem); color: var(--on-ink); line-height: 1.06; letter-spacing: -0.02em; margin-bottom: 0.75rem; }
 .next-copy p { font-size: 1rem; color: var(--on-ink-dim); line-height: 1.65; max-width: 38rem; }
 .next-cta { white-space: nowrap; flex-shrink: 0; }

 /* ════════════ RESPONSIVE ════════════ */
 @media (max-width: 900px) {
 .trk-hero { min-height: 48vh; }
 .trk-lead-row { flex-direction: column; align-items: flex-start; gap: 1rem; }
 .trk-lead-note { text-align: left; }
 .next-inner { flex-direction: column; align-items: flex-start; gap: 1.75rem; }
 }
 @media (max-width: 600px) {
 .trk-shell { padding-top: 2.5rem; }
 .step { grid-template-columns: 1fr; gap: 0.85rem; }
 .step-rail { flex-direction: row; align-items: center; gap: 0.85rem; }
 .step-num { width: auto; padding: 0.4rem 0; border-top: none; border-bottom: 2px solid var(--vermilion); }
 .step-connector { display: none; }
 .step-content { border-top: none; padding-top: 0; }
 .trk-hero-meta { gap: 1rem 1.75rem; }
 }
</style>
