---
import Layout from '../layouts/Layout.astro';

const sources = [
 {
 jurisdiction: 'United States, FDA',
 color: 'var(--vermilion)',
 items: [
 {
 title: '21 CFR Part 11, Electronic Records; Electronic Signatures',
 type: 'Regulation',
 year: '1997 (amended)',
 what: 'Governs when electronic records may be used in place of paper records under FDA GxP regulations, and the requirements for electronic signatures. Audit trails, system validation, access controls, and signature authentication are the core requirements.',
 applies: ['CSV/CSA', 'Data Integrity', 'All GxP'],
 url: 'https://www.ecfr.gov/current/title-21/chapter-I/subchapter-A/part-11',
 },
 {
 title: '21 CFR Part 211, Current Good Manufacturing Practice for Finished Pharmaceuticals',
 type: 'Regulation',
 year: 'Current',
 what: 'The GMP regulation for finished drug products. Relevant sections for DI and CSV: §211.68 (automatic, mechanical, electronic equipment), §211.180 (general records retention), §211.188 (batch production records), §211.194 (laboratory records).',
 applies: ['GMP', 'Data Integrity', 'Manufacturing', 'Laboratory'],
 url: 'https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-211',
 },
 {
 title: '21 CFR Part 210, cGMP in Manufacturing, Processing, Packing, or Holding of Drugs',
 type: 'Regulation',
 year: 'Current',
 what: 'Companion regulation to Part 211. Sets out the definitions and scope of GMP requirements.',
 applies: ['GMP'],
 url: 'https://www.ecfr.gov/current/title-21/chapter-I/subchapter-C/part-210',
 },
 {
 title: 'FDA Guidance: Data Integrity and Compliance With Drug CGMP, Questions and Answers',
 type: 'Guidance',
 year: 'December 2018',
 what: 'The primary FDA guidance on data integrity. Covers ALCOA+ definitions, audit trails, backup, metadata, original records, raw data, true copies, hybrid records, shared accounts, computer access controls, and the "data integrity framework." Referenced in nearly every DI inspection.',
 applies: ['Data Integrity', 'All GxP'],
 url: 'https://www.fda.gov/media/119267/download',
 },
 {
 title: 'FDA Guidance: Guidance for Industry: Part 11, Electronic Records; Electronic Signatures, Scope and Application',
 type: 'Guidance',
 year: 'August 2003',
 what: 'Clarifies when Part 11 applies and FDA\'s risk-based enforcement approach. Introduced the "predicate rule" concept, Part 11 requirements apply when electronic records are used under predicate regulations (Part 211, Part 58, etc.).',
 applies: ['CSV/CSA', '21 CFR Part 11'],
 url: 'https://www.fda.gov/media/75414/download',
 },
 {
 title: 'FDA Guidance: Computer Software Assurance for Production and Quality System Software',
 type: 'Guidance',
 year: 'Finalized February 2026',
 what: 'Introduces the FDA\'s CSA approach: risk-based, intended-use focused, emphasizing critical thinking over documentation volume. Applies to software used for production and quality activities. Supplements but does not replace GAMP 5.',
 applies: ['CSV/CSA'],
 url: 'https://www.fda.gov/regulatory-information/search-fda-guidance-documents/computer-software-assurance-production-and-quality-system-software',
 },
 {
 title: 'FDA Guidance: Process Validation: General Principles and Practices',
 type: 'Guidance',
 year: 'January 2011',
 what: 'Defines the three-stage process validation lifecycle (Process Design, PPQ, Continued Process Verification). The current FDA framework for pharmaceutical manufacturing validation.',
 applies: ['Process Validation', 'Manufacturing'],
 url: 'https://www.fda.gov/media/71021/download',
 },
 {
 title: 'FDA Guidance: Investigating Out-of-Specification (OOS) Test Results for Pharmaceutical Production',
 type: 'Guidance',
 year: 'October 2006',
 what: 'The step-by-step FDA framework for OOS investigations: Phase I laboratory investigation, Phase II full investigation, invalidation criteria, and reporting requirements.',
 applies: ['Laboratory', 'QMS'],
 url: 'https://www.fda.gov/media/72704/download',
 },
 {
 title: 'FDA Guidance: Submission of Electronic Records in Regulatory Submissions',
 type: 'Guidance',
 year: 'Various',
 what: 'Guidance on electronic submissions to FDA, electronic record standards, and eCTD format. Relevant to BLA/NDA submissions and data packages.',
 applies: ['Submissions', 'Clinical Systems'],
 url: 'https://www.fda.gov/regulatory-information/search-fda-guidance-documents?search_api_fulltext=electronic+records+regulatory+submissions&field_center_bereaved_target_id_entityreference_filter=All&sort_by=rel&items_per_page=10',
 },
 ],
 },
 {
 jurisdiction: 'European Union, EMA / EudraLex',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'EudraLex Volume 4, EU Guidelines for Good Manufacturing Practice, Annex 11: Computerised Systems',
 type: 'Regulation / Guidance',
 year: '2011 (under review)',
 what: 'EU GMP requirements for computerized systems in pharmaceutical manufacturing. Covers validation, audit trails, data storage, backup and recovery, access controls, incident management, periodic review, and electronic signatures. The European counterpart to 21 CFR Part 11.',
 applies: ['CSV/CSA', 'Data Integrity', 'Manufacturing'],
 url: 'https://health.ec.europa.eu/system/files/2016-11/annex11_01-2011_en_0.pdf',
 },
 {
 title: 'EudraLex Volume 4, EU GMP Annex 15: Qualification and Validation',
 type: 'Regulation / Guidance',
 year: '2015',
 what: 'EU GMP requirements for the qualification lifecycle (DQ, IQ, OQ, PQ), process validation, cleaning validation, change control, and revalidation. The foundational EU document for the validation lifecycle.',
 applies: ['Qualification', 'Validation', 'Process Validation'],
 url: 'https://health.ec.europa.eu/system/files/2016-11/2015-10_annex15_0.pdf',
 },
 {
 title: 'EudraLex Volume 4, EU GMP Chapter 4: Documentation',
 type: 'Regulation',
 year: 'Current',
 what: 'EU GMP documentation requirements: data integrity requirements for paper and electronic records, retention, document control, and the definition of original records and true copies.',
 applies: ['Data Integrity', 'Documentation', 'GMP'],
 url: 'https://health.ec.europa.eu/system/files/2016-11/chapter4_0.pdf',
 },
 {
 title: 'EudraLex Volume 4, EU GMP Part II: Basic Requirements for Active Substances Used as Starting Materials',
 type: 'Regulation',
 year: 'Current',
 what: 'ICH Q7 implemented as EU GMP Part II. Covers API manufacturing with the same data integrity and documentation requirements as finished product manufacturing.',
 applies: ['API', 'Data Integrity', 'Manufacturing'],
 url: 'https://health.ec.europa.eu/system/files/2016-11/2014-08_gmp_part-ii_en_0.pdf',
 },
 ],
 },
 {
 jurisdiction: 'MHRA (UK)',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'MHRA GxP Data Integrity Guidance and Definitions',
 type: 'Guidance',
 year: 'March 2018',
 what: 'One of the most specific and detailed DI guidances available. Covers ALCOA+ in depth, shared accounts, audit trail review, backup, hybrid records, management responsibilities, and what inspectors look for. Widely used alongside FDA guidance even outside UK.',
 applies: ['Data Integrity', 'All GxP'],
 url: 'https://www.gov.uk/government/publications/gxp-data-integrity-guidance-and-definitions',
 },
 ],
 },
 {
 jurisdiction: 'ICH, International Council for Harmonisation',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'ICH Q10, Pharmaceutical Quality System',
 type: 'Guideline',
 year: '2008',
 what: 'Describes a model pharmaceutical quality system applicable across the product lifecycle. Covers quality manual, knowledge management, quality risk management, process performance and product quality monitoring, and CAPA system requirements.',
 applies: ['QMS', 'Quality Assurance'],
 url: 'https://www.ich.org/products/guidelines/quality/quality-single/article/pharmaceutical-quality-system.html',
 },
 {
 title: 'ICH Q9(R1), Quality Risk Management',
 type: 'Guideline',
 year: '2023 (Revision 1)',
 what: 'Provides principles and tools for quality risk management across the pharmaceutical lifecycle. Tools include FMEA, HACCP, and risk ranking/filtering. R1 revision added guidance on subjectivity and human error in risk assessment.',
 applies: ['QRM', 'Validation', 'All GxP'],
 url: 'https://www.ich.org/products/guidelines/quality/quality-single/article/quality-risk-management.html',
 },
 {
 title: 'ICH Q2(R2), Validation of Analytical Procedures',
 type: 'Guideline',
 year: '2022 (Revision 2)',
 what: 'Current ICH guideline on method validation parameters: specificity, linearity, range, accuracy, precision, detection limit, quantitation limit, and robustness. R2 updated to address lifecycle approach and modern analytical technologies.',
 applies: ['Method Validation', 'Analytical', 'Laboratory'],
 url: 'https://www.ich.org/products/guidelines/quality/quality-single/article/validation-of-analytical-procedures-text-and-methodology.html',
 },
 {
 title: 'ICH E6(R3), Good Clinical Practice',
 type: 'Guideline',
 year: '2024 (draft/finalization)',
 what: 'International standard for designing, conducting, recording, and reporting clinical trials. R3 revision adds risk-based monitoring, electronic records, and proportional oversight principles.',
 applies: ['GCP', 'Clinical Systems'],
 url: 'https://www.ich.org/products/guidelines/efficacy/efficacy-single/article/good-clinical-practice.html',
 },
 ],
 },
 {
 jurisdiction: 'PIC/S, Pharmaceutical Inspection Co-operation Scheme',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'PIC/S PI 041-1, Good Practices for Data Management and Integrity in Regulated GMP/GDP Environments',
 type: 'Guidance',
 year: 'Current version',
 what: 'Comprehensive PIC/S guidance on data management and data integrity. Covers the data governance framework, risk-based approach to DI, ALCOA+ application, computerized systems, paper systems, hybrid systems, and expectations for quality culture. Widely cited alongside FDA and MHRA guidance.',
 applies: ['Data Integrity', 'All GxP'],
 url: 'https://picscheme.org/docserver/publicdocs/PI_041_1.pdf',
 },
 ],
 },
 {
 jurisdiction: 'WHO, World Health Organization',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'WHO TRS 996 Annex 5, Guidance on Good Data and Record Management Practices',
 type: 'Guidance',
 year: '2016',
 what: 'WHO guidance on data and record management. Covers data lifecycle, ALCOA principles, computerized systems, data integrity culture, and the responsibilities of management. Widely used as a reference in developing country regulatory contexts.',
 applies: ['Data Integrity', 'All GxP'],
 url: 'https://apps.who.int/iris/bitstream/handle/10665/249001/9789241209922-eng.pdf',
 },
 ],
 },
 {
 jurisdiction: 'ISPE / GAMP',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'GAMP 5: A Risk-Based Approach to Compliant GxP Computerized Systems, Second Edition',
 type: 'Industry Standard',
 year: '2022',
 what: 'The industry standard framework for GxP computerized system validation. Covers software categorization (Categories 1-5), validation lifecycle, supplier assessment, testing strategies, cloud systems, data integrity, and change control. Published by ISPE. Copyright protected, reference by concept only.',
 applies: ['CSV/CSA', 'All Systems'],
 url: 'https://ispe.org/publications/guidance-documents/gamp-5',
 },
 {
 title: 'ISPE Baseline Guide: Commissioning and Qualification, Second Edition',
 type: 'Industry Guidance',
 year: '2019',
 what: 'ISPE framework for equipment and facility qualification (IQ/OQ/PQ). Covers the lifecycle approach, risk-based qualification, DQ, IQ, OQ, PQ, and integration with process validation. Referenced in EU Annex 15 context.',
 applies: ['Equipment Qualification', 'Facilities'],
 url: 'https://ispe.org/publications/guidance-documents/commissioning-and-qualification-baseline-guide',
 },
 ],
 },
 {
 jurisdiction: 'USP, US Pharmacopeia',
 color: 'var(--vermilion)',
 items: [
 {
 title: 'USP <1058>, Analytical Instrument Qualification',
 type: 'Compendial Standard',
 year: 'Current edition',
 what: 'USP general chapter on the qualification of analytical instruments. Defines four groups of instruments by complexity and sets out qualification activities for each group. Group A (simple), Group B (instruments with measurable performance characteristics), Group C (complex computerized systems).',
 applies: ['Analytical Instruments', 'Equipment Qualification', 'Laboratory'],
 url: 'https://www.usp.org',
 },
 ],
 },
];

const totalRefs = sources.reduce((n, s) => n + s.items.length, 0);
---
<Layout
 title="Regulatory References"
 description="Curated index of FDA, EMA, MHRA, ICH, PIC/S, WHO, and ISPE guidance for GxP quality, data integrity, CSV, and inspection readiness professionals."
 wide={true}
>
 <!-- ═══════════ MASTHEAD (dark, image-led) ═══════════ -->
 <section class="reg-masthead section-dark duotone">
 <img class="reg-masthead-img" src="/images/records-review.jpg" alt="" loading="eager" />
 <div class="reg-masthead-grad"></div>
 <div class="wrap reg-masthead-inner">
 <div class="reg-mast-grid">
 <div>
 <div class="reg-kick">
 <span class="kicker">Reference Index</span>
 <span class="reg-kick-line"></span>
 <span class="marginalia reg-kick-note">The source register</span>
 </div>
 <h1 class="reg-title">Regulatory References</h1>
 <p class="lead reg-lead">
 Curated index of primary regulatory sources for GxP quality, data integrity, computer system validation,
 equipment qualification, and inspection readiness. Organized by jurisdiction.
 Links go to official sources where available.
 </p>
 <div class="reg-stats">
 <div class="reg-stat"><span class="reg-stat-n">{totalRefs}</span><span class="reg-stat-l">Sources</span></div>
 <div class="reg-stat"><span class="reg-stat-n">{String(sources.length).padStart(2, '0')}</span><span class="reg-stat-l">Bodies</span></div>
 <div class="reg-stat"><span class="reg-stat-n">PD</span><span class="reg-stat-l">Public sources</span></div>
 </div>
 </div>
 <img class="reg-mast-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 </div>
 </div>
 </section>

 <!-- ═══════════ DISCLAIMER + REGISTER NAV ═══════════ -->
 <section class="section-tight reg-orient">
 <div class="wrap reg-orient-grid">
 <div class="callout reg-disclaimer">
 <div class="callout-title">Use primary sources</div>
 <p>This index is a navigation aid, not a substitute for reading the actual documents. Regulatory guidance is updated, always check the current version at the official source. Links are provided for reference; verify currency before citing in quality documentation.</p>
 </div>
 <nav class="reg-register" aria-label="Jump to jurisdiction">
 <div class="reg-register-label marginalia">The register · jump to a body</div>
 {sources.map((s, i) => (
 <a
 href={`#${s.jurisdiction.replace(/[^a-zA-Z]/g, '-').toLowerCase()}`}
 class="reg-register-row"
 style={`--accent-color: ${s.color}`}
 >
 <span class="reg-register-num">{String(i + 1).padStart(2, '0')}</span>
 <span class="reg-register-name">{s.jurisdiction.split(', ')[0]}</span>
 <span class="reg-register-count">{s.items.length}</span>
 </a>
 ))}
 </nav>
 </div>
 </section>

 <img class="reg-rule" src="/brand/ticks-rule.svg" alt="" aria-hidden="true" />

 <!-- ═══════════ SOURCES BY JURISDICTION (editorial register) ═══════════ -->
 <section class="section-tight reg-sources">
 <div class="wrap">
 <div class="sources-list">
 {sources.map((s, si) => (
 <section class="jurisdiction-section" id={s.jurisdiction.replace(/[^a-zA-Z]/g, '-').toLowerCase()} style={`--accent-color: ${s.color}`}>
 <div class="jurisdiction-header">
 <span class="jurisdiction-num">{String(si + 1).padStart(2, '0')}</span>
 <div class="jurisdiction-headtext">
 <div class="jurisdiction-eyebrow">Source · {s.items.length} {s.items.length === 1 ? 'document' : 'documents'}</div>
 <h2 class="jurisdiction-name">{s.jurisdiction}</h2>
 </div>
 </div>
 <ol class="refs-register">
 {s.items.map((item, ii) => (
 <li class="ref-row">
 <span class="ref-num">{String(si + 1).padStart(2, '0')}.{String(ii + 1).padStart(2, '0')}</span>
 <div class="ref-main">
 <div class="ref-meta-top">
 <span class="ref-type-badge">{item.type}</span>
 <span class="ref-year">{item.year}</span>
 </div>
 <h3 class="ref-title">{item.title}</h3>
 <p class="ref-what">{item.what}</p>
 <div class="ref-footer">
 <div class="ref-applies">
 {item.applies.map(a => <span class="tag applies-tag">{a}</span>)}
 </div>
 {item.url && (
 <a href={item.url} target="_blank" rel="noopener noreferrer" class="ref-link">
 View source →
 </a>
 )}
 </div>
 </div>
 </li>
 ))}
 </ol>
 </section>
 ))}
 </div>
 </div>
 </section>

 <!-- ═══════════ CLOSING, HOW TO USE (featured editorial) ═══════════ -->
 <section class="section reg-closing section-dark">
 <div class="wrap reg-closing-grid">
 <div class="reg-closing-aside">
 <span class="kicker">Orientation</span>
 <img class="reg-closing-seal seal" src="/brand/seal.svg" alt="" aria-hidden="true" />
 </div>
 <div class="reg-closing-body">
 <h3 class="reg-closing-h">How to use this index</h3>
 <p>These sources are the primary regulatory basis for the content on this site. When an article makes a regulatory claim, it references one of these documents. Reading the primary sources, even selectively, is the most effective way to build regulatory knowledge that holds up under scrutiny in an inspection room.</p>
 <p>For most GxP professionals, five documents cover 80% of the regulatory framework: <strong>FDA DI Q&amp;A (2018)</strong>, <strong>MHRA DI Guidance (2018)</strong>, <strong>21 CFR Part 11</strong>, <strong>Annex 11</strong>, and <strong>GAMP 5 Second Edition</strong>. Start there.</p>
 </div>
 </div>
 </section>
</Layout>

<style>
 /* ════════════ MASTHEAD (dark, image-led) ════════════ */
 .reg-masthead {
 position: relative;
 border-bottom: 3px solid var(--vermilion);
 overflow: hidden;
 }
 .reg-masthead-img {
 position: absolute; inset: 0;
 width: 100%; height: 100%; object-fit: cover;
 }
 .reg-masthead-grad {
 position: absolute; inset: 0; z-index: 2;
 background: linear-gradient(150deg, rgba(22,19,13,0.78) 0%, rgba(22,19,13,0.7) 45%, rgba(122,46,35,0.62) 100%);
 }
 .reg-masthead-inner { position: relative; z-index: 3; padding: 5.5rem 0 4rem; }
 .reg-mast-grid { display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center; }

 .reg-kick { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.5rem; }
 .reg-kick-line { flex: 0 0 auto; width: 80px; height: 1px; background: var(--line-ink); }
 .reg-kick-note { color: var(--on-ink-dim); }

 .reg-title {
 font-family: var(--display); font-weight: 500; color: var(--on-ink);
 font-size: clamp(2.6rem, 6vw, 4.6rem); line-height: 0.98; letter-spacing: -0.03em;
 margin-bottom: 1.4rem;
 }
 .reg-lead { color: var(--on-ink-dim); max-width: 44rem; margin-bottom: 2rem; }

 .reg-stats { display: flex; gap: 2.5rem; border-top: 1px solid var(--line-ink); padding-top: 1.5rem; }
 .reg-stat { display: flex; flex-direction: column; gap: 0.2rem; }
 .reg-stat-n { font-family: var(--display); font-size: 2rem; font-weight: 500; color: var(--on-ink); line-height: 1; }
 .reg-stat-l { font-family: var(--mono); font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--vermilion); }

 .reg-mast-seal { width: 150px; color: var(--vermilion); opacity: 0.92; flex-shrink: 0; }

 /* ════════════ ORIENT: disclaimer + register ════════════ */
 .reg-orient-grid {
 display: grid; grid-template-columns: 1fr 0.85fr; gap: 3.5rem; align-items: start;
 }
 .reg-disclaimer { margin: 0; }

 .reg-register { border-top: 2px solid var(--ink); }
 .reg-register-label { padding: 0.9rem 0 1rem; border-bottom: 1px solid var(--line); }
 .reg-register-row {
 display: grid; grid-template-columns: 2.5rem 1fr auto; gap: 1rem; align-items: baseline;
 padding: 0.85rem 0; border-bottom: 1px solid var(--line); color: var(--graphite);
 transition: padding-left 0.15s, color 0.15s;
 }
 .reg-register-row:hover { padding-left: 0.5rem; color: var(--ink); }
 .reg-register-num { font-family: var(--mono); font-size: 0.74rem; color: var(--accent-color, var(--vermilion)); }
 .reg-register-name { font-family: var(--display); font-size: 1.15rem; font-weight: 500; color: var(--ink); line-height: 1.1; }
 .reg-register-row:hover .reg-register-name { color: var(--vermilion-2); }
 .reg-register-count { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); }

 .reg-rule { display: block; width: 100%; height: 14px; color: var(--line); margin: 0.5rem 0 1rem; }

 /* ════════════ SOURCES BY JURISDICTION ════════════ */
 .sources-list { display: flex; flex-direction: column; gap: 4.5rem; }

 .jurisdiction-header {
 display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; align-items: baseline;
 padding-bottom: 1.4rem; margin-bottom: 1.75rem; border-bottom: 2px solid var(--ink);
 }
 .jurisdiction-num {
 font-family: var(--display); font-weight: 500; font-size: clamp(2.4rem, 4vw, 3.4rem);
 line-height: 0.9; color: var(--accent-color, var(--vermilion)); letter-spacing: -0.02em;
 }
 .jurisdiction-eyebrow {
 font-family: var(--mono); font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
 letter-spacing: 0.16em; color: var(--vermilion); margin-bottom: 0.55rem;
 }
 .jurisdiction-name {
 font-family: var(--display); font-weight: 500; color: var(--ink);
 font-size: clamp(1.5rem, 2.8vw, 2.2rem); letter-spacing: -0.02em; line-height: 1.08;
 }

 /* ── Reference register rows (NOT cards) ── */
 .refs-register { list-style: none; padding: 0; margin: 0; }
 .ref-row {
 display: grid; grid-template-columns: 5rem 1fr; gap: 1.75rem; align-items: start;
 padding: 1.85rem 0; border-bottom: 1px solid var(--line);
 transition: padding-left 0.15s;
 }
 .ref-row:first-child { border-top: 1px solid var(--line); }
 .ref-row:hover { padding-left: 0.6rem; }

 .ref-num {
 font-family: var(--mono); font-size: 0.82rem; color: var(--accent-color, var(--vermilion));
 padding-top: 0.3rem; letter-spacing: 0.02em;
 }

 .ref-main { min-width: 0; }
 .ref-meta-top { display: flex; align-items: center; gap: 0.7rem; margin-bottom: 0.7rem; }
 .ref-type-badge {
 font-family: var(--mono); font-size: 0.64rem; font-weight: 700; text-transform: uppercase;
 letter-spacing: 0.08em; padding: 0.18rem 0.5rem; border-radius: var(--radius);
 background: var(--bone-2); border: 1px solid var(--line); color: var(--graphite);
 }
 .ref-year { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); letter-spacing: 0.02em; }

 .ref-title {
 font-family: var(--display); font-weight: 500; font-size: clamp(1.2rem, 2vw, 1.5rem);
 color: var(--ink); line-height: 1.2; letter-spacing: -0.015em; margin-bottom: 0.6rem;
 max-width: 52ch;
 }
 .ref-row:hover .ref-title { color: var(--vermilion-2); }

 .ref-what {
 font-family: var(--sans); font-size: 0.95rem; color: var(--graphite);
 line-height: 1.65; margin-bottom: 1rem; max-width: 68ch;
 }

 .ref-footer {
 display: flex; align-items: center; justify-content: space-between; gap: 1rem;
 flex-wrap: wrap;
 }
 .ref-applies { display: flex; flex-wrap: wrap; gap: 0.4rem; }
 .applies-tag { font-size: 0.62rem; padding: 0.14rem 0.45rem; }

 .ref-link {
 font-family: var(--mono); font-size: 0.74rem; font-weight: 700; text-transform: uppercase;
 letter-spacing: 0.04em; color: var(--vermilion-2); white-space: nowrap; flex-shrink: 0;
 transition: color 0.15s;
 }
 .ref-link:hover { color: var(--ink); }

 /* ════════════ CLOSING (dark featured) ════════════ */
 .reg-closing { border-top: 3px solid var(--vermilion); }
 .reg-closing-grid { display: grid; grid-template-columns: 0.4fr 1fr; gap: 3.5rem; align-items: start; }
 .reg-closing-aside { display: flex; flex-direction: column; gap: 1.5rem; }
 .reg-closing-seal { width: 110px; color: var(--vermilion); }
 .reg-closing-h {
 font-family: var(--display); font-weight: 500; color: var(--on-ink);
 font-size: clamp(1.8rem, 3.4vw, 2.7rem); line-height: 1.05; letter-spacing: -0.02em;
 margin-bottom: 1.4rem; max-width: 18ch;
 }
 .reg-closing-body p { font-size: 1.05rem; color: var(--on-ink-dim); line-height: 1.7; margin-bottom: 1.1rem; max-width: 60ch; }
 .reg-closing-body p:last-child { margin-bottom: 0; }

 /* ════════════ RESPONSIVE ════════════ */
 @media (max-width: 900px) {
