---
import { getCollection } from 'astro:content';
import TemplateLayout from '../../layouts/TemplateLayout.astro';

export async function getStaticPaths() {
  const templates = await getCollection('templates', ({ data }) => !data.draft);
  const articles = await getCollection('articles', ({ data }) => !data.draft);
  const titleBySlug = Object.fromEntries(articles.map((a) => [a.slug, a.data.title]));
  return templates.map((entry) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      related: (entry.data.relatedArticles ?? [])
        .filter((s) => titleBySlug[s])
        .map((s) => ({ slug: s, title: titleBySlug[s] })),
    },
  }));
}

const { entry, related } = Astro.props;
const { Content } = await entry.render();
---
<TemplateLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  docType={entry.data.docType}
  pillar={entry.data.pillar}
  tags={entry.data.tags}
  tier={entry.data.tier}
  relatedArticles={related}
>
  <Content />
</TemplateLayout>
