---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { pillarBySlug } from '../../data/pillars';

const templates = await getCollection('templates', ({ data }) => !data.draft);
const sorted = templates.sort((a, b) => a.data.title.localeCompare(b.data.title));

// group by document type
const byType: Record<string, typeof sorted> = {};
for (const t of sorted) {
  (byType[t.data.docType] ??= []).push(t);
}
const typeOrder = ['SOP', 'Policy', 'Work Instruction', 'Protocol', 'Plan', 'Specification',
  'Risk Assessment', 'Matrix', 'Checklist', 'Form', 'Log', 'Report', 'Record', 'Template', 'Guideline'];
const types = Object.keys(byType).sort((a, b) => {
  const ia = typeOrder.indexOf(a), ib = typeOrder.indexOf(b);
  return (ia < 0 ? 99 : ia) - (ib < 0 ? 99 : ib);
});
const pillarName = (s: string) => pillarBySlug(s)?.short ?? s;
---
<Layout title="Templates & Procedures" description="Plug-and-play, inspection-grade SOPs, policies, procedures, work instructions, protocols, forms, logs, checklists, and risk assessments for GxP quality across biotech, pharma, medical devices, and life sciences. Copy, fill in your specifics, and use." wide={true}>
  <section class="tl-header">
    <div class="wrap">
      <div class="page-label">Templates & Procedures</div>
      <h1 class="tl-h1">Ready-to-use documents, not just explanations.</h1>
      <p class="lead">Plug-and-play SOPs, policies, procedures, work instructions, protocols, forms, logs, checklists, and risk assessments. Each one carries the full inspection-grade structure with placeholders for your company, system, and process, plus a worked filled-in specimen. Copy it, fill it in, route it through your own document control.</p>
      <div class="tl-stats">
        <span><strong>{templates.length}</strong> documents</span>
        <span><strong>{types.length}</strong> document types</span>
        <span>Free to copy and adapt</span>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="wrap">
      {templates.length === 0 && (
        <p class="tl-empty">The library is being built. New ready-to-use documents are added with the daily updates. Check back shortly.</p>
      )}
      {types.map((type) => (
        <div class="tl-group">
          <h2 class="tl-group-h">{type}<span class="tl-group-n">{byType[type].length}</span></h2>
          <ul class="tl-list">
            {byType[type].map((t) => (
              <li>
                <a href={`/templates/${t.slug}`} class="tl-row">
                  <div class="tl-row-main">
                    <span class="tl-row-title">{t.data.title}</span>
                    <span class="tl-row-desc">{t.data.description}</span>
                  </div>
                  <span class="tl-row-pillar">{pillarName(t.data.pillar)}</span>
                  <span class="tl-row-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .tl-header { padding: 3.4rem 0 2rem; border-bottom: 1px solid var(--line); background: var(--panel); }
  .page-label { font-family: var(--mono); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.7rem; }
  .tl-h1 { font-family: var(--display); font-weight: 700; font-size: clamp(2rem, 4.4vw, 3.2rem); line-height: 1.05; letter-spacing: -0.03em; color: var(--navy); margin-bottom: 1rem; max-width: 20ch; }
  .tl-header .lead { max-width: 60ch; }
  .tl-stats { display: flex; gap: 1.6rem; flex-wrap: wrap; margin-top: 1.3rem; font-size: 0.9rem; color: var(--muted); }
  .tl-stats strong { color: var(--navy); font-size: 1.05rem; }

  .tl-empty { font-size: 1.1rem; color: var(--muted); padding: 2rem 0; }
  .tl-group { margin-bottom: 2.6rem; }
  .tl-group-h { display: flex; align-items: center; gap: 0.7rem; font-family: var(--display); font-size: 1.4rem; color: var(--navy); padding-bottom: 0.6rem; border-bottom: 2px solid var(--navy); margin-bottom: 0.3rem; }
  .tl-group-n { font-family: var(--mono); font-size: 0.78rem; font-weight: 700; color: var(--blue); background: var(--page); border: 1px solid var(--line); border-radius: 999px; padding: 1px 9px; }
  .tl-list { list-style: none; padding: 0; margin: 0; }
  .tl-row { display: grid; grid-template-columns: 1fr auto 1.5rem; gap: 1.2rem; align-items: center; padding: 1.1rem 0.4rem; border-bottom: 1px solid var(--line); color: inherit; transition: background 0.15s, padding-left 0.15s; }
  .tl-row:hover { background: var(--panel); padding-left: 0.8rem; text-decoration: none; }
  .tl-row-main { display: flex; flex-direction: column; gap: 0.25rem; }
  .tl-row-title { font-family: var(--display); font-weight: 700; font-size: 1.1rem; color: var(--navy); }
  .tl-row:hover .tl-row-title { color: var(--blue); }
  .tl-row-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.45; max-width: 62ch; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .tl-row-pillar { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); white-space: nowrap; }
  .tl-row-arrow { color: var(--line-2); font-size: 1.1rem; text-align: right; transition: color 0.15s, transform 0.15s; }
  .tl-row:hover .tl-row-arrow { color: var(--blue); transform: translateX(3px); }
  @media (max-width: 640px) {
    .tl-row { grid-template-columns: 1fr 1.2rem; }
    .tl-row-pillar { display: none; }
  }
</style>
