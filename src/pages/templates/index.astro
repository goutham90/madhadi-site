---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { pillarBySlug } from '../../data/pillars';

const templates = await getCollection('templates', ({ data }) => !data.draft);
const sorted = templates.sort((a, b) => a.data.title.localeCompare(b.data.title));

// group by document type
const byType: Record<string, typeof sorted> = {};
for (const t of sorted) {
  (byType[t.data.docType] ??= []).push(t);
}
const typeOrder = ['SOP', 'Policy', 'Work Instruction', 'Protocol', 'Plan', 'Specification',
  'Risk Assessment', 'Matrix', 'Checklist', 'Form', 'Log', 'Report', 'Record', 'Template', 'Guideline'];
const types = Object.keys(byType).sort((a, b) => {
  const ia = typeOrder.indexOf(a), ib = typeOrder.indexOf(b);
  return (ia < 0 ? 99 : ia) - (ib < 0 ? 99 : ib);
});
const pillarName = (s: string) => pillarBySlug(s)?.short ?? s;
const pillarsPresent = [...new Set(sorted.map(t => t.data.pillar))]
  .map(s => ({ slug: s, name: pillarName(s) }))
  .sort((a, b) => a.name.localeCompare(b.name));
---
<Layout title="Templates & Procedures" description="Plug-and-play SOPs, policies, procedures, work instructions, protocols, forms, logs, checklists, and risk assessments for GxP quality across biotech, pharma, biologics, and life sciences. Copy, fill in your specifics, and adapt through your own document control." wide={true}>
  <section class="tl-header">
    <div class="wrap">
      <div class="page-label">Templates & Procedures</div>
      <h1 class="tl-h1">Ready-to-use documents, not just explanations.</h1>
      <p class="lead">Plug-and-play SOPs, policies, procedures, work instructions, protocols, forms, logs, checklists, and risk assessments. Each one carries the full inspection-grade structure with placeholders for your company, system, and process, plus a worked filled-in specimen. Copy it, fill it in, route it through your own document control.</p>
      <div class="tl-stats">
        <span><strong>{templates.length}</strong> documents</span>
        <span><strong>{types.length}</strong> document types</span>
        <span>Free to copy and adapt</span>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="wrap">
      {templates.length === 0 && (
        <p class="tl-empty">The library is being built. New ready-to-use documents are added with the daily updates. Check back shortly.</p>
      )}

      {templates.length > 0 && (
        <div class="tl-filters" id="tl-filters">
          <div class="tl-search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input id="tl-q" type="search" placeholder="Filter documents by name or keyword" autocomplete="off" aria-label="Filter documents" />
          </div>
          <div class="tl-chips" role="group" aria-label="Filter by document type">
            <button class="tl-chip is-on" data-kind="type" data-val="all">All types</button>
            {types.map((type) => (<button class="tl-chip" data-kind="type" data-val={type}>{type}<span>{byType[type].length}</span></button>))}
          </div>
          <div class="tl-chips" role="group" aria-label="Filter by discipline">
            <button class="tl-chip is-on" data-kind="pillar" data-val="all">All disciplines</button>
            {pillarsPresent.map((p) => (<button class="tl-chip" data-kind="pillar" data-val={p.slug}>{p.name}</button>))}
          </div>
          <p class="tl-count" id="tl-count" aria-live="polite"></p>
        </div>
      )}

      {types.map((type) => (
        <div class="tl-group" data-group={type}>
          <h2 class="tl-group-h">{type}<span class="tl-group-n">{byType[type].length}</span></h2>
          <ul class="tl-list">
            {byType[type].map((t) => (
              <li class="tl-item" data-type={type} data-pillar={t.data.pillar} data-text={`${t.data.title} ${t.data.description} ${(t.data.tags ?? []).join(' ')}`.toLowerCase()}>
                <a href={`/templates/${t.slug}`} class="tl-row">
                  <div class="tl-row-main">
                    <span class="tl-row-title">{t.data.title}</span>
                    <span class="tl-row-desc">{t.data.description}</span>
                  </div>
                  <span class="tl-row-pillar">{pillarName(t.data.pillar)}</span>
                  <span class="tl-row-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
      <p class="tl-empty" id="tl-noresults" hidden>No documents match that filter. Clear it to see the full library.</p>
    </div>
  </section>

  <script is:inline>
    (function () {
      var q = document.getElementById('tl-q');
      var count = document.getElementById('tl-count');
      var noRes = document.getElementById('tl-noresults');
      var filters = document.getElementById('tl-filters');
      if (!filters) return;
      var state = { type: 'all', pillar: 'all', text: '' };
      var items = Array.prototype.slice.call(document.querySelectorAll('.tl-item'));
      var groups = Array.prototype.slice.call(document.querySelectorAll('.tl-group'));
      function apply() {
        var shown = 0;
        items.forEach(function (li) {
          var ok = (state.type === 'all' || li.getAttribute('data-type') === state.type)
            && (state.pillar === 'all' || li.getAttribute('data-pillar') === state.pillar)
            && (state.text === '' || li.getAttribute('data-text').indexOf(state.text) !== -1);
          li.hidden = !ok;
          if (ok) shown++;
        });
        groups.forEach(function (g) {
          var any = g.querySelectorAll('.tl-item:not([hidden])').length;
          g.hidden = any === 0;
        });
        if (noRes) noRes.hidden = shown !== 0;
        if (count) count.textContent = shown + (shown === 1 ? ' document' : ' documents');
      }
      filters.addEventListener('click', function (e) {
        var btn = e.target.closest('.tl-chip');
        if (!btn) return;
        var kind = btn.getAttribute('data-kind');
        state[kind] = btn.getAttribute('data-val');
        filters.querySelectorAll('.tl-chip[data-kind="' + kind + '"]').forEach(function (b) { b.classList.toggle('is-on', b === btn); });
        apply();
      });
      if (q) q.addEventListener('input', function () { state.text = q.value.trim().toLowerCase(); apply(); });
      apply();
    })();
  </script>
</Layout>

<style>
  .tl-header { padding: 3.4rem 0 2rem; border-bottom: 1px solid var(--line); background: var(--panel); }
  .page-label { font-family: var(--mono); font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--blue); margin-bottom: 0.7rem; }
  .tl-h1 { font-family: var(--display); font-weight: 700; font-size: clamp(2rem, 4.4vw, 3.2rem); line-height: 1.05; letter-spacing: -0.03em; color: var(--navy); margin-bottom: 1rem; max-width: 20ch; }
  .tl-header .lead { max-width: 60ch; }
  .tl-stats { display: flex; gap: 1.6rem; flex-wrap: wrap; margin-top: 1.3rem; font-size: 0.9rem; color: var(--muted); }
  .tl-stats strong { color: var(--navy); font-size: 1.05rem; }

  .tl-empty { font-size: 1.1rem; color: var(--muted); padding: 2rem 0; }

  /* interactive filters */
  .tl-filters { margin-bottom: 2rem; padding-bottom: 1.4rem; border-bottom: 2px solid var(--navy); }
  .tl-search { display: flex; align-items: center; gap: 10px; background: #fff; border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 10px 14px; margin-bottom: 14px; max-width: 460px; }
  .tl-search svg { color: var(--blue); flex: none; }
  .tl-search input { flex: 1; border: none; outline: none; font-family: var(--sans); font-size: 0.98rem; color: var(--ink); background: transparent; }
  .tl-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
  .tl-chip { display: inline-flex; align-items: center; gap: 6px; padding: 6px 13px; background: #fff; border: 1px solid var(--line-strong); border-radius: 999px; font-family: var(--sans); font-size: 0.86rem; font-weight: 600; color: var(--muted); cursor: pointer; transition: all .12s; }
  .tl-chip span { font-size: 0.74rem; color: var(--blue); font-weight: 700; }
  .tl-chip:hover { border-color: var(--navy); color: var(--navy); }
  .tl-chip.is-on { background: var(--navy); border-color: var(--navy); color: #fff; }
  .tl-chip.is-on span { color: #ffd98a; }
  .tl-count { font-size: 0.84rem; color: var(--faint); font-weight: 600; margin-top: 4px; }
  .tl-item[hidden], .tl-group[hidden] { display: none; }
  .tl-group { margin-bottom: 2.6rem; }
  .tl-group-h { display: flex; align-items: center; gap: 0.7rem; font-family: var(--display); font-size: 1.4rem; color: var(--navy); padding-bottom: 0.6rem; border-bottom: 2px solid var(--navy); margin-bottom: 0.3rem; }
  .tl-group-n { font-family: var(--mono); font-size: 0.78rem; font-weight: 700; color: var(--blue); background: var(--page); border: 1px solid var(--line); border-radius: 999px; padding: 1px 9px; }
  .tl-list { list-style: none; padding: 0; margin: 0; }
  .tl-row { display: grid; grid-template-columns: 1fr auto 1.5rem; gap: 1.2rem; align-items: center; padding: 1.1rem 0.4rem; border-bottom: 1px solid var(--line); color: inherit; transition: background 0.15s, padding-left 0.15s; }
  .tl-row:hover { background: var(--panel); padding-left: 0.8rem; text-decoration: none; }
  .tl-row-main { display: flex; flex-direction: column; gap: 0.25rem; }
  .tl-row-title { font-family: var(--display); font-weight: 700; font-size: 1.1rem; color: var(--navy); }
  .tl-row:hover .tl-row-title { color: var(--blue); }
  .tl-row-desc { font-size: 0.9rem; color: var(--muted); line-height: 1.45; max-width: 62ch; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .tl-row-pillar { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); white-space: nowrap; }
  .tl-row-arrow { color: var(--line-2); font-size: 1.1rem; text-align: right; transition: color 0.15s, transform 0.15s; }
  .tl-row:hover .tl-row-arrow { color: var(--blue); transform: translateX(3px); }
  @media (max-width: 640px) {
    .tl-row { grid-template-columns: 1fr 1.2rem; }
    .tl-row-pillar { display: none; }
  }
</style>
