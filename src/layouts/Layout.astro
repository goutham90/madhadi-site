---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'A practitioner-built field manual for data integrity, computerized system validation, and GxP quality in regulated biotech.', wide = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');

const primary = [
  { href: '/articles', label: 'Articles' },
  { href: '/pillars', label: 'Pillars' },
  { href: '/tracks', label: 'Learn' },
];
const resources = [
  { href: '/glossary', label: 'Glossary' },
  { href: '/scenarios', label: 'Scenarios' },
  { href: '/tools', label: 'Tools' },
  { href: '/regulatory-refs', label: 'Regulatory References' },
  { href: '/learning-paths', label: 'Learning Paths' },
  { href: '/topics', label: 'Topics' },
];
const resourcesActive = resources.some(r => isActive(r.href));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#08090B" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  <title>{title === 'Home' ? 'madhadi.com — A Field Manual for Data Integrity & GxP Quality' : `${title} · madhadi.com`}</title>
  <noscript><style>[data-reveal]{opacity:1 !important;transform:none !important}</style></noscript>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Modern precision-tech system (dark-first) ── */
      --bg:        #08090B;
      --bg-2:      #0E1014;
      --surface:   #121519;
      --surface-2: #171B21;
      --text:      #F2F4F7;
      --muted:     #A6AEBA;
      --faint:     #6B7480;
      --line:      rgba(255,255,255,0.08);
      --line-2:    rgba(255,255,255,0.14);
      --accent:    #34E59B;      /* signal — the "verified record" */
      --accent-2:  #21C282;
      --accent-dim: rgba(52,229,155,0.12);
      --violet:    #8A7DFF;

      /* back-compat aliases so existing pages/articles never break */
      --bone: var(--bg); --bone-2: var(--bg-2); --paper: var(--surface); --paper-2: var(--surface-2);
      --ink: var(--text); --ink-2: var(--surface-2); --graphite: var(--muted); --muted-light: var(--muted);
      --line-ink: var(--line); --border: var(--line); --border-dim: var(--line);
      --vermilion: var(--accent); --vermilion-2: var(--accent-2); --oxblood: var(--accent-2);
      --accent-h: var(--accent-2); --brass: var(--accent); --green: var(--accent);
      --on-ink: var(--text); --on-ink-dim: var(--muted); --navy: var(--text); --navy-2: var(--text);
      --link: var(--accent); --link-h: var(--text); --body: var(--muted); --serif: var(--display);
      --font: var(--sans); --shadow: 0 30px 70px -40px rgba(0,0,0,0.8); --shadow-sm: 0 2px 8px rgba(0,0,0,0.4);
      --container-narrow: 760px; --max-w: 760px; --max-w-wide: var(--container);

      --display: "Space Grotesk", "SF Pro Display", system-ui, sans-serif;
      --sans: "Manrope", system-ui, -apple-system, sans-serif;
      --mono: "JetBrains Mono", ui-monospace, "SF Mono", monospace;
      --container: 1200px;
      --measure: 70ch;
      --radius: 14px; --radius-lg: 18px; --radius-sm: 10px;
    }

    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      background: var(--bg); color: var(--text); font-family: var(--sans);
      font-size: 17px; line-height: 1.7; letter-spacing: -0.011em;
      -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; overflow-x: hidden;
    }
    body::before {
      content: ""; position: fixed; inset: 0; z-index: -1; pointer-events: none;
      background:
        linear-gradient(var(--line) 1px, transparent 1px) 0 0 / 70px 70px,
        linear-gradient(90deg, var(--line) 1px, transparent 1px) 0 0 / 70px 70px;
      -webkit-mask-image: radial-gradient(120% 85% at 50% -8%, #000 28%, transparent 74%);
      mask-image: radial-gradient(120% 85% at 50% -8%, #000 28%, transparent 74%);
      opacity: 0.55;
    }

    .wrap { max-width: var(--container); margin-inline: auto; padding-inline: 28px; }
    .wide { max-width: 1340px; }

    h1,h2,h3,h4 { font-family: var(--display); font-weight: 600; line-height: 1.05; letter-spacing: -0.035em; color: var(--text); }
    a { color: inherit; text-decoration: none; }
    p { color: var(--muted); }

    .kicker, .mono-label, .marginalia { font-family: var(--mono); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); }
    .marginalia { color: var(--faint); text-transform: none; letter-spacing: 0.02em; }
    .eyebrow { display: inline-flex; align-items: center; gap: 9px; }
    .eyebrow::before { content: ""; width: 22px; height: 1px; background: var(--accent); }

    .pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 13px; font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); background: var(--surface); border: 1px solid var(--line); border-radius: 999px; }
    .pill .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 10px var(--accent); }

    .btn, .btn-accent, .btn-ghost { display: inline-flex; align-items: center; gap: 9px; padding: 13px 22px; font-family: var(--sans); font-weight: 600; font-size: 0.95rem; border-radius: 12px; cursor: pointer; transition: transform .18s ease, background .2s ease, border-color .2s ease, box-shadow .2s ease; border: 1px solid transparent; }
    .btn-accent { background: var(--accent); color: #04150D; }
    .btn-accent:hover { background: var(--accent-2); transform: translateY(-2px); box-shadow: 0 14px 34px -12px rgba(52,229,155,0.55); }
    .btn-ghost { background: transparent; color: var(--text); border-color: var(--line-2); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }

    .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: saturate(140%) blur(14px); background: color-mix(in srgb, var(--bg) 76%, transparent); border-bottom: 1px solid var(--line); }
    .nav-in { display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .brand { display: inline-flex; align-items: center; gap: 11px; font-family: var(--display); font-weight: 600; font-size: 1.06rem; letter-spacing: -0.02em; }
    .brand-mark { width: 26px; height: 26px; border-radius: 7px; background: linear-gradient(140deg, var(--accent), var(--violet)); display: grid; place-items: center; color: #04150D; font-family: var(--mono); font-weight: 700; font-size: 0.8rem; box-shadow: 0 0 18px -4px var(--accent); }
    .brand b { color: var(--text); font-weight: 600; } .brand .tld { color: var(--faint); }
    .nav-links { display: flex; align-items: center; gap: 4px; }
    .nav-links a { padding: 8px 13px; font-size: 0.92rem; font-weight: 500; color: var(--muted); border-radius: 9px; transition: color .18s, background .18s; }
    .nav-links a:hover { color: var(--text); background: var(--surface); }
    .nav-links a.active { color: var(--text); }
    .nav-cta { margin-left: 10px; color: #04150D !important; }
    .menu-btn { display: none; background: none; border: 1px solid var(--line-2); color: var(--text); width: 40px; height: 40px; border-radius: 10px; cursor: pointer; font-size: 1.1rem; }
    .drawer { display: none; }

    .footer { border-top: 1px solid var(--line); margin-top: 110px; background: var(--bg-2); }
    .footer-in { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 40px; padding: 60px 0 40px; }
    .footer h4 { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); margin-bottom: 16px; font-weight: 500; }
    .footer a { color: var(--muted); font-size: 0.94rem; display: block; padding: 5px 0; transition: color .15s; }
    .footer a:hover { color: var(--accent); }
    .footer-lead { color: var(--muted); max-width: 40ch; margin: 14px 0 0; font-size: 0.95rem; }
    .footer-bottom { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 22px 0; border-top: 1px solid var(--line); font-family: var(--mono); font-size: 0.74rem; color: var(--faint); letter-spacing: 0.03em; }

    ::selection { background: var(--accent-dim); color: var(--text); }
    *:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; border-radius: 4px; }
    img { max-width: 100%; display: block; }

    [data-reveal] { opacity: 0; transform: translateY(18px); transition: opacity .7s cubic-bezier(.2,.7,.2,1), transform .7s cubic-bezier(.2,.7,.2,1); }
    [data-reveal].in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) { [data-reveal]{opacity:1;transform:none;transition:none;} html{scroll-behavior:auto;} }

    @media (max-width: 860px) {
      .nav-links { display: none; } .menu-btn { display: grid; place-items: center; }
      .footer-in { grid-template-columns: 1fr; gap: 30px; } body { font-size: 16px; } .wrap { padding-inline: 20px; }
      .drawer.open { display: block; position: fixed; inset: 64px 0 0; background: var(--bg); z-index: 49; padding: 22px; overflow:auto; }
      .drawer.open a { display:block; padding: 14px 6px; font-size: 1.1rem; border-bottom: 1px solid var(--line); color: var(--text); }
    }
  </style>
</head>
<body>
  <header class="nav">
    <div class="wrap nav-in">
      <a href="/" class="brand" aria-label="madhadi.com home"><span class="brand-mark">M</span><b>madhadi</b><span class="tld">.com</span></a>
      <nav class="nav-links" aria-label="Primary">
        {primary.map(l => <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>)}
        <a href="/glossary" class={resourcesActive ? 'active' : ''}>Resources</a>
        <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        <a href="/start" class="btn-accent nav-cta">Start →</a>
      </nav>
      <button class="menu-btn" aria-label="Menu" onclick="document.getElementById('drawer').classList.toggle('open')">☰</button>
    </div>
    <div class="drawer" id="drawer">
      {[...primary, ...resources, {href:'/about',label:'About'}, {href:'/start',label:'Start here'}].map(l => <a href={l.href}>{l.label}</a>)}
    </div>
  </header>

  <main class={wide ? 'wide-page' : ''}><slot /></main>

  <footer class="footer">
    <div class="wrap footer-in">
      <div>
        <a href="/" class="brand"><span class="brand-mark">M</span><b>madhadi</b><span class="tld">.com</span></a>
        <p class="footer-lead">A practitioner's field manual for data integrity, computerized system validation, and GxP quality in regulated biotech. Written to be used, not skimmed.</p>
      </div>
      <div><h4>Explore</h4>{primary.map(l => <a href={l.href}>{l.label}</a>)}<a href="/start">Start here</a><a href="/about">About</a></div>
      <div><h4>Resources</h4>{resources.map(l => <a href={l.href}>{l.label}</a>)}</div>
    </div>
    <div class="wrap footer-bottom">
      <span>© {new Date().getFullYear()} madhadi.com — public-domain practitioner reference.</span>
      <a href="mailto:goutham@madhadi.com">goutham@madhadi.com</a>
    </div>
  </footer>

  <script>
    const io = new IntersectionObserver((es) => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.1 });
    document.querySelectorAll('[data-reveal]').forEach((el, i) => { (el as HTMLElement).style.transitionDelay = `${Math.min(i % 6, 5) * 55}ms`; io.observe(el); });
  </script>
</body>
</html>
