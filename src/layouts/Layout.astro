---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'Working notes and guides on data integrity, computerized system validation, and GxP quality in regulated biotech.', wide = false } = Astro.props;
const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');

const primary = [
  { href: '/articles', label: 'Articles' },
  { href: '/pillars', label: 'Topics' },
  { href: '/tracks', label: 'Learning' },
];
const resources = [
  { href: '/glossary', label: 'Glossary' },
  { href: '/scenarios', label: 'Scenarios' },
  { href: '/tools', label: 'Tools' },
  { href: '/regulatory-refs', label: 'Regulatory References' },
  { href: '/learning-paths', label: 'Learning Paths' },
  { href: '/topics', label: 'Topics' },
];
const resourcesActive = resources.some(r => isActive(r.href));
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#0b2e4f" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Franklin:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet" />
  <title>{title === 'Home' ? 'madhadi.com · Data Integrity & GxP Quality' : `${title} · madhadi.com`}</title>
  <noscript><style>[data-reveal]{opacity:1 !important;transform:none !important}</style></noscript>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Institutional / standards-body system (FDA · MHRA · ISPE · PDA) ── */
      --page:    #ffffff;        /* page bg */
      --panel:   #f4f6f8;        /* light grey sections (gov-style) */
      --panel-2: #eaeef2;
      --navy:    #0b2e4f;        /* deep institutional navy, masthead, headings */
      --navy-2:  #11385f;
      --blue:    #005ea2;        /* USWDS primary, links, accents */
      --blue-d:  #1a4480;        /* dark blue hover */
      --ink:     #1b1b1b;        /* body text */
      --ink-2:   #2e2e2e;
      --muted:   #565c65;        /* secondary text */
      --faint:   #71767a;        /* meta */
      --line:    #dfe1e2;        /* hairline */
      --line-2:  #c9ccd0;
      --line-strong: #c6ccd2;
      --gold:    #a8631b;        /* restrained warm accent (rules/marks), used sparingly */
      --on-navy: #eef3f8;
      --on-navy-dim: #b9c7d6;

      /* back-compat aliases so existing pages/articles never break */
      --bg: var(--page); --bone: var(--page); --bone-2: var(--panel); --paper: var(--page); --paper-2: var(--panel);
      --surface: var(--page); --surface-2: var(--panel); --text: var(--ink); --body: var(--muted);
      --graphite: var(--muted); --muted-light: var(--muted); --line-ink: var(--line); --border: var(--line); --border-dim: var(--line);
      --accent: var(--blue); --accent-2: var(--blue-d); --accent-h: var(--blue-d); --vermilion: var(--blue); --vermilion-2: var(--blue-d);
      --oxblood: var(--navy); --brass: var(--gold); --green: #0f7a52; --link: var(--blue); --link-h: var(--blue-d);
      --on-ink: var(--on-navy); --on-ink-dim: var(--on-navy-dim); --ink-section: var(--navy);
      --shadow: 0 12px 28px -18px rgba(11,46,79,0.28); --shadow-sm: 0 1px 2px rgba(27,27,27,0.08);
      --container-narrow: 740px; --max-w: 740px; --max-w-wide: var(--container); --violet: var(--blue);

      --serif: "Newsreader", Georgia, serif;
      --sans: "Libre Franklin", system-ui, -apple-system, "Segoe UI", Arial, sans-serif;
      --display: "Libre Franklin", system-ui, -apple-system, sans-serif;
      --mono: ui-monospace, "SF Mono", "Cascadia Mono", Consolas, monospace;
      --container: 1180px;
      --measure: 68ch;
      --radius: 4px; --radius-lg: 6px; --radius-sm: 3px;
    }

    html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }
    body {
      background: var(--page); color: var(--ink); font-family: var(--sans);
      font-size: 17px; line-height: 1.6; -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility;
    }
    .wrap { max-width: var(--container); margin-inline: auto; padding-inline: 28px; }
    .wide { max-width: 1300px; }

    h1,h2,h3,h4 { font-family: var(--display); font-weight: 700; line-height: 1.14; letter-spacing: -0.022em; color: var(--navy); }
    a { color: var(--blue); text-decoration: none; }
    a:hover { color: var(--blue-d); text-decoration: underline; text-underline-offset: 2px; }
    p { color: var(--ink-2); }

    .kicker, .mono-label, .overline { font-family: var(--sans); font-size: 0.74rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue); }
    .overline { display: inline-flex; align-items: center; gap: 9px; }
    .overline::before { content: ""; width: 3px; height: 14px; background: var(--gold); border-radius: 1px; }
    .marginalia { font-family: var(--sans); font-size: 0.84rem; color: var(--faint); }

    .btn, .btn-accent, .btn-ghost { display: inline-flex; align-items: center; gap: 9px; padding: 12px 22px; font-family: var(--sans); font-weight: 600; font-size: 0.97rem; border-radius: var(--radius); cursor: pointer; transition: background .15s, color .15s, border-color .15s; border: 1px solid transparent; line-height: 1.2; }
    .btn-accent { background: var(--navy); color: #fff; }
    .btn-accent:hover { background: var(--navy-2); color: #fff; text-decoration: none; }
    .btn-ghost { background: #fff; color: var(--navy); border-color: var(--line-strong); }
    .btn-ghost:hover { border-color: var(--navy); color: var(--navy); text-decoration: none; }

    /* ── Top utility strip ── */
    .util { background: var(--navy); color: var(--on-navy); font-size: 0.78rem; }
    .util-in { display: flex; align-items: center; justify-content: space-between; gap: 16px; height: 34px; }
    .util a { color: var(--on-navy); }
    .util .util-note { color: var(--on-navy-dim); letter-spacing: 0.01em; }

    /* ── Masthead ── */
    .mast { background: #fff; border-bottom: 3px solid var(--navy); position: sticky; top: 0; z-index: 50; }
    .mast-in { display: flex; align-items: center; justify-content: space-between; height: 78px; }
    .brand { display: inline-flex; align-items: center; gap: 12px; }
    .brand-mark { width: 42px; height: 42px; display: block; }
    .brand-txt { display: flex; flex-direction: column; line-height: 1.02; }
    .brand-name { font-family: var(--display); font-weight: 800; font-size: 1.34rem; color: var(--navy); letter-spacing: -0.035em; }
    .brand-name .dot { color: var(--gold); }
    .brand-sub { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); font-weight: 700; margin-top: 2px; }
    .mast-nav { display: flex; align-items: center; gap: 2px; }
    .mast-nav a { padding: 10px 14px; font-size: 0.95rem; font-weight: 600; color: var(--ink); border-radius: 4px; }
    .mast-nav a:hover { color: var(--blue); background: var(--panel); text-decoration: none; }
    .mast-nav a.active { color: var(--navy); box-shadow: inset 0 -3px 0 var(--gold); }
    .mast-nav a.mast-cta { color: #fff; margin-left: 8px; }
    .mast-nav a.mast-cta:hover { color: #fff; background: var(--navy-2); }
    .menu-btn { display: none; background: none; border: 1px solid var(--line-strong); color: var(--navy); width: 42px; height: 42px; border-radius: 4px; cursor: pointer; font-size: 1.2rem; }
    .drawer { display: none; }

    /* ── Footer (dense institutional) ── */
    .footer { margin-top: 80px; background: var(--navy); color: var(--on-navy); }
    .footer-in { display: grid; grid-template-columns: 1.7fr 1fr 1fr 1fr; gap: 36px; padding: 56px 0 40px; }
    .footer h4 { font-family: var(--sans); font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: #fff; margin-bottom: 14px; font-weight: 700; }
    .footer a { color: var(--on-navy-dim); font-size: 0.93rem; display: block; padding: 5px 0; }
    .footer a:hover { color: #fff; text-decoration: underline; }
    .footer-lead { color: var(--on-navy-dim); max-width: 42ch; margin: 14px 0 0; font-size: 0.94rem; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.16); }
    .footer-bottom-in { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 20px 0; font-size: 0.82rem; color: var(--on-navy-dim); }
    .footer .brand-name, .footer .brand-mark { color: #fff; }
    .footer .brand-mark { background: rgba(255,255,255,0.12); }

    ::selection { background: #cfe3f3; color: var(--navy); }
    *:focus-visible { outline: 3px solid #ffbf47; outline-offset: 2px; }
    img { max-width: 100%; display: block; }

    [data-reveal] { opacity: 0; transform: translateY(14px); transition: opacity .6s ease, transform .6s ease; }
    [data-reveal].in { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce){ [data-reveal]{opacity:1;transform:none;transition:none;} html{scroll-behavior:auto;} }

    @media (max-width: 900px) {
      .mast-nav { display: none; } .menu-btn { display: grid; place-items: center; }
      .util-in .util-note { display: none; }
      .footer-in { grid-template-columns: 1fr 1fr; gap: 28px; } body { font-size: 16px; } .wrap { padding-inline: 20px; }
      .drawer.open { display: block; position: fixed; inset: 112px 0 0; background: #fff; z-index: 49; padding: 20px; overflow: auto; }
      .drawer.open a { display: block; padding: 14px 6px; font-size: 1.08rem; border-bottom: 1px solid var(--line); color: var(--navy); font-weight: 600; }
    }
    @media (max-width: 560px) { .footer-in { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="util"><div class="wrap util-in">
    <span class="util-note">Independent and not affiliated with the FDA, MHRA, ISPE, PDA, or any agency.</span>
    <a href="mailto:goutham@madhadi.com">goutham@madhadi.com</a>
  </div></div>

  <header class="mast">
    <div class="wrap mast-in">
      <a href="/" class="brand" aria-label="madhadi.com home">
        <img src="/brand/mark.svg" class="brand-mark" alt="" width="42" height="42" />
        <span class="brand-txt"><span class="brand-name">madhadi<span class="dot">.</span>com</span><span class="brand-sub">Data Integrity &amp; GxP Quality</span></span>
      </a>
      <nav class="mast-nav" aria-label="Primary">
        {primary.map(l => <a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a>)}
        <a href="/glossary" class={resourcesActive ? 'active' : ''}>Resources</a>
        <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
        <a href="/start" class="btn-accent mast-cta">Start here</a>
      </nav>
      <button class="menu-btn" aria-label="Menu" onclick="document.getElementById('drawer').classList.toggle('open')">☰</button>
    </div>
    <div class="drawer" id="drawer">
      {[...primary, ...resources, {href:'/about',label:'About'}, {href:'/start',label:'Start here'}].map(l => <a href={l.href}>{l.label}</a>)}
    </div>
  </header>

  <main class={wide ? 'wide-page' : ''}><slot /></main>

  <footer class="footer">
    <div class="wrap footer-in">
      <div>
        <a href="/" class="brand"><img src="/brand/mark.svg" class="brand-mark" alt="" width="42" height="42" /><span class="brand-txt"><span class="brand-name" style="color:#fff">madhadi<span class="dot">.</span>com</span></span></a>
        <p class="footer-lead">Working notes and guides on data integrity, computerized system validation, and GxP quality in regulated biotech. Written to be used on the job, not skimmed.</p>
      </div>
      <div><h4>Explore</h4>{primary.map(l => <a href={l.href}>{l.label}</a>)}<a href="/start">Start here</a><a href="/about">About</a></div>
      <div><h4>Resources</h4>{resources.slice(0,4).map(l => <a href={l.href}>{l.label}</a>)}</div>
      <div><h4>More</h4>{resources.slice(4).map(l => <a href={l.href}>{l.label}</a>)}<a href="/articles">All articles</a></div>
    </div>
    <div class="footer-bottom"><div class="wrap footer-bottom-in">
      <span>© {new Date().getFullYear()} madhadi.com · Free, public-domain knowledge.</span>
      <span>Built and maintained by a working Director of Digital Quality.</span>
    </div></div>
  </footer>

  <script>
    const io = new IntersectionObserver((es) => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }), { threshold: 0.08 });
    document.querySelectorAll('[data-reveal]').forEach((el, i) => { (el as HTMLElement).style.transitionDelay = `${Math.min(i % 5, 4) * 50}ms`; io.observe(el); });
  </script>
</body>
</html>
