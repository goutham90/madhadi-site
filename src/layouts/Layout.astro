---
interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'In-depth guides, case studies, and practical tools for data integrity professionals in regulated biotech.', wide = false } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/start', label: 'Start Here' },
  { href: '/articles', label: 'Articles' },
  { href: '/pillars', label: 'Pillars' },
  { href: '/tracks', label: 'Learn' },
  { href: '/glossary', label: 'Glossary' },
  { href: '/scenarios', label: 'Scenarios' },
  { href: '/tools', label: 'Tools' },
  { href: '/about', label: 'About' },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title === 'Home' ? 'Data Integrity Hub — Goutham Madhadi' : `${title} — Data Integrity Hub`}</title>
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #08090a;
      --surface:      #0f1114;
      --surface2:     #141820;
      --border:       #1e2430;
      --border-dim:   #151b24;
      --text:         #e8edf2;
      --muted:        #64748b;
      --muted-light:  #94a3b8;
      --accent:       #4f8ef7;
      --accent-h:     #7eb0fb;
      --accent-glow:  rgba(79, 142, 247, 0.12);
      --green:        #34d399;
      --amber:        #fbbf24;
      --font: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      --mono: "SF Mono", "Fira Code", Consolas, monospace;
      --radius: 10px;
      --max-w: 780px;
      --max-w-wide: 1100px;
    }

    html {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      scroll-behavior: smooth;
    }

    body { min-height: 100vh; display: flex; flex-direction: column; }

    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent-h); }

    p { color: #94a3b8; line-height: 1.75; }
    h1, h2, h3, h4 { color: var(--text); font-weight: 600; line-height: 1.25; letter-spacing: -0.02em; }

    code {
      font-family: var(--mono);
      font-size: 0.85em;
      background: var(--surface2);
      border: 1px solid var(--border);
      padding: 0.15em 0.45em;
      border-radius: 5px;
      color: var(--accent-h);
    }

    pre {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      overflow-x: auto;
      margin: 1.75rem 0;
    }

    pre code { background: none; border: none; padding: 0; font-size: 0.875em; }

    blockquote {
      border-left: 3px solid var(--accent);
      padding: 0.75rem 1.25rem;
      margin: 2rem 0;
      background: var(--accent-glow);
      border-radius: 0 var(--radius) var(--radius) 0;
      color: var(--muted-light);
      font-style: italic;
    }

    hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

    ul, ol { padding-left: 1.5rem; color: #94a3b8; }
    li { margin-bottom: 0.4rem; }

    img { max-width: 100%; border-radius: var(--radius); }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 1.5rem 0;
    }

    th {
      text-align: left;
      padding: 0.6rem 1rem;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--text);
      font-weight: 600;
    }

    td {
      padding: 0.6rem 1rem;
      border: 1px solid var(--border);
      color: #94a3b8;
    }

    tr:hover td { background: var(--surface); }

    /* ── Nav ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(8, 9, 10, 0.88);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border-dim);
    }

    .nav-inner {
      max-width: var(--max-w-wide);
      margin: 0 auto;
      padding: 0 2rem;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 0.6rem;
    }

    .nav-icon {
      width: 28px;
      height: 28px;
      background: linear-gradient(135deg, var(--accent), #7b3fff);
      border-radius: 7px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 800;
      color: white;
      flex-shrink: 0;
    }

    .nav-logo {
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--text);
      letter-spacing: -0.01em;
    }

    .nav-logo:hover { color: var(--accent); }

    .nav-links {
      display: flex;
      gap: 0.15rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.875rem;
      color: var(--muted);
      padding: 0.45rem 0.85rem;
      border-radius: 7px;
      transition: color 0.15s, background 0.15s;
      font-weight: 500;
    }

    .nav-links a:hover { color: var(--text); background: var(--surface2); }
    .nav-links a.active { color: var(--text); background: var(--surface2); }

    /* ── Main ── */
    main {
      flex: 1;
      max-width: var(--max-w);
      width: 100%;
      margin: 0 auto;
      padding: 3.5rem 1.75rem 5rem;
    }

    main.wide {
      max-width: var(--max-w-wide);
      padding: 0 2rem 5rem;
    }

    /* ── Footer ── */
    footer {
      border-top: 1px solid var(--border-dim);
      padding: 2.5rem 2rem;
      margin-top: auto;
    }

    .footer-inner {
      max-width: var(--max-w-wide);
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      align-items: center;
    }

    .footer-brand p {
      font-size: 0.8rem;
      color: var(--muted);
      margin-top: 0.35rem;
      line-height: 1.5;
    }

    .footer-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-links a {
      font-size: 0.8rem;
      color: var(--muted);
      transition: color 0.15s;
    }

    .footer-links a:hover { color: var(--accent); }

    .footer-copy {
      grid-column: 1 / -1;
      font-size: 0.75rem;
      color: var(--muted);
      padding-top: 1.25rem;
      border-top: 1px solid var(--border-dim);
    }

    /* ── Tags ── */
    .tag {
      display: inline-flex;
      align-items: center;
      font-size: 0.7rem;
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted-light);
      font-family: var(--mono);
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: border-color 0.15s, color 0.15s;
    }

    .tag:hover { border-color: var(--accent); color: var(--accent); }

    /* ── Gradient text ── */
    .gradient-text {
      background: linear-gradient(135deg, #e8edf2 30%, #4f8ef7 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Callout ── */
    .callout {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      margin: 2rem 0;
    }

    .callout-title {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
      font-family: var(--mono);
    }

    .callout p { color: var(--muted-light); font-size: 0.95rem; margin: 0; }

    @media (max-width: 700px) {
      .nav-inner { padding: 0 1.25rem; }
      main { padding: 2.5rem 1.25rem 3.5rem; }
      main.wide { padding: 0 1.25rem 3.5rem; }
      .footer-inner { grid-template-columns: 1fr; }
      .footer-links { flex-wrap: wrap; gap: 1rem; }
      .nav-links a { padding: 0.4rem 0.6rem; font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-brand">
        <div class="nav-icon">DI</div>
        <span class="nav-logo">madhadi.com</span>
      </a>
      <ul class="nav-links">
        {navLinks.map(link => (
          <li>
            <a href={link.href} class={currentPath.startsWith(link.href) ? 'active' : ''}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <main class={wide ? 'wide' : ''}>
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="nav-logo">madhadi.com</div>
        <p>Data integrity knowledge for regulated biotech professionals.</p>
      </div>
      <div class="footer-links">
        <a href="/start">Start Here</a>
        <a href="/articles">Articles</a>
        <a href="/pillars">Pillars</a>
        <a href="/tracks">Learn</a>
        <a href="/learning-paths">Learning Paths</a>
        <a href="/scenarios">Scenarios</a>
        <a href="/glossary">Glossary</a>
        <a href="/regulatory-refs">Regulatory Refs</a>
        <a href="/tools">Tools</a>
        <a href="/topics">Topics</a>
        <a href="/about">About</a>
        <a href="mailto:goutham@madhadi.com">Contact</a>
      </div>
      <div class="footer-copy">
        © {new Date().getFullYear()} Goutham Madhadi · goutham@madhadi.com · Opinions are my own.
      </div>
    </div>
  </footer>
</body>
</html>
