---
import Layout from './Layout.astro';

interface Props {
 title: string;
 description: string;
 pubDate: Date;
 tags: string[];
 tier?: string;
 pillar?: string;
 body?: string;
}

const { title, description, pubDate, tags, tier, pillar, body = '' } = Astro.props;

const tierColors: Record<string, string> = {
 Beginner: '#2F6E4F',
 Intermediate: '#1C4E80',
 Advanced: '#7A3B57',
};

const pillarNames: Record<string, string> = {
 'data-integrity': 'Data Integrity',
 'csv-csa': 'CSV / CSA',
 'equipment-qualification': 'Equipment Qualification',
 'quality-assurance': 'Quality Assurance',
 'audits-inspection': 'Audits & Inspection',
 'cell-gene-therapy': 'Cell & Gene Therapy',
 'manufacturing-automation': 'Manufacturing Automation',
 'ai-automation': 'AI & Automation',
};

const formatted = pubDate.toLocaleDateString('en-US', {
 year: 'numeric', month: 'long', day: 'numeric',
});

const wordCount = body.split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 220));
const tierColor = tier ? (tierColors[tier] ?? '#756B5B') : '#756B5B';
---
<Layout title={title} description={description}>
 <div class="reading-bar" id="reading-bar"></div>
 <article>
 <header class="article-header">
 <div class="article-eyebrow">
 {pillar && <a href={`/pillars/${pillar}`} class="pillar-link">{pillarNames[pillar] ?? pillar}</a>}
 {pillar && tier && <span class="dot">·</span>}
 {tier && (
 <span class="tier-badge" style={`background:${tierColor}1A;color:${tierColor};border-color:${tierColor}40`}>{tier}</span>
 )}
 </div>

 <h1>{title}</h1>
 <p class="article-desc">{description}</p>

 <div class="article-meta">
 <time datetime={pubDate.toISOString()}>{formatted}</time>
 <span class="sep">·</span>
 <span class="read-time">{readTime} min read</span>
 {tags.length > 0 && (
 <div class="article-tags">
 {tags.map(tag => (
 <a href={`/topics#${tag}`} class="tag">{tag}</a>
 ))}
 </div>
 )}
 </div>
 </header>

 <div class="article-body prose">
 <slot />
 </div>

 <footer class="article-footer">
 <div class="article-footer-inner">
 <a href="/articles" class="back-link">← All articles</a>
 {pillar && <a href={`/pillars/${pillar}`} class="pillar-back">More in {pillarNames[pillar] ?? pillar} →</a>}
 <a href="mailto:goutham@madhadi.com" class="feedback-link">Send feedback →</a>
 </div>
 </footer>
 </article>
</Layout>

<style>
 .reading-bar {
 position: fixed;
 top: 0; left: 0;
 height: 3px;
 width: 0;
 background: var(--brass);
 z-index: 200;
 transition: width 0.08s linear;
 }

 article { max-width: var(--measure); margin: 0 auto; }

 .article-header {
 margin-bottom: 3rem;
 padding-bottom: 2rem;
 border-bottom: 1px solid var(--line);
 }

 .article-eyebrow {
 display: flex;
 align-items: center;
 gap: 0.65rem;
 margin-bottom: 1.5rem;
 }
 .pillar-link {
 font-family: var(--mono);
 font-size: 0.72rem;
 font-weight: 500;
 text-transform: uppercase;
 letter-spacing: 0.14em;
 color: var(--brass);
 }
 .pillar-link:hover { color: var(--navy); }
 .dot { color: var(--line-2); }

 h1 {
 font-family: var(--serif);
 font-weight: 500;
 font-size: clamp(2rem, 4.5vw, 3rem);
 line-height: 1.12;
 letter-spacing: -0.02em;
 margin-bottom: 1.1rem;
 color: var(--ink);
 }

 .article-desc {
 font-family: var(--serif);
 font-size: 1.3rem;
 font-style: italic;
 color: var(--muted);
 line-height: 1.5;
 max-width: 36rem;
 margin-bottom: 1.75rem;
 }

 .article-meta {
 display: flex;
 align-items: center;
 gap: 0.55rem;
 flex-wrap: wrap;
 }
 .article-meta time, .read-time {
 font-size: 0.8rem;
 color: var(--muted);
 font-family: var(--mono);
 }
 .sep { color: var(--line-2); }
 .article-tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-left: 0.25rem; }

 .article-body {
 font-size: 1.125rem;
 line-height: 1.78;
 color: var(--body);
 }

 .article-body :global(h2) {
 font-family: var(--serif);
 font-weight: 500;
 font-size: 1.7rem;
 letter-spacing: -0.01em;
 margin: 3.25rem 0 1.1rem;
 padding-top: 1.5rem;
 border-top: 1px solid var(--line);
 color: var(--ink);
 }

 .article-body :global(h3) {
 font-family: var(--serif);
 font-weight: 600;
 font-size: 1.3rem;
 margin: 2.5rem 0 0.8rem;
 color: var(--ink);
 }

 .article-body :global(h4) {
 font-family: var(--mono);
 font-size: 0.8rem;
 font-weight: 600;
 margin: 2rem 0 0.6rem;
 color: var(--navy);
 text-transform: uppercase;
 letter-spacing: 0.08em;
 }

 .article-body :global(p) { margin-bottom: 1.4rem; color: var(--body); }

 .article-body :global(ul),
 .article-body :global(ol) { margin-bottom: 1.4rem; padding-left: 1.5rem; }

 .article-body :global(li) { margin-bottom: 0.5rem; }

 .article-body :global(strong) { color: var(--ink); font-weight: 600; }

 .article-body :global(a) {
 color: var(--link);
 text-decoration: underline;
 text-underline-offset: 3px;
 text-decoration-color: var(--line-2);
 transition: text-decoration-color 0.15s;
 }
 .article-body :global(a:hover) { color: var(--link-h); text-decoration-color: var(--link); }

 .article-body :global(table) { margin: 2rem 0; }
 .article-body :global(blockquote) { font-size: 1.15rem; }

 .article-footer {
 max-width: var(--measure);
 margin: 4rem auto 0;
 padding-top: 2rem;
 border-top: 1px solid var(--line);
 }
 .article-footer-inner {
 display: flex;
 justify-content: space-between;
 align-items: center;
 gap: 1rem;
 flex-wrap: wrap;
 }
 .back-link, .feedback-link, .pillar-back {
 font-size: 0.875rem;
 font-weight: 500;
 color: var(--muted);
 transition: color 0.15s;
 }
 .pillar-back { color: var(--link); }
 .back-link:hover, .feedback-link:hover, .pillar-back:hover { color: var(--navy); }

 @media (max-width: 560px) {
 .article-desc { font-size: 1.15rem; }
 .article-footer-inner { flex-direction: column; align-items: flex-start; gap: 0.6rem; }
 }
</style>

<script is:inline>
 (function () {
 const bar = document.getElementById('reading-bar');
 if (!bar) return;
 const update = function () {
 const h = document.documentElement;
 const max = h.scrollHeight - h.clientHeight;
 const pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
 bar.style.width = Math.min(100, Math.max(0, pct * 100)) + '%';
 };
 window.addEventListener('scroll', update, { passive: true });
 window.addEventListener('resize', update);
 update();
 })();
</script>
