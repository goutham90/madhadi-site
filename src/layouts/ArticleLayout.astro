---
import Layout from './Layout.astro';
import { tagKey } from '../data/tags';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  tier?: string;
  pillar?: string;
  body?: string;
  relatedTemplates?: { slug: string; title: string; docType: string }[];
  pillarTemplates?: { slug: string; title: string; docType: string }[];
}

const { title, description, pubDate, tags, tier, pillar, body = '', relatedTemplates = [], pillarTemplates = [] } = Astro.props;
// Show the documents that target this article directly; otherwise fall back to documents in
// the same pillar so the article still connects to the library.
const deliverables = relatedTemplates.length ? relatedTemplates : pillarTemplates;
const deliverablesAreDirect = relatedTemplates.length > 0;

const tierColors: Record<string, string> = {
  Beginner: '#0f7a52',
  Intermediate: '#005ea2',
  Advanced: '#0b2e4f',
};

const pillarNames: Record<string, string> = {
  'data-integrity': 'Data Integrity',
  'csv-csa': 'CSV / CSA',
  'equipment-qualification': 'Equipment Qualification',
  'quality-assurance': 'Quality Assurance',
  'audits-inspection': 'Audits & Inspection',
  'cell-gene-therapy': 'Cell & Gene Therapy',
  'manufacturing-automation': 'Manufacturing Automation',
  'ai-automation': 'AI & Automation',
  'sterility-microbiology': 'Sterility & Microbiology',
  'regulatory-affairs': 'Regulatory Affairs',
  'medical-devices': 'Medical Devices & SaMD',
  'clinical-gcp': 'Clinical & GCP',
  'supply-chain-gdp': 'Supply Chain & GDP',
};

const pillarImg: Record<string, string> = {
  'data-integrity': '/images/records-review.jpg',
  'csv-csa': '/images/records-server.jpg',
  'equipment-qualification': '/images/instrument-bench.jpg',
  'quality-assurance': '/images/audit-signing.jpg',
  'audits-inspection': '/images/audit-paperwork.jpg',
  'cell-gene-therapy': '/images/microscopy-blue.jpg',
  'manufacturing-automation': '/images/manufacturing-cleanroom.jpg',
  'ai-automation': '/images/instrument-machine.jpg',
  'sterility-microbiology': '/images/microscopy-blue.jpg',
  'regulatory-affairs': '/images/audit-paperwork.jpg',
  'medical-devices': '/images/instrument-machine.jpg',
  'clinical-gcp': '/images/records-review.jpg',
  'supply-chain-gdp': '/images/manufacturing-cleanroom.jpg',
};
const heroImg = (pillar && pillarImg[pillar]) || '/images/lab-beakers.jpg';

const wordCount = body.split(/\s+/).length;
const readTime = Math.max(1, Math.ceil(wordCount / 220));
const tierColor = tier ? (tierColors[tier] ?? '#565c65') : '#565c65';

// "On this page" navigation, built from the article's H2 headings (ids added by
// remark-heading-ids using the same slug logic).
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-+|-+$)/g, '');
const toc = [...body.matchAll(/^##\s+(.+?)\s*$/gm)].map((m) => {
  const text = m[1].replace(/[*_`#\[\]]/g, '').trim();
  return { text, id: slugify(text) };
});
const hasRail = toc.length > 2 || deliverables.length > 0;
---
<Layout title={title} description={description} wide={true}>
  <div class="reading-bar" id="reading-bar"></div>

  <header class="art-hero">
    <img src={heroImg} alt="" loading="eager" />
    <div class="art-hero-grad"></div>
    <div class="wrap art-hero-inner">
      <nav class="crumb"><a href="/">Home</a> <span>›</span> <a href="/articles">Articles</a>{pillar && <> <span>›</span> <a href={`/pillars/${pillar}`}>{pillarNames[pillar] ?? pillar}</a></>}</nav>
      <div class="art-hero-eyebrow">
        {tier && <span class="tier-badge" style={`background:${tierColor}`}>{tier}</span>}
        {pillar && <a href={`/pillars/${pillar}`} class="art-pillar">{pillarNames[pillar] ?? pillar}</a>}
      </div>
      <h1 class="art-title">{title}</h1>
      <p class="art-standfirst">{description}</p>
      <div class="art-meta">
        <span>{readTime} min read</span>
        {tags.length > 0 && <span class="sep">·</span>}
        {tags.slice(0,4).map((t) => (<a href={`/topics#${tagKey(t)}`} class="art-tag">#{t}</a>))}
      </div>
    </div>
  </header>

  <div class="wrap art-shell">
    <div class={hasRail ? 'art-grid' : 'art-grid art-grid-single'}>
      <article class="art-body prose"><slot /></article>

      {hasRail && (
        <aside class="art-rail">
          {toc.length > 2 && (
            <nav class="art-toc" aria-label="On this page">
              <h2 class="art-rail-h">On this page</h2>
              <ul>
                {toc.map((t) => (<li><a href={`#${t.id}`}>{t.text}</a></li>))}
              </ul>
            </nav>
          )}

          {deliverables.length > 0 && (
            <section class="art-deliverables">
              <h2 class="art-rail-h">{deliverablesAreDirect ? 'Ready-to-use documents' : `Documents in ${pillarNames[pillar] ?? pillar}`}</h2>
              <p class="art-deliv-sub">Plug-and-play, inspection-grade. Copy, fill in your specifics, and use.</p>
              <ul class="art-deliv-list">
                {deliverables.map((t) => (
                  <li>
                    <a href={`/templates/${t.slug}`} class="art-deliv-row">
                      <span class="art-deliv-badge">{t.docType}</span>
                      <span class="art-deliv-title">{t.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <a class="art-deliv-all" href="/templates">All templates →</a>
            </section>
          )}
        </aside>
      )}
    </div>

    <footer class="art-footer">
      <a href="/articles" class="af-link">← All articles</a>
      {pillar && <a href={`/pillars/${pillar}`} class="af-link af-mid">More in {pillarNames[pillar] ?? pillar} →</a>}
      <a href="mailto:goutham@madhadi.com" class="af-link">Send feedback</a>
    </footer>
  </div>
</Layout>

<style>
  .reading-bar { position: fixed; top: 0; left: 0; height: 3px; width: 0; background: var(--blue); z-index: 200; transition: width 0.08s linear; }

  /* ── Image header with navy overlay ── */
  .art-hero { position: relative; min-height: 46vh; display: flex; align-items: flex-end; border-bottom: 4px solid var(--gold); background: var(--navy); }
  .art-hero > img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; }
  .art-hero-grad { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(11,46,79,0.55) 0%, rgba(11,46,79,0.78) 60%, rgba(11,46,79,0.95) 100%); z-index: 2; }
  .art-hero-inner { position: relative; z-index: 3; padding-top: 4rem; padding-bottom: 2.6rem; }

  .crumb { font-size: 0.82rem; color: var(--on-navy-dim); margin-bottom: 1.4rem; }
  .crumb a { color: var(--on-navy-dim); } .crumb a:hover { color: #fff; } .crumb span { opacity: 0.6; margin: 0 2px; }
  .art-hero-eyebrow { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.1rem; }
  .tier-badge { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #fff; padding: 4px 11px; border-radius: 3px; }
  .art-pillar { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #ffd98a; }
  .art-pillar:hover { color: #fff; }

  .art-title { font-family: var(--display); font-weight: 700; color: #fff; font-size: clamp(2rem, 4.4vw, 3.3rem); line-height: 1.08; letter-spacing: -0.025em; max-width: 22ch; margin-bottom: 1.1rem; }
  .art-standfirst { font-family: var(--serif); font-weight: 400; color: var(--on-navy); font-size: clamp(1.1rem, 1.7vw, 1.4rem); line-height: 1.45; max-width: 46ch; margin-bottom: 1.4rem; }
  .art-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.55rem; font-size: 0.84rem; color: var(--on-navy-dim); font-weight: 500; }
  .art-meta .sep { color: var(--gold); }
  .art-tag { color: var(--on-navy-dim); } .art-tag:hover { color: #fff; }

  /* ── Body: Newsreader serif for comfortable long-form reading ── */
  .art-shell { padding-top: 3.2rem; padding-bottom: 4.5rem; }
  /* Two-column reading layout: article on the left, sticky rail (contents + documents) on the right. */
  .art-grid { display: grid; grid-template-columns: minmax(0, var(--measure)) 19rem; gap: 3rem; justify-content: center; align-items: start; }
  .art-grid-single { grid-template-columns: minmax(0, var(--measure)); }
  .art-rail { position: sticky; top: 92px; display: flex; flex-direction: column; gap: 1.6rem; font-family: var(--sans); max-height: calc(100vh - 110px); overflow-y: auto; padding-right: 2px; }
  .art-rail-h { font-family: var(--display); font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--navy); margin-bottom: 0.55rem; }
  .art-toc ul { list-style: none; padding: 0; margin: 0; border-left: 2px solid var(--line); }
  .art-toc a { display: block; padding: 5px 0 5px 12px; margin-left: -2px; border-left: 2px solid transparent; font-size: 0.85rem; line-height: 1.35; color: var(--muted); }
  .art-toc a:hover { color: var(--blue); border-left-color: var(--blue); text-decoration: none; }
  .art-body { max-width: var(--measure); margin: 0 auto; font-family: var(--serif); font-size: 1.2rem; line-height: 1.72; color: #24292e; }
  .art-body :global(p) { margin-bottom: 1.4rem; }
  .art-body :global(> p:first-of-type) { font-size: 1.3rem; line-height: 1.6; color: var(--ink); }
  .art-body :global(h2) { font-family: var(--display); font-weight: 700; font-size: 1.7rem; letter-spacing: -0.02em; line-height: 1.15; margin: 2.8rem 0 1rem; padding-top: 1.6rem; border-top: 1px solid var(--line); color: var(--navy); }
  .art-body :global(h3) { font-family: var(--display); font-weight: 700; font-size: 1.3rem; margin: 2.2rem 0 0.7rem; color: var(--navy); }
  .art-body :global(h4) { font-family: var(--display); font-size: 0.95rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--blue); margin: 1.8rem 0 0.5rem; }
  .art-body :global(ul), .art-body :global(ol) { margin-bottom: 1.4rem; padding-left: 1.4rem; }
  .art-body :global(li) { margin-bottom: 0.5rem; }
  .art-body :global(strong) { color: var(--navy); font-weight: 600; }
  .art-body :global(a) { color: var(--blue); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--line-strong); }
  .art-body :global(a:hover) { color: var(--blue-d); text-decoration-color: var(--blue); }
  .art-body :global(blockquote) { border-left: 4px solid var(--gold); background: var(--panel); margin: 1.8rem 0; padding: 1rem 1.4rem; font-style: italic; color: var(--ink-2); }
  .art-body :global(blockquote p:last-child) { margin-bottom: 0; }
  .art-body :global(table) { width: 100%; border-collapse: collapse; margin: 1.8rem 0; font-family: var(--sans); font-size: 0.96rem; }
  .art-body :global(th), .art-body :global(td) { border: 1px solid var(--line); padding: 10px 14px; text-align: left; }
  .art-body :global(th) { background: var(--panel); color: var(--navy); font-weight: 700; }
  .art-body :global(code) { font-family: var(--mono); font-size: 0.88em; background: var(--panel); padding: 2px 6px; border-radius: 3px; }
  .art-body :global(pre) { font-family: var(--mono); font-size: 0.86rem; line-height: 1.55; border: 1px solid var(--line-strong); border-radius: var(--radius); padding: 1rem 1.2rem; overflow-x: auto; margin: 1.8rem 0; -webkit-overflow-scrolling: touch; }
  /* reset the inline-code style for code INSIDE a pre block (was making white boxes over the diagram) */
  .art-body :global(pre) :global(code) { background: none; padding: 0; border-radius: 0; font-size: inherit; color: inherit; white-space: pre; }
  .art-body :global(hr) { border: none; border-top: 1px solid var(--line); margin: 2.4rem 0; }

  /* ── Ready-to-use documents box (sits in the right rail) ── */
  .art-deliverables { background: var(--panel); border: 1px solid var(--line); border-left: 4px solid var(--gold); border-radius: var(--radius); padding: 1rem 1.1rem; }
  .art-deliv-all { display: inline-block; margin-top: 0.7rem; font-size: 0.85rem; font-weight: 700; color: var(--blue); }
  .art-deliv-all:hover { color: var(--blue-d); }
  .art-deliv-sub { font-size: 0.8rem; line-height: 1.4; color: var(--muted); margin-bottom: 0.8rem; }
  .art-deliv-list { list-style: none; padding: 0; margin: 0; }
  .art-deliv-row { display: flex; flex-direction: column; align-items: flex-start; gap: 4px; padding: 0.6rem 0; border-top: 1px solid var(--line); color: inherit; }
  .art-deliv-list li:first-child .art-deliv-row { border-top: none; padding-top: 0; }
  .art-deliv-badge { font-family: var(--mono); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--navy); background: var(--gold); padding: 2px 7px; border-radius: 3px; }
  .art-deliv-title { font-family: var(--sans); font-weight: 600; font-size: 0.9rem; line-height: 1.3; color: var(--navy); }
  .art-deliv-row:hover .art-deliv-title { color: var(--blue); text-decoration: underline; }

  .art-footer { max-width: var(--measure); margin: 3.5rem auto 0; padding-top: 1.6rem; border-top: 2px solid var(--navy); display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .af-link { font-size: 0.92rem; font-weight: 700; color: var(--blue); }
  .af-link:hover { color: var(--blue-d); }
  .af-mid { color: var(--navy); }

  @media (max-width: 1080px) {
    .art-grid, .art-grid-single { grid-template-columns: minmax(0, var(--measure)); }
    .art-rail { position: static; max-height: none; overflow: visible; margin-top: 2.5rem; border-top: 2px solid var(--navy); padding-top: 1.4rem; }
    .art-toc { display: none; }
  }
  @media (max-width: 700px) {
    .art-hero { min-height: 40vh; } .art-hero-inner { padding-top: 2.6rem; }
    .art-body { font-size: 1.12rem; } .art-body :global(> p:first-of-type) { font-size: 1.2rem; }
    .art-footer { flex-direction: column; align-items: flex-start; gap: 0.6rem; }
  }
</style>

<script is:inline>
  (function () {
    var bar = document.getElementById('reading-bar');
    if (!bar) return;
    function update() {
      var h = document.documentElement;
      var max = h.scrollHeight - h.clientHeight;
      var pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
      bar.style.width = Math.min(100, Math.max(0, pct * 100)) + '%';
    }
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
    update();
  })();
</script>
